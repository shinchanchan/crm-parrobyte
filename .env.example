# ============================================
# ParroByte CRM - Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://crm.parrobyte.co.in

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/whatscrm

# Session
SESSION_SECRET=your_session_secret_here

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=ParroByte CRM <your_email@gmail.com>

# Facebook / Instagram OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
INSTAGRAM_REDIRECT_URI=https://crm.parrobyte.co.in/instagram/oauth/callback

# Instagram Webhook (Meta webhook verification)
# Webhook URL in Meta dashboard: https://crm.parrobyte.co.in/instagram/webhook
# This is DIFFERENT from the OAuth callback URL above!
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=parrobyte_crm_verify_12345

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# YouTube API
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=https://crm.parrobyte.co.in/youtube/oauth/callback

# OpenAI / Ollama (optional)
OPENAI_API_KEY=your_openai_key

# WhatsApp Chromium path
PUPPETEER_EXECUTABLE_PATH=/snap/bin/chromium
