<!-- ===== Create Automation Modal ===== -->
<dialog id="automationModal" class="modal">
  <div class="modal-box glass-builder rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Create DM Automation Rule</h3>
    <form action="/social-automation/create" method="POST" data-loading-text="Creating automation...">
      <div class="space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Rule Name</label>
            <input type="text" name="name" required class="w-full px-4 py-2.5 rounded-xl glass-input text-sm outline-none" placeholder="Price inquiry reply">
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Platform</label>
            <select name="platform" id="saPlatform" class="w-full px-4 py-2.5 rounded-xl glass-input text-sm outline-none bg-transparent" onchange="updateAccountSelect()">
              <option value="facebook">Facebook</option>
              <option value="instagram">Instagram</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Connected Account</label>
          <select name="accountId" id="saAccountId" class="w-full px-4 py-2.5 rounded-xl glass-input text-sm outline-none bg-transparent">
            <% const activeFb = fbAccounts.filter(function(a){return a.isActive;});
               const activeIg = igAccounts.filter(function(a){return a.isActive;});
               if (!activeFb.length && !activeIg.length) { %>
              <option value="">No accounts connected - connect one first</option>
            <% } %>
            <% activeFb.forEach(function(a){ %>
              <option value="<%= a.id %>" data-platform="facebook"><%= a.accountName %> (Facebook)</option>
            <% }); %>
            <% activeIg.forEach(function(a){ %>
              <option value="<%= a.id %>" data-platform="instagram"><%= a.accountName %> (Instagram)</option>
            <% }); %>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Trigger</label>
            <select name="triggerType" class="w-full px-4 py-2.5 rounded-xl glass-input text-sm outline-none bg-transparent">
              <option value="contains">Contains</option>
              <option value="exact">Exact Match</option>
              <option value="starts_with">Starts With</option>
              <option value="regex">Regex</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Keyword / Phrase</label>
            <input type="text" name="triggerValue" required class="w-full px-4 py-2.5 rounded-xl glass-input text-sm outline-none" placeholder="price, hello, help">
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Response Type</label>
          <select name="responseType" id="saResponseType" onchange="toggleSaAiPrompt(this)" class="w-full px-4 py-2.5 rounded-xl glass-input text-sm outline-none bg-transparent">
            <option value="static">Static Text Reply</option>
            <option value="ai">AI Generated (Ollama)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Response Message</label>
          <textarea name="responseContent" rows="3" required class="w-full px-4 py-2.5 rounded-xl glass-input text-sm outline-none resize-none" placeholder="Thank you for messaging us! Our team will reply shortly."></textarea>
        </div>
        <div id="saAiPromptDiv" class="hidden">
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">AI Prompt Template</label>
          <textarea name="aiPrompt" rows="2" class="w-full px-4 py-2.5 rounded-xl glass-input text-sm outline-none resize-none" placeholder="System prompt for AI generation..."></textarea>
        </div>
      </div>
      <div class="flex gap-3 justify-end mt-4">
        <button type="button" onclick="document.getElementById('automationModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-save-line"></i> Create Rule</button>
      </div>
    </form>
  </div>
</dialog>

<script>
function toggleGuide(id) {
  var el = document.getElementById(id);
  el.classList.toggle('open');
  // Close the other guide
  var other = id === 'fbGuide' ? 'igGuide' : 'fbGuide';
  document.getElementById(other).classList.remove('open');
  // Scroll to guide
  if (el.classList.contains('open')) {
    setTimeout(function() { el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 100);
  }
}

function copyText(text) {
  navigator.clipboard.writeText(text).then(function() {
    // Flash a toast or change icon
    var btns = document.querySelectorAll('button[onclick*="' + text + '"]');
    btns.forEach(function(btn) {
      var old = btn.innerHTML;
      btn.innerHTML = '<i class="ri-check-line text-green-500"></i>';
      setTimeout(function() { btn.innerHTML = old; }, 1500);
    });
  });
}

function toggleSaAiPrompt(select) {
  document.getElementById('saAiPromptDiv').classList.toggle('hidden', select.value !== 'ai');
}

function updateAccountSelect() {
  var platform = document.getElementById('saPlatform').value;
  var select = document.getElementById('saAccountId');
  Array.from(select.options).forEach(function(opt) {
    if (opt.dataset.platform) {
      opt.style.display = opt.dataset.platform === platform ? '' : 'none';
    }
  });
  for (var i = 0; i < select.options.length; i++) {
    if (select.options[i].style.display !== 'none') { select.selectedIndex = i; break; }
  }
}

function toggleRule(id, btn) {
  fetch('/social-automation/toggle/' + id, { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        var icon = btn.querySelector('i');
        icon.className = data.isActive ? 'ri-toggle-fill text-green-500 text-xl' : 'ri-toggle-line text-gray-400 text-xl';
      }
    });
}

document.addEventListener('DOMContentLoaded', updateAccountSelect);
</script>
