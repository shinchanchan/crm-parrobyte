<div class="max-w-2xl mx-auto">
  <div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
    <div class="p-6 border-b border-pink-100 bg-gradient-to-r from-pink-50 to-white">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-pink-400 to-pink-600 flex items-center justify-center text-white font-bold text-2xl">
          <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
        </div>
        <div>
          <h2 class="text-xl font-bold text-gray-900"><%= user.name %></h2>
          <p class="text-sm text-gray-500"><%= user.email %></p>
          <span class="inline-flex items-center gap-1 mt-1 px-3 py-0.5 rounded-full text-xs font-bold bg-gradient-to-r from-pink-50 to-pink-100 text-pink-700 border border-pink-200">
            <i class="ri-coins-line"></i> ₹<%= parseFloat(typeof creditBalance !== 'undefined' ? creditBalance : (user.credits || 0)).toFixed(2) %>
          </span>
        </div>
      </div>
    </div>

    <div class="p-6 border-b border-pink-100">
      <h3 class="font-semibold text-gray-900 mb-4">Profile Information</h3>
      <form action="/auth/profile" method="POST" class="space-y-4">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
            <input type="text" name="name" value="<%= user.name %>" required
              class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" value="<%= user.email %>" disabled
              class="w-full px-4 py-2.5 rounded-xl border border-pink-200 bg-gray-50 text-sm text-gray-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Country Code</label>
            <input type="text" name="countryCode" value="<%= user.countryCode || '+1' %>"
              class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Timezone</label>
            <input type="text" name="timezone" value="<%= user.timezone || 'UTC' %>"
              class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Theme Color</label>
          <div class="flex items-center gap-3">
            <input type="color" name="themeColor" value="<%= user.themeColor || '#ec4899' %>"
              class="w-16 h-10 rounded-xl border border-pink-200 cursor-pointer"
              onchange="document.getElementById('themePreview').style.backgroundColor = this.value">
            <div id="themePreview" class="w-10 h-10 rounded-full" style="background:<%= user.themeColor || '#ec4899' %>"></div>
            <span class="text-xs text-gray-500">Choose your dashboard accent color</span>
          </div>
        </div>
        <button type="submit" class="px-6 py-2.5 bg-pink-600 text-white text-sm font-medium rounded-xl hover:bg-pink-700 transition-colors flex items-center gap-2">
          <i class="ri-save-line"></i> Save Changes
        </button>
      </form>
    </div>

    <div class="p-6 border-b border-pink-100">
      <h3 class="font-semibold text-gray-900 mb-4">Credits & Billing</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-gradient-to-br from-pink-50 to-pink-100 rounded-xl p-4 border border-pink-200">
          <p class="text-xs text-pink-600">Available Credits</p>
          <p class="text-2xl font-bold text-pink-700">₹<%= parseFloat(typeof creditBalance !== 'undefined' ? creditBalance : (user.credits || 0)).toFixed(2) %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <p class="text-xs text-gray-500">Email Status</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold <%= user.emailVerified ? 'text-green-600' : 'text-yellow-600' %>">
            <span class="w-2 h-2 rounded-full <%= user.emailVerified ? 'bg-green-500' : 'bg-yellow-500' %>"></span>
            <%= user.emailVerified ? 'Verified' : 'Not Verified' %>
          </span>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <p class="text-xs text-gray-500">Account Role</p>
          <p class="text-sm font-semibold text-gray-900 capitalize"><%= user.role %></p>
        </div>
      </div>
      <a href="/billing" class="mt-4 block w-full py-2.5 text-center text-sm font-medium text-pink-600 border border-pink-200 rounded-xl hover:bg-pink-50 transition-colors">
        <i class="ri-coins-line"></i> Top Up Credits
      </a>
    </div>

    <div class="p-6">
      <h3 class="font-semibold text-gray-900 mb-4">Change Password</h3>
      <form action="/auth/change-password" method="POST" class="space-y-4">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Current Password</label>
            <input type="password" name="currentPassword" required minlength="6"
              class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
            <input type="password" name="newPassword" required minlength="6"
              class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
          </div>
        </div>
        <button type="submit" class="px-6 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-xl hover:bg-gray-800 transition-colors flex items-center gap-2">
          <i class="ri-lock-password-line"></i> Update Password
        </button>
      </form>
    </div>
  </div>
</div>
