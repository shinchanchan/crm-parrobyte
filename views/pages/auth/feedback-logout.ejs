<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feedback - ParroByte CRM</title>
  <link rel="stylesheet" href="/css/app.css">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.1.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .btn-pink { background: linear-gradient(135deg, #ec4899 0%, #f472b6 100%); }
    .btn-pink:hover { background: linear-gradient(135deg, #db2777 0%, #ec4899 100%); }
  </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-pink-50 via-purple-50 to-blue-50 flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="w-16 h-16 rounded-2xl btn-pink flex items-center justify-center mx-auto mb-4 shadow-lg shadow-pink-200">
        <i class="ri-feedback-line text-white text-3xl"></i>
      </div>
      <h1 class="text-2xl font-bold text-gray-900">Before You Go...</h1>
      <p class="text-sm text-gray-500 mt-1">Help us improve by sharing your feedback</p>
    </div>

    <!-- Flash Messages -->
    <% const flashSuccess = typeof messages !== 'undefined' && messages.success && messages.success.length ? messages.success : null; %>
    <% const flashError = typeof messages !== 'undefined' && messages.error && messages.error.length ? messages.error : null; %>
    <% if (flashSuccess) { %>
      <div class="mb-4 bg-green-50 border border-green-200 rounded-xl p-4 flex items-center gap-3">
        <i class="ri-checkbox-circle-line text-green-500 text-xl"></i>
        <p class="text-sm text-green-700"><%= flashSuccess %></p>
      </div>
    <% } %>
    <% if (flashError) { %>
      <div class="mb-4 bg-red-50 border border-red-200 rounded-xl p-4 flex items-center gap-3">
        <i class="ri-error-warning-line text-red-500 text-xl"></i>
        <p class="text-sm text-red-700"><%= flashError %></p>
      </div>
    <% } %>

    <!-- Feedback Form -->
    <div class="bg-white rounded-2xl shadow-xl shadow-pink-100/50 border border-pink-100 p-6">
      <form action="/feedback/submit" method="POST" class="space-y-4">
        <!-- Name -->
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Your Name</label>
          <input type="text" name="name" required value="<%= userName || '' %>"
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-gray-50"
            placeholder="Your name">
        </div>

        <!-- Phone -->
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Phone Number</label>
          <input type="tel" name="phone"
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-gray-50"
            placeholder="9876543210">
        </div>

        <!-- Email -->
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Email</label>
          <input type="email" name="email" value="<%= userEmail || '' %>"
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-gray-50"
            placeholder="you@example.com">
        </div>

        <!-- Rating -->
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">How was your experience?</label>
          <div class="flex gap-2">
            <% for (let i = 1; i <= 5; i++) { %>
              <label class="cursor-pointer">
                <input type="radio" name="rating" value="<%= i %>" <%= i === 5 ? 'checked' : '' %> class="sr-only peer">
                <span class="text-2xl text-gray-300 peer-checked:text-pink-500 transition-colors hover:text-pink-400">
                  <i class="ri-star-fill"></i>
                </span>
              </label>
            <% } %>
          </div>
        </div>

        <!-- Message -->
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Your Feedback *</label>
          <textarea name="message" rows="3" required
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-gray-50 resize-none"
            placeholder="Tell us what you liked or how we can improve..."></textarea>
        </div>

        <!-- Buttons -->
        <div class="flex gap-3 pt-2">
          <a href="/logout/do" class="flex-1 px-4 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors text-center">
            Skip & Logout
          </a>
          <button type="submit" class="flex-1 px-4 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center justify-center gap-2">
            <i class="ri-send-plane-line"></i> Submit & Logout
          </button>
        </div>
      </form>
    </div>

    <p class="text-center text-xs text-gray-400 mt-6">
      <i class="ri-heart-line text-pink-400"></i> We appreciate your time, <%= userName || 'valued user' %>!
    </p>
  </div>
</body>
</html>
