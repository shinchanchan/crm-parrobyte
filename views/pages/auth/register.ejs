<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Create a ParroByte CRM account — start automating WhatsApp and managing leads today.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#ec4899">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <link rel="stylesheet" href="/css/app.css">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.1.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 50%, #fbcfe8 100%); min-height: 100vh; }
    .btn-pink { background: linear-gradient(135deg, #ec4899 0%, #f472b6 100%); }
    .btn-pink:hover { background: linear-gradient(135deg, #db2777 0%, #ec4899 100%); }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: #fce7f3; }
    ::-webkit-scrollbar-thumb { background: #ec4899; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #db2777; }
    * { scrollbar-width: thin; scrollbar-color: #ec4899 #fce7f3; }
  </style>
</head>
<body class="flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-3xl shadow-xl shadow-pink-100 border border-pink-100 p-8">
      <div class="text-center mb-8">
        <div class="w-16 h-16 rounded-2xl btn-pink flex items-center justify-center mx-auto mb-4">
          <i class="ri-user-add-line text-white text-3xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Create Account</h1>
        <p class="text-sm text-gray-500 mt-1">Start your free 3-day trial</p>
      </div>

      <% if (error && error.length > 0) { %>
        <div class="alert alert-error mb-4 bg-red-50 text-red-700 border border-red-200 text-sm">
          <i class="ri-error-warning-line"></i> <%= error %>
        </div>
      <% } %>

      <form action="/auth/register" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
          <div class="relative">
            <i class="ri-user-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="text" name="name" required minlength="2"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="Your full name">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
          <div class="relative">
            <i class="ri-mail-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="email" name="email" required
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="you@example.com">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Country Code</label>
          <div class="relative">
            <i class="ri-global-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="text" name="countryCode" 
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="+1" value="+1">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <div class="relative">
            <i class="ri-lock-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="password" name="password" required minlength="6" autocomplete="new-password"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="Min 6 characters">
          </div>
        </div>
        <button type="submit" class="w-full py-3.5 text-white font-semibold rounded-xl btn-pink shadow-lg shadow-pink-200 hover:shadow-xl transition-all flex items-center justify-center gap-2">
          <i class="ri-rocket-line"></i> Create Account
        </button>
      </form>

      <div class="mt-4 bg-blue-50 rounded-xl p-3 text-xs text-blue-700">
        <i class="ri-mail-check-line"></i> <strong>Email verification required:</strong> After registration, you'll receive a 6-digit OTP to verify your email before accessing your account.
      </div>

      <div class="mt-4 text-center">
        <p class="text-sm text-gray-600">Already have an account? <a href="/auth/login" class="text-pink-600 font-semibold hover:underline">Sign In</a></p>
        <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-pink-600 mt-3"><i class="ri-arrow-left-line"></i> Back to Home</a>
      </div>
    </div>
  </div>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function() {
        navigator.serviceWorker.register('/sw.js')
          .then(function(reg) { console.log('[PWA] SW registered'); })
          .catch(function(err) { console.log('[PWA] SW registration failed', err); });
      });
    }
  </script>
</body>
</html>
