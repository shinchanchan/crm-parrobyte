<div class="mb-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h2 class="text-xl font-bold text-gray-900">WhatsApp API Templates</h2>
      <p class="text-sm text-gray-500">Manage Meta-approved message templates for business-initiated conversations</p>
    </div>
    <div class="flex gap-2">
      <a href="/meta-whatsapp" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-xl transition-colors flex items-center gap-2">
        <i class="ri-arrow-left-line"></i> Back
      </a>
      <button onclick="document.getElementById('createTemplateModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2">
        <i class="ri-add-line"></i> New Template
      </button>
    </div>
  </div>
</div>

<!-- Credit Cost Banner -->
<div class="bg-gradient-to-r from-purple-50 to-pink-50 border border-purple-100 rounded-xl p-4 mb-6 flex items-center justify-between">
  <div class="flex items-center gap-3">
    <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center">
      <i class="ri-coins-line text-purple-600"></i>
    </div>
    <div>
      <p class="text-sm font-medium text-gray-700">Cost per template submission: <span class="text-purple-600 font-bold">₹<%= creditCost.toFixed(2) %></span></p>
      <p class="text-[10px] text-gray-500">Meta reviews templates within minutes to 24 hours. Credits deducted on submission.</p>
    </div>
  </div>
</div>

<!-- Sync Templates -->
<% if (accounts.length > 0) { %>
<div class="bg-white rounded-2xl border border-pink-100 p-4 mb-6">
  <form action="/meta-whatsapp/templates/sync" method="POST" class="flex items-center gap-3">
    <select name="accountId" required class="px-4 py-2 rounded-xl border border-pink-200 text-sm bg-white focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none">
      <% accounts.forEach(acc => { %>
        <option value="<%= acc.id %>"><%= acc.accountName %></option>
      <% }); %>
    </select>
    <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-xl hover:bg-blue-700 transition-all flex items-center gap-2">
      <i class="ri-refresh-line"></i> Sync from Meta
    </button>
    <p class="text-xs text-gray-400 ml-auto">Fetches latest template statuses from Meta</p>
  </form>
</div>
<% } %>

<!-- Templates Table -->
<div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
  <% if (templates.length === 0) { %>
    <div class="p-12 text-center">
      <div class="w-16 h-16 rounded-full bg-purple-50 flex items-center justify-center mx-auto mb-4">
        <i class="ri-file-list-3-line text-2xl text-purple-300"></i>
      </div>
      <h3 class="font-semibold text-gray-900 mb-2">No Templates Yet</h3>
      <p class="text-sm text-gray-500 mb-4 max-w-md mx-auto">Templates are required for sending business-initiated messages outside the 24-hour conversation window.</p>
      <button onclick="document.getElementById('createTemplateModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all inline-flex items-center gap-2">
        <i class="ri-add-line"></i> Create First Template
      </button>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Template</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Language</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Category</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Meta ID</th>
            <th class="text-right px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% templates.forEach(tpl => { %>
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-6 py-4">
                <p class="font-medium text-gray-900"><%= tpl.templateName %></p>
                <% if (tpl.rejectionReason) { %>
                  <p class="text-[10px] text-red-500 mt-0.5"><i class="ri-error-warning-line"></i> <%= tpl.rejectionReason %></p>
                <% } %>
              </td>
              <td class="px-6 py-4">
                <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-600 font-mono"><%= tpl.language %></span>
              </td>
              <td class="px-6 py-4">
                <span class="text-xs px-2 py-1 rounded-full
                  <%= tpl.category === 'MARKETING' ? 'bg-pink-100 text-pink-600' : tpl.category === 'AUTHENTICATION' ? 'bg-blue-100 text-blue-600' : 'bg-green-100 text-green-600' %> font-medium">
                  <%= tpl.category %>
                </span>
              </td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full
                  <%= tpl.status === 'approved' ? 'bg-green-100 text-green-700' : tpl.status === 'rejected' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %>">
                  <span class="w-1.5 h-1.5 rounded-full <%= tpl.status === 'approved' ? 'bg-green-500' : tpl.status === 'rejected' ? 'bg-red-500' : 'bg-amber-500' %>"></span>
                  <%= tpl.status %>
                </span>
              </td>
              <td class="px-6 py-4">
                <span class="text-[10px] font-mono text-gray-400"><%= tpl.metaTemplateId || '—' %></span>
              </td>
              <td class="px-6 py-4 text-right">
                <button onclick="viewTemplate('<%= tpl.id %>', '<%= encodeURIComponent(tpl.components || "") %>')" class="p-2 text-gray-400 hover:text-blue-500 hover:bg-blue-50 rounded-lg transition-colors" title="View Components">
                  <i class="ri-eye-line"></i>
                </button>
                <form action="/meta-whatsapp/templates/delete/<%= tpl.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this template? This will also remove it from Meta.')">
                  <button type="submit" class="p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
                    <i class="ri-delete-bin-line"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- Create Template Modal -->
<dialog id="createTemplateModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-2xl max-h-[90vh] overflow-y-auto">
    <h3 class="font-bold text-lg text-gray-900 mb-1">Create WhatsApp Template</h3>
    <p class="text-xs text-gray-500 mb-4">Submit a new template to Meta for approval</p>
    <form action="/meta-whatsapp/templates/create" method="POST" id="templateForm">
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Account *</label>
            <select name="accountId" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-white">
              <% accounts.forEach(acc => { %>
                <option value="<%= acc.id %>"><%= acc.accountName %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Template Name *</label>
            <input type="text" name="templateName" required pattern="[a-z0-9_]+"
              class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm font-mono"
              placeholder="welcome_message">
            <p class="text-[10px] text-gray-400 mt-1">Lowercase, numbers, underscores only</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Category *</label>
            <select name="category" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-white">
              <option value="UTILITY">UTILITY — Order updates, reminders</option>
              <option value="MARKETING">MARKETING — Promotions, announcements</option>
              <option value="AUTHENTICATION">AUTHENTICATION — OTP, verification</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Language *</label>
            <select name="language" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-white">
              <option value="en">English (en)</option>
              <option value="hi">Hindi (hi)</option>
              <option value="ta">Tamil (ta)</option>
              <option value="te">Telugu (te)</option>
              <option value="ml">Malayalam (ml)</option>
              <option value="kn">Kannada (kn)</option>
              <option value="mr">Marathi (mr)</option>
              <option value="gu">Gujarati (gu)</option>
              <option value="bn">Bengali (bn)</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Components (JSON) *</label>
          <textarea name="componentsJson" rows="10" required
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm font-mono resize-none"
            placeholder='[
  {
    "type": "BODY",
    "text": "Hello {{1}}, welcome to our service!"
  },
  {
    "type": "FOOTER",
    "text": "Reply STOP to unsubscribe"
  }
]'>[
  {
    "type": "BODY",
    "text": "Hello {{1}}, welcome to our service!"
  },
  {
    "type": "FOOTER",
    "text": "Reply STOP to unsubscribe"
  }
]</textarea>
          <div class="flex items-center justify-between mt-1">
            <p class="text-[10px] text-gray-400">Define header, body, footer, and buttons as JSON array</p>
            <button type="button" onclick="loadExample()" class="text-[10px] text-pink-600 hover:underline">Load Example</button>
          </div>
        </div>
      </div>
      <div class="flex gap-3 justify-end mt-4">
        <button type="button" onclick="document.getElementById('createTemplateModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg flex items-center gap-1">
          <i class="ri-upload-cloud-line mr-1"></i> Submit to Meta
        </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- View Components Modal -->
<dialog id="viewModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-2">Template Components</h3>
    <pre id="viewComponents" class="bg-gray-900 text-green-400 rounded-xl p-4 text-xs font-mono overflow-x-auto max-h-96 overflow-y-auto"></pre>
    <div class="flex justify-end mt-4">
      <button onclick="document.getElementById('viewModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Close</button>
    </div>
  </div>
</dialog>

<script>
function loadExample() {
  const example = JSON.stringify([
    {
      "type": "HEADER",
      "format": "TEXT",
      "text": "Welcome {{1}}!"
    },
    {
      "type": "BODY",
      "text": "Hi {{1}}, thanks for joining us. Your account is now active.\n\nNeed help? Reply to this message."
    },
    {
      "type": "FOOTER",
      "text": "Powered by ParroByte CRM"
    },
    {
      "type": "BUTTONS",
      "buttons": [
        { "type": "PHONE_NUMBER", "text": "Call Us", "phone_number": "+919876543210" },
        { "type": "URL", "text": "Visit Website", "url": "https://example.com" }
      ]
    }
  ], null, 2);
  document.querySelector('[name="componentsJson"]').value = example;
}

function viewTemplate(id, componentsEncoded) {
  const components = decodeURIComponent(componentsEncoded);
  let formatted;
  try {
    formatted = JSON.stringify(JSON.parse(components), null, 2);
  } catch {
    formatted = components;
  }
  document.getElementById('viewComponents').textContent = formatted;
  document.getElementById('viewModal').showModal();
}
</script>
