<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h2 class="text-xl font-bold text-gray-900">Send Message</h2>
    <p class="text-sm text-gray-500">Send individual messages via WhatsApp</p>
  </div>
</div>

<!-- Interactive Message Limitation Warning -->
<div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 flex items-start gap-3">
  <i class="ri-error-warning-line text-amber-600 text-lg mt-0.5"></i>
  <div class="text-xs text-amber-800 leading-relaxed">
    <strong>Polls:</strong> Poll messages work on all WhatsApp accounts. When a recipient votes, their response automatically creates or updates a lead in your CRM. Check the <strong>Message History</strong> below — poll messages show a green badge.
  </div>
</div>

<div class="bg-white rounded-2xl border border-pink-100 p-6 mb-6">
  <form action="/messages/send" method="POST" enctype="multipart/form-data" data-loading-text="Sending..." onsubmit="return prepareMsgSubmit()">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <% if (isAdmin) { %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Session *</label>
          <select name="sessionId" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <% sessions.filter(s => s.status === 'connected').forEach(s => { %>
              <option value="<%= s.id %>"><%= s.sessionName %></option>
            <% }); %>
          </select>
        </div>
      <% } else if (sharedSession) { %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Session</label>
          <div class="w-full px-4 py-2.5 rounded-xl border border-green-200 bg-green-50 text-sm flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <span class="text-green-800 font-medium"><%= sharedSession.sessionName %> (<%= sharedSession.phoneNumber || 'Admin' %>)</span>
          </div>
          <input type="hidden" name="sessionId" value="<%= sharedSession.id %>">
          <p class="text-[10px] text-gray-400 mt-1">Using admin's shared session</p>
        </div>
      <% } else { %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Session</label>
          <div class="w-full px-4 py-2.5 rounded-xl border border-red-200 bg-red-50 text-sm text-red-700">
            <i class="ri-error-warning-line mr-1"></i> No shared session available. Contact your admin.
          </div>
        </div>
      <% } %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number *</label>
        <input type="tel" name="phone" required placeholder="919876543210"
          class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Template (optional)</label>
        <select name="templateId" id="msgTemplateSelect" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white"
          onchange="fillMsgTemplate(this)">
          <option value="">Select template</option>
          <% templates.forEach(t => { %>
            <option value="<%= t.id %>" data-content="<%= (t.content || '').replace(/"/g, '&quot;') %>" data-type="<%= t.type %>" data-mediaurl="<%= t.mediaUrl || '' %>" data-variables="<%= (t.variables || '').replace(/"/g, '&quot;') %>"><%= t.name %> <%= t.type !== 'text' ? '(' + t.type + ')' : '' %></option>
          <% }); %>
        </select>
      </div>
    </div>
    <input type="hidden" name="type" id="msgType" value="text">
    <input type="hidden" name="mediaUrl" id="msgMediaUrl" value="">

    <!-- Message Type Tabs -->
    <div class="mt-4">
      <label class="block text-sm font-medium text-gray-700 mb-2">Message Type</label>
      <div class="flex gap-2 flex-wrap">
        <button type="button" onclick="setMsgType('text')" id="tab-text" class="msg-type-tab px-4 py-2 rounded-xl text-sm font-medium transition-all bg-pink-100 text-pink-700 border border-pink-200">
          <i class="ri-chat-1-line mr-1"></i> Text / Media
        </button>
        <button type="button" onclick="setMsgType('poll')" id="tab-poll" class="msg-type-tab px-4 py-2 rounded-xl text-sm font-medium transition-all bg-gray-100 text-gray-600 border border-gray-200 hover:bg-gray-200">
          <i class="ri-bar-chart-box-line mr-1"></i> Poll
        </button>
      </div>
    </div>

    <!-- Text / Media Input -->
    <div id="panel-text" class="msg-panel mt-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
      <textarea id="msgContent" name="content" rows="4" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></textarea>
      <div class="mt-4 grid md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Media File (optional — max 150MB)</label>
          <input type="file" name="mediaFile" id="msgMediaFile" accept="image/*,video/*,audio/*,.pdf,.doc,.docx"
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-pink-50 file:text-pink-600 hover:file:bg-pink-100">
        </div>
        <div id="msgRecorderBox">
          <%- include('../../partials/audio-recorder', { inputId: 'msgMediaUrl', containerId: 'msgRecorderWrap', typeInputId: 'msgType', showMic: false, showFileUpload: true }) %>
        </div>
      </div>
    </div>

    <!-- Poll Panel -->
    <div id="panel-poll" class="msg-panel mt-4 hidden">
      <div class="bg-green-50 border border-green-100 rounded-xl p-4">
        <p class="text-xs text-green-700 mb-3"><i class="ri-information-line mr-1"></i> Polls let recipients vote on options. Votes automatically create or update leads with the selected options.</p>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Poll Question *</label>
            <textarea name="content" rows="2" class="poll-content w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm resize-none" placeholder="Which package do you prefer?"></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Poll Options *</label>
            <textarea name="pollOptions" rows="4" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm font-mono text-xs resize-none" placeholder="Starter&#10;Pro&#10;Enterprise"></textarea>
            <p class="text-[10px] text-gray-400 mt-1">One option per line. Minimum 2 options required.</p>
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" name="pollAllowMultiple" id="pollAllowMultiple" value="true" class="rounded border-pink-200 text-pink-500">
            <label for="pollAllowMultiple" class="text-xs text-gray-600">Allow multiple answers</label>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-4 flex justify-end">
      <button type="submit" class="px-6 py-2.5 btn-pink text-white text-sm font-medium rounded-xl flex items-center gap-2">
        <i class="ri-send-plane-line"></i> Send Message
      </button>
    </div>
  </form>

  <script>
  function fillMsgTemplate(select) {
    const option = select.options[select.selectedIndex];
    const contentEl = document.getElementById('msgContent');
    const typeEl = document.getElementById('msgType');
    const mediaEl = document.getElementById('msgMediaUrl');
    const recorderBox = document.getElementById('msgRecorderBox');
    if (option.value) {
      const type = option.dataset.type || 'text';
      contentEl.value = option.dataset.content || '';
      typeEl.value = type;
      mediaEl.value = option.dataset.mediaurl || '';
      if (type === 'audio') {
        recorderBox.classList.add('hidden');
      } else {
        recorderBox.classList.remove('hidden');
      }
      // Handle poll template
      if (type === 'poll') {
        setMsgType('poll');
        try {
          const vars = JSON.parse(option.dataset.variables || '{}');
          const pollOpts = document.querySelector('#panel-poll textarea[name="pollOptions"]');
          const pollAllow = document.getElementById('pollAllowMultiple');
          if (pollOpts && vars.pollOptions) pollOpts.value = vars.pollOptions.join('\n');
          if (pollAllow) pollAllow.checked = !!vars.allowMultipleAnswers;
        } catch (e) {}
      } else {
        setMsgType('text');
      }
    } else {
      typeEl.value = 'text';
      mediaEl.value = '';
      recorderBox.classList.remove('hidden');
    }
  }

  function setMsgType(type) {
    document.getElementById('msgType').value = type;

    // Update tabs
    document.querySelectorAll('.msg-type-tab').forEach(tab => {
      tab.classList.remove('bg-pink-100', 'text-pink-700', 'border-pink-200');
      tab.classList.add('bg-gray-100', 'text-gray-600', 'border-gray-200');
    });
    const activeTab = document.getElementById('tab-' + type);
    if (activeTab) {
      activeTab.classList.remove('bg-gray-100', 'text-gray-600', 'border-gray-200');
      activeTab.classList.add('bg-pink-100', 'text-pink-700', 'border-pink-200');
    }

    // Show/hide panels
    document.querySelectorAll('.msg-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById('panel-' + type).classList.remove('hidden');

    // Update required fields and clear inactive panels
    const textContent = document.getElementById('msgContent');
    const pollContent = document.querySelector('.poll-content');

    if (type === 'text') {
      if (textContent) textContent.required = true;
      if (pollContent) { pollContent.required = false; pollContent.value = ''; }
    } else if (type === 'poll') {
      if (textContent) { textContent.required = false; textContent.value = ''; }
      if (pollContent) pollContent.required = true;
    }
  }

  function prepareMsgSubmit() {
    // Clear inactive panels to avoid duplicate array submission
    const msgType = document.getElementById('msgType').value;
    const textContent = document.getElementById('msgContent');
    const pollContent = document.querySelector('.poll-content');

    if (msgType === 'poll') {
      if (textContent && pollContent) textContent.value = pollContent.value;
    } else {
      if (pollContent) pollContent.value = '';
    }
    return true;
  }
  </script>
</div>

<!-- Message History with Pagination -->
<div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
  <div class="p-5 border-b border-pink-100 flex items-center justify-between">
    <h3 class="font-semibold text-gray-900">Message History</h3>
    <% if (typeof pagination !== 'undefined' && pagination) { %>
      <span class="text-xs text-gray-500"><%= pagination.total %> total</span>
    <% } %>

<!-- Message Details Modal -->
<div id="msgDetailsModal" class="fixed inset-0 z-50 hidden" style="background: rgba(0,0,0,0.4);">
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold text-gray-900 text-sm">Message Details</h3>
        <button type="button" onclick="closeMsgDetails()" class="text-gray-400 hover:text-gray-600">
          <i class="ri-close-line text-lg"></i>
        </button>
      </div>
      <div id="msgDetailsContent" class="text-sm text-gray-600 space-y-3"></div>
      <div class="mt-5 flex justify-end">
        <button type="button" onclick="closeMsgDetails()" class="px-4 py-2 bg-gray-100 text-gray-700 text-xs font-medium rounded-lg hover:bg-gray-200">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
function showMsgDetails(data, type) {
  let html = '';
  const d = typeof data === 'string' ? JSON.parse(data) : data;
  
  if (type === 'buttons') {
    html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Type</span><div class="mt-1"><span class="text-xs bg-blue-100 text-blue-600 px-2 py-0.5 rounded-full">Buttons</span></div></div>';
    if (d.title) html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Title</span><p class="mt-0.5 text-gray-800">' + escapeHtml(d.title) + '</p></div>';
    if (d.footer) html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Footer</span><p class="mt-0.5 text-gray-800">' + escapeHtml(d.footer) + '</p></div>';
    html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Buttons (' + (d.buttons || []).length + ')</span><ul class="mt-1 space-y-1">';
    (d.buttons || []).forEach(function(b, i) {
      html += '<li class="flex items-center gap-2"><span class="text-xs bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded">' + (i+1) + '</span><span>' + escapeHtml(b.body || b) + '</span></li>';
    });
    html += '</ul></div>';
  } else if (type === 'list') {
    html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Type</span><div class="mt-1"><span class="text-xs bg-purple-100 text-purple-600 px-2 py-0.5 rounded-full">List</span></div></div>';
    if (d.title) html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Title</span><p class="mt-0.5 text-gray-800">' + escapeHtml(d.title) + '</p></div>';
    if (d.footer) html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Footer</span><p class="mt-0.5 text-gray-800">' + escapeHtml(d.footer) + '</p></div>';
    html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Button Text</span><p class="mt-0.5 text-gray-800">' + escapeHtml(d.buttonText || 'Select') + '</p></div>';
    html += '<div><span class="text-xs font-semibold text-gray-500 uppercase">Sections</span>';
    (d.sections || []).forEach(function(s) {
      html += '<div class="mt-2 bg-gray-50 rounded-lg p-3"><p class="text-xs font-medium text-gray-700 mb-2">' + escapeHtml(s.title) + '</p><ul class="space-y-1">';
      (s.rows || []).forEach(function(r) {
        html += '<li class="text-xs text-gray-600"><span class="font-medium text-gray-800">' + escapeHtml(r.title) + '</span>' + (r.description ? '<br><span class="text-gray-400">' + escapeHtml(r.description) + '</span>' : '') + '</li>';
      });
      html += '</ul></div>';
    });
    html += '</div>';
  } else {
    html += '<p class="text-gray-500">No interactive details available.</p>';
  }
  
  document.getElementById('msgDetailsContent').innerHTML = html;
  document.getElementById('msgDetailsModal').classList.remove('hidden');
}

function closeMsgDetails() {
  document.getElementById('msgDetailsModal').classList.add('hidden');
}

function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// Close modal on backdrop click
document.getElementById('msgDetailsModal').addEventListener('click', function(e) {
  if (e.target === this) closeMsgDetails();
});
</script>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-pink-100">
        <tr>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Phone</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Content</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Type</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Status</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% messages.forEach(m => { %>
          <tr class="hover:bg-pink-50/50 transition-colors">
            <td class="px-6 py-3 font-medium text-gray-900"><%= m.phone %></td>
            <td class="px-6 py-3 text-gray-600 max-w-xs truncate"><%= m.content %></td>
            <td class="px-6 py-3">
              <span class="text-xs capitalize px-2 py-1 rounded-full
                <%= m.type === 'poll' ? 'bg-green-100 text-green-600' : m.type === 'image' ? 'bg-pink-100 text-pink-600' : m.type === 'video' ? 'bg-red-100 text-red-600' : m.type === 'audio' ? 'bg-amber-100 text-amber-600' : 'bg-gray-100 text-gray-600' %>">
                <i class="ri-<%= m.type === 'poll' ? 'bar-chart-box-line' : m.type === 'image' ? 'image-line' : m.type === 'video' ? 'video-line' : m.type === 'audio' ? 'mic-line' : m.type === 'document' ? 'file-line' : 'chat-1-line' %> mr-1"></i>
                <%= m.type %>
              </span>
            </td>
            <td class="px-6 py-3">
              <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full
                <%= m.status === 'sent' || m.status === 'delivered' ? 'bg-green-100 text-green-700' : m.status === 'failed' ? 'bg-red-100 text-red-700' : m.status === 'sending' ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-600' %>">
                <% if (m.status === 'sending') { %><div class="loading-spinner w-3 h-3 border-2"></div><% } %>
                <%= m.status %>
              </span>
            </td>
            <td class="px-6 py-3">
              <% if (m.interactiveData) { %>
                <button type="button" onclick='showMsgDetails(<%= JSON.stringify(m.interactiveData) %>, "<%= m.type %>")' class="text-xs text-pink-600 hover:text-pink-700 font-medium underline">
                  View
                </button>
              <% } else { %>
                <span class="text-xs text-gray-400">—</span>
              <% } %>
            </td>
            <td class="px-6 py-3 text-xs text-gray-500"><%= m.sentAt ? new Date(m.sentAt).toLocaleString() : new Date(m.createdAt).toLocaleString() %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (!messages || messages.length === 0) { %>
    <div class="p-8 text-center">
      <p class="text-sm text-gray-500">No messages sent yet</p>
    </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
<style>
  .page-btn { min-width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; font-size: 13px; font-weight: 500; border: 1px solid #e5e7eb; background: #fff; color: #374151; transition: all 0.15s; cursor: pointer; text-decoration: none; }
  .page-btn:hover { border-color: #ec4899; color: #ec4899; }
  .page-btn.active { background: #ec4899; color: #fff; border-color: #ec4899; }
  .page-btn.disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }
  .per-page-select { padding: 6px 28px 6px 12px; border-radius: 10px; border: 1px solid #e5e7eb; background: #fff url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e") right 8px center/16px no-repeat; font-size: 13px; color: #374151; appearance: none; -webkit-appearance: none; cursor: pointer; }
</style>
<div class="flex flex-wrap items-center justify-between gap-3 mt-4 px-2">
  <div class="text-xs text-gray-500">
    Showing <span class="font-semibold text-gray-700"><%= (pagination.page - 1) * pagination.perPage + 1 %></span>
    – <span class="font-semibold text-gray-700"><%= Math.min(pagination.page * pagination.perPage, pagination.total) %></span>
    of <span class="font-semibold text-gray-700"><%= pagination.total %></span>
  </div>
  <div class="flex items-center gap-2">
    <a href="/messages?page=<%= pagination.page - 1 %>&perPage=<%= pagination.perPage %>" class="page-btn <%= pagination.hasPrev ? '' : 'disabled' %>"><i class="ri-arrow-left-s-line"></i></a>
    <% pagination.pageRange.forEach(p => { %>
      <a href="/messages?page=<%= p %>&perPage=<%= pagination.perPage %>" class="page-btn <%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
    <% }); %>
    <a href="/messages?page=<%= pagination.page + 1 %>&perPage=<%= pagination.perPage %>" class="page-btn <%= pagination.hasNext ? '' : 'disabled' %>"><i class="ri-arrow-right-s-line"></i></a>
    <select class="per-page-select ml-2" onchange="window.location.href='/messages?page=1&perPage=' + this.value">
      <option value="10" <%= pagination.perPage === 10 ? 'selected' : '' %>>10</option>
      <option value="30" <%= pagination.perPage === 30 ? 'selected' : '' %>>30</option>
      <option value="50" <%= pagination.perPage === 50 ? 'selected' : '' %>>50</option>
    </select>
  </div>
</div>
<% } %>
