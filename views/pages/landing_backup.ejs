<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="ParroByte CRM — All-in-one WhatsApp automation, lead management, enquiry forms, business scraper, email automation, and social media tools for growing businesses.">
  <meta name="keywords" content="WhatsApp CRM, WhatsApp automation, lead management, enquiry forms, business scraper, email automation, bulk messaging, ParroByte">
  <meta name="author" content="ParroByte CRM">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://crm.parrobyte.co.in/">
  <link rel="icon" type="image/svg+xml" href="/crm.png">
  <link rel="shortcut icon" href="/crm.png">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="All-in-one WhatsApp automation and lead management platform for growing businesses.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://crm.parrobyte.co.in/">
  <meta property="og:image" content="https://crm.parrobyte.co.in/crm.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="All-in-one WhatsApp automation and lead management platform for growing businesses.">
  <meta name="twitter:image" content="https://crm.parrobyte.co.in/crm.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/daisyui@4.10.1/dist/full.min.css" rel="stylesheet" type="text/css" />
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.1.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#ec4899',
            secondary: '#f472b6',
            accent: '#fbcfe8',
          },
        },
      },
    };
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .gradient-bg { background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 50%, #fbcfe8 100%); }
    .btn-pink { background: linear-gradient(135deg, #ec4899 0%, #f472b6 100%); }
    .btn-pink:hover { background: linear-gradient(135deg, #db2777 0%, #ec4899 100%); }
    .hero-pattern { background-image: radial-gradient(circle at 1px 1px, rgba(236,72,153,0.08) 1px, transparent 0); background-size: 40px 40px; }
    .service-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px -12px rgba(236, 72, 153, 0.15); }
  </style>
</head>
<body class="gradient-bg min-h-screen">
  <!-- Navbar -->
  <nav class="bg-white/80 backdrop-blur-md border-b border-pink-100 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl btn-pink flex items-center justify-center">
            <i class="ri-whatsapp-line text-white text-xl"></i>
          </div>
          <span class="font-bold text-xl text-gray-900">ParroByte CRM</span>
        </div>
        <div class="flex items-center gap-3">
          <a href="/auth/login" class="px-5 py-2 text-sm font-medium text-gray-700 hover:text-pink-600 transition-colors">Sign In</a>
          <a href="/auth/register" class="px-5 py-2.5 text-sm font-medium text-white rounded-xl btn-pink shadow-lg shadow-pink-200 hover:shadow-xl transition-all">Get Started</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero-pattern py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-pink-100 text-pink-700 rounded-full text-sm font-medium mb-6">
            <i class="ri-sparkling-line"></i> All-in-One Business Automation CRM
          </div>
          <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 leading-tight mb-6">
            Automate Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-pink-700">Business Growth</span>
          </h1>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            WhatsApp CRM, YouTube auto-reply, Instagram automation, AI assistant, lead scraping, bulk messaging, scheduling, and more — all in one powerful platform. Pay only for what you use.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/auth/register" class="px-8 py-4 text-white font-semibold rounded-xl btn-pink shadow-lg shadow-pink-200 hover:shadow-xl transition-all flex items-center gap-2">
              <i class="ri-rocket-line"></i> Get Started Free
            </a>
            <a href="#services" class="px-8 py-4 bg-white text-pink-600 font-semibold rounded-xl border-2 border-pink-200 hover:border-pink-400 transition-all flex items-center gap-2">
              <i class="ri-apps-line"></i> Explore Services
            </a>
          </div>
          <div class="flex items-center gap-6 mt-8 text-sm text-gray-500">
            <span class="flex items-center gap-1.5"><i class="ri-check-line text-green-500"></i> No credit card required</span>
            <span class="flex items-center gap-1.5"><i class="ri-check-line text-green-500"></i> 50 free credits on signup</span>
            <span class="flex items-center gap-1.5"><i class="ri-check-line text-green-500"></i> Pay as you go</span>
          </div>
        </div>
        <div class="relative">
          <div class="bg-white rounded-3xl shadow-2xl shadow-pink-100 p-6 lg:p-8 border border-pink-100">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-2xl bg-green-100 flex items-center justify-center">
                <i class="ri-whatsapp-line text-green-600 text-2xl"></i>
              </div>
              <div>
                <p class="font-semibold text-gray-900">WhatsApp Connected</p>
                <p class="text-sm text-green-600 flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-500"></span> Online</p>
              </div>
            </div>
            <div class="space-y-3">
              <div class="flex items-center gap-3 p-3 bg-pink-50 rounded-xl">
                <div class="w-8 h-8 rounded-lg bg-pink-200 flex items-center justify-center text-pink-700 text-sm font-bold">J</div>
                <div class="flex-1"><p class="text-sm font-medium text-gray-900">John Doe</p><p class="text-xs text-gray-500">+1 234 567 890</p></div>
                <span class="text-xs text-green-600 bg-green-100 px-2 py-1 rounded-full">Sent</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
                <div class="w-8 h-8 rounded-lg bg-purple-200 flex items-center justify-center text-purple-700 text-sm font-bold">S</div>
                <div class="flex-1"><p class="text-sm font-medium text-gray-900">Sarah Smith</p><p class="text-xs text-gray-500">+1 987 654 321</p></div>
                <div class="w-4 h-4 border-2 border-pink-500 border-t-transparent rounded-full animate-spin"></div>
              </div>
              <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
                <div class="w-8 h-8 rounded-lg bg-blue-200 flex items-center justify-center text-blue-700 text-sm font-bold">M</div>
                <div class="flex-1"><p class="text-sm font-medium text-gray-900">Mike Johnson</p><p class="text-xs text-gray-500">+44 789 012 345</p></div>
                <span class="text-xs text-green-600 bg-green-100 px-2 py-1 rounded-full">Sent</span>
              </div>
            </div>
          </div>
          <div class="absolute -top-4 -right-4 w-20 h-20 bg-pink-400 rounded-full opacity-20 blur-2xl"></div>
          <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-purple-400 rounded-full opacity-10 blur-3xl"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- All Services Section -->
  <section id="services" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Everything You Get</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">A complete suite of automation tools to grow your business across WhatsApp, YouTube, Instagram, and more.</p>
      </div>

      <!-- Core Services -->
      <div class="mb-12">
        <h3 class="text-lg font-semibold text-gray-800 mb-6 flex items-center gap-2">
          <i class="ri-apps-line text-pink-500"></i> Core CRM Services
        </h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% const coreServices = [
            { icon: 'ri-qr-code-line', color: 'bg-green-100 text-green-600', title: 'Multiple WhatsApp Sessions', desc: 'Connect and manage multiple WhatsApp Business accounts simultaneously using QR code scanning. Perfect for agencies managing client accounts.' },
            { icon: 'ri-send-plane-line', color: 'bg-blue-100 text-blue-600', title: 'Bulk Messaging', desc: 'Send messages to thousands of contacts with smart rate limiting (30-50s gap) to prevent WhatsApp account bans and ensure deliverability.' },
            { icon: 'ri-file-list-line', color: 'bg-amber-100 text-amber-600', title: 'Message Templates', desc: 'Create reusable text, image, document, and video templates for quick messaging. Save time by using pre-built responses.' },
            { icon: 'ri-calendar-schedule-line', color: 'bg-purple-100 text-purple-600', title: 'Schedule Messages', desc: 'Plan campaigns to be sent at optimal times with daily, weekly, or monthly repeat options. Never miss a follow-up again.' },
            { icon: 'ri-robot-line', color: 'bg-pink-100 text-pink-600', title: 'Auto Reply', desc: 'Set up intelligent keyword-based auto-replies and AI-generated responses. Reply instantly even when you are offline.' },
            { icon: 'ri-contacts-line', color: 'bg-indigo-100 text-indigo-600', title: 'Contact Management', desc: 'Import contacts via CSV, organize with groups and tags, and manage your entire contact list from one dashboard.' },
          ]; %>
          <% coreServices.forEach(s => { %>
            <div class="service-card p-6 rounded-2xl bg-gradient-to-br from-gray-50 to-white border border-gray-100 transition-all duration-300">
              <div class="w-12 h-12 rounded-xl <%= s.color %> flex items-center justify-center mb-4">
                <i class="<%= s.icon %> text-2xl"></i>
              </div>
              <h4 class="font-semibold text-gray-900 mb-2"><%= s.title %></h4>
              <p class="text-sm text-gray-600 leading-relaxed"><%= s.desc %></p>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Social Media Automation -->
      <div class="mb-12">
        <h3 class="text-lg font-semibold text-gray-800 mb-6 flex items-center gap-2">
          <i class="ri-youtube-line text-red-500"></i> Social Media Automation
        </h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% const socialServices = [
            { icon: 'ri-youtube-line', color: 'bg-red-100 text-red-600', title: 'YouTube Auto-Reply', desc: 'Connect your YouTube channel and automatically reply to comments based on keywords. Save hours of manual engagement. Supports exact match, contains, starts_with, ends_with, and regex triggers.' },
            { icon: 'ri-instagram-line', color: 'bg-gradient-to-br from-purple-100 to-pink-100 text-purple-600', title: 'Instagram Auto-Reply', desc: 'Connect your Instagram Business account and auto-reply to post comments. Engage with your audience 24/7 without lifting a finger. Deduplication prevents double replies.' },
            { icon: 'ri-messenger-line', color: 'bg-blue-100 text-blue-600', title: 'Social Automation (Facebook/IG DMs)', desc: 'Automate Facebook and Instagram direct messages. Set up keyword triggers and auto-responses for incoming DMs.' },
          ]; %>
          <% socialServices.forEach(s => { %>
            <div class="service-card p-6 rounded-2xl bg-gradient-to-br from-gray-50 to-white border border-gray-100 transition-all duration-300">
              <div class="w-12 h-12 rounded-xl <%= s.color %> flex items-center justify-center mb-4">
                <i class="<%= s.icon %> text-2xl"></i>
              </div>
              <h4 class="font-semibold text-gray-900 mb-2"><%= s.title %></h4>
              <p class="text-sm text-gray-600 leading-relaxed"><%= s.desc %></p>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- AI & Smart Tools -->
      <div class="mb-12">
        <h3 class="text-lg font-semibold text-gray-800 mb-6 flex items-center gap-2">
          <i class="ri-brain-line text-violet-500"></i> AI & Smart Tools
        </h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% const aiServices = [
            { icon: 'ri-brain-line', color: 'bg-violet-100 text-violet-600', title: 'AI Assistant (Ollama)', desc: 'AI-powered responses using your own Ollama instance. Configure system prompts, business data, and temperature. Queue-based processing ensures low resource usage.' },
            { icon: 'ri-map-pin-line', color: 'bg-emerald-100 text-emerald-600', title: 'Business Scraper', desc: 'Scrape Google Maps for business leads with name, phone, address, website, and ratings. Export to CSV or directly add to your contacts.' },
            { icon: 'ri-survey-line', color: 'bg-cyan-100 text-cyan-600', title: 'Enquiry Forms', desc: 'Build custom lead capture forms with your branding. Share via public link or Meta ads. Every submission becomes a lead in your CRM.' },
            { icon: 'ri-user-search-line', color: 'bg-rose-100 text-rose-600', title: 'Lead Management', desc: 'Track leads from forms, scraper, manual entry, and enquiries. Move leads through status pipeline: New → Contacted → Qualified → Converted.' },
            { icon: 'ri-bar-chart-line', color: 'bg-orange-100 text-orange-600', title: 'Analytics Dashboard', desc: 'Real-time stats on messages sent, contacts added, sessions connected, and credit usage. Visual progress bars show your activity at a glance.' },
            { icon: 'ri-key-line', color: 'bg-teal-100 text-teal-600', title: 'Developer API & Webhooks', desc: 'Generate secure API keys for external integration. Receive real-time webhooks for message events, session connects, and disconnects.' },
          ]; %>
          <% aiServices.forEach(s => { %>
            <div class="service-card p-6 rounded-2xl bg-gradient-to-br from-gray-50 to-white border border-gray-100 transition-all duration-300">
              <div class="w-12 h-12 rounded-xl <%= s.color %> flex items-center justify-center mb-4">
                <i class="<%= s.icon %> text-2xl"></i>
              </div>
              <h4 class="font-semibold text-gray-900 mb-2"><%= s.title %></h4>
              <p class="text-sm text-gray-600 leading-relaxed"><%= s.desc %></p>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Dynamic Service Pricing from DB -->
      <div class="bg-gradient-to-r from-pink-50 to-purple-50 rounded-2xl p-8 border border-pink-100">
        <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
          <i class="ri-coins-line text-pink-500"></i> Credit-Based Pricing
        </h3>
        <p class="text-sm text-gray-600 mb-4">No subscriptions. No monthly fees. Buy credits once and use them for any service. Credits never expire. Admin can configure free monthly quotas for basic usage.</p>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          <% if (typeof creditConfigs !== 'undefined' && creditConfigs.length > 0) { %>
            <% creditConfigs.forEach(c => { %>
              <div class="bg-white rounded-xl p-4 border border-gray-100 flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-pink-50 flex items-center justify-center text-pink-600 flex-shrink-0">
                  <i class="ri-price-tag-3-line text-lg"></i>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-medium text-gray-900 truncate"><%= c.serviceName %></p>
                  <p class="text-xs text-pink-600 font-semibold">₹<%= parseFloat(c.cost).toFixed(2) %>
                    <% if (c.freeQuota > 0) { %>
                      <span class="text-xs text-blue-500 ml-1">(<%= c.freeQuota %> free/mo)</span>
                    <% } %>
                  </p>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <% const fallbackPricing = [
              { label: 'Send Message', cost: '₹0.10' },
              { label: 'Contact', cost: '₹0.50' },
              { label: 'Template', cost: '₹1.00' },
              { label: 'Scrape Record', cost: '₹2.00' },
              { label: 'Auto Reply', cost: '₹3.00' },
              { label: 'Session', cost: '₹5.00' },
              { label: 'Schedule', cost: '₹0.10' },
              { label: 'API Key', cost: '₹5.00' },
            ]; %>
            <% fallbackPricing.forEach(s => { %>
              <div class="bg-white rounded-xl p-4 border border-gray-100 flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-pink-50 flex items-center justify-center text-pink-600 flex-shrink-0">
                  <i class="ri-price-tag-3-line text-lg"></i>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= s.label %></p>
                  <p class="text-xs text-pink-600 font-semibold"><%= s.cost %></p>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Packages -->
  <% if (typeof servicePackages !== 'undefined' && servicePackages.length > 0) { %>
  <% const landingBundleIcons = {
    'send_message': 'ri-send-plane-line', 'incoming_message': 'ri-message-3-line', 'ai_reply': 'ri-brain-line',
    'create_contact': 'ri-contacts-line', 'create_template': 'ri-file-list-line', 'scrape': 'ri-map-pin-line',
    'schedule_message': 'ri-calendar-schedule-line', 'auto_reply': 'ri-robot-line', 'create_session': 'ri-qr-code-line',
    'social_automation': 'ri-messenger-line', 'api_key': 'ri-key-line', 'webhook': 'ri-webhook-line',
    'poll_results': 'ri-bar-chart-box-line', 'create_form': 'ri-survey-line', 'lead_import': 'ri-user-search-line',
    'youtube_rule': 'ri-youtube-line', 'instagram_rule': 'ri-instagram-line'
  }; %>
  <section class="py-20 gradient-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Service Bundles</h2>
        <p class="text-gray-600">Discounted credit packs for specific services</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <% servicePackages.forEach(pkg => { %>
          <div class="bg-white rounded-2xl border-2 border-gray-100 overflow-hidden card-hover relative">
            <div class="p-6 text-center bg-gradient-to-b from-pink-50 to-white">
              <div class="w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center mx-auto mb-3">
                <i class="<%= landingBundleIcons[pkg.serviceKey] || 'ri-stack-line' %> text-2xl text-pink-600"></i>
              </div>
              <h4 class="font-bold text-lg text-gray-900"><%= pkg.serviceName %></h4>
              <div class="flex items-baseline justify-center gap-1 mt-2">
                <span class="text-3xl font-extrabold text-gray-900">₹<%= pkg.price %></span>
              </div>
              <p class="text-sm text-gray-500 mt-1"><%= pkg.credits.toLocaleString() %> credits</p>
            </div>
            <div class="px-6 py-5">
              <p class="text-xs text-gray-500 mb-4 text-center"><%= pkg.description || 'Credits for ' + pkg.serviceName %></p>
              <a href="/auth/register" class="block w-full py-3 text-center text-sm font-semibold rounded-xl transition-all bg-gradient-to-r from-pink-500 to-pink-600 text-white hover:shadow-lg">
                Get Started
              </a>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- How It Works -->
  <section class="py-20 <%= (typeof servicePackages !== 'undefined' && servicePackages.length > 0) ? 'bg-white' : 'gradient-bg' %>">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">How It Works</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Get started in minutes with these simple steps</p>
      </div>
      <div class="grid md:grid-cols-4 gap-8 max-w-5xl mx-auto">
        <% const steps = [
          { num: '01', icon: 'ri-user-add-line', title: 'Create Account', desc: 'Sign up free. Get 50 credits instantly.' },
          { num: '02', icon: 'ri-qr-code-line', title: 'Connect WhatsApp', desc: 'Scan QR code to link your WhatsApp Business account.' },
          { num: '03', icon: 'ri-settings-3-line', title: 'Configure Rules', desc: 'Set up auto-replies, templates, and scheduled campaigns.' },
          { num: '04', icon: 'ri-send-plane-fill', title: 'Start Automating', desc: 'Watch messages send, leads capture, and replies flow automatically.' },
        ]; %>
        <% steps.forEach(step => { %>
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-white shadow-lg shadow-pink-100 flex items-center justify-center mx-auto mb-4">
              <i class="<%= step.icon %> text-2xl text-pink-600"></i>
            </div>
            <span class="text-xs font-bold text-pink-400 mb-1 block"><%= step.num %></span>
            <h4 class="font-semibold text-gray-900 mb-1"><%= step.title %></h4>
            <p class="text-sm text-gray-500"><%= step.desc %></p>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Credit Packages -->
  <section class="py-20 <%= (typeof servicePackages !== 'undefined' && servicePackages.length > 0) ? 'gradient-bg' : 'bg-white' %>">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Buy Credits</h2>
        <p class="text-gray-600">Start with 50 free credits. Top up anytime. Credits never expire.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        <%
        const creditPackages = [
          { name: 'Starter', credits: 100, price: 99, icon: 'ri-seedling-line', gradient: 'bg-gradient-to-b from-gray-50 to-gray-100', text: 'text-gray-700', btn: 'bg-gray-900 text-white hover:bg-gray-800', badge: '', popular: false },
          { name: 'Pro', credits: 500, price: 399, icon: 'ri-medal-line', gradient: 'bg-gradient-to-b from-slate-50 to-slate-100', text: 'text-slate-700', btn: 'bg-gradient-to-r from-slate-600 to-slate-700 text-white hover:shadow-lg', badge: 'MOST POPULAR', popular: true },
          { name: 'Business', credits: 2000, price: 1299, icon: 'ri-briefcase-line', gradient: 'bg-gradient-to-b from-amber-50 to-yellow-100', text: 'text-amber-700', btn: 'bg-gradient-to-r from-amber-400 to-yellow-500 text-white hover:shadow-lg', badge: '', popular: false },
          { name: 'Enterprise', credits: 10000, price: 4999, icon: 'ri-vip-diamond-line', gradient: 'bg-gradient-to-b from-purple-50 to-pink-100', text: 'text-purple-700', btn: 'bg-gradient-to-r from-purple-500 to-pink-500 text-white hover:shadow-lg', badge: 'BEST VALUE', popular: false },
        ];
        %>
        <% creditPackages.forEach(pkg => { %>
          <div class="bg-white rounded-2xl border-2 <%= pkg.popular ? 'border-pink-400 ring-2 ring-pink-100' : 'border-gray-100' %> overflow-hidden card-hover relative">
            <% if (pkg.badge) { %>
              <div class="absolute top-0 right-0 bg-gradient-to-l from-amber-200 to-yellow-300 text-xs font-bold px-3 py-1 rounded-bl-xl text-amber-800">
                <%= pkg.badge %>
              </div>
            <% } %>
            <!-- Header -->
            <div class="p-6 text-center <%= pkg.gradient %>">
              <div class="w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center mx-auto mb-3">
                <i class="<%= pkg.icon %> text-2xl <%= pkg.text %>"></i>
              </div>
              <h4 class="font-bold text-lg text-gray-900"><%= pkg.name %></h4>
              <div class="flex items-baseline justify-center gap-1 mt-2">
                <span class="text-3xl font-extrabold text-gray-900">₹<%= pkg.price %></span>
              </div>
              <p class="text-sm text-gray-500 mt-1"><%= pkg.credits.toLocaleString() %> credits</p>
            </div>
            <!-- Features -->
            <div class="px-6 py-5">
              <ul class="space-y-2 mb-3">
                <li class="flex items-center gap-2 text-sm text-gray-600"><i class="ri-check-line text-green-500"></i> <strong><%= pkg.credits.toLocaleString() %></strong> Credits</li>
                <li class="flex items-center gap-2 text-sm text-gray-600"><i class="ri-check-line text-green-500"></i> Never expires</li>
              </ul>
              <!-- Services included -->
              <div class="mb-4">
                <p class="text-[10px] font-medium text-gray-400 mb-1.5 uppercase tracking-wide">All Services</p>
                <div class="flex flex-wrap gap-1">
                  <% const landingSvcIcons = {
                    'send_message': 'ri-send-plane-line', 'incoming_message': 'ri-message-3-line', 'ai_reply': 'ri-brain-line',
                    'create_contact': 'ri-contacts-line', 'create_template': 'ri-file-list-line', 'scrape': 'ri-map-pin-line',
                    'schedule_message': 'ri-calendar-schedule-line', 'auto_reply': 'ri-robot-line', 'create_session': 'ri-qr-code-line',
                    'social_automation': 'ri-messenger-line', 'api_key': 'ri-key-line', 'webhook': 'ri-webhook-line',
                    'poll_results': 'ri-bar-chart-box-line', 'create_form': 'ri-survey-line', 'lead_import': 'ri-user-search-line',
                    'youtube_rule': 'ri-youtube-line', 'instagram_rule': 'ri-instagram-line'
                  }; %>
                  <% if (typeof creditConfigs !== 'undefined' && creditConfigs.length > 0) { %>
                    <% creditConfigs.slice(0, 8).forEach(c => { %>
                      <span class="inline-flex items-center gap-1 text-[10px] px-1.5 py-0.5 rounded bg-gray-50 text-gray-500 border border-gray-100" title="<%= c.serviceName %>">
                        <i class="<%= landingSvcIcons[c.serviceKey] || 'ri-apps-line' %> text-pink-400 text-[10px]"></i>
                        <%= c.serviceName %>
                      </span>
                    <% }); %>
                    <% if (creditConfigs.length > 8) { %>
                      <span class="text-[10px] text-gray-400 px-1">+<%= creditConfigs.length - 8 %> more</span>
                    <% } %>
                  <% } else { %>
                    <span class="text-xs text-gray-400">All platform services included</span>
                  <% } %>
                </div>
              </div>
              <a href="/auth/register" class="block w-full py-3 text-center text-sm font-semibold rounded-xl transition-all <%= pkg.btn %>">
                Get Started
              </a>
            </div>
          </div>
        <% }); %>
      </div>
      <p class="text-center text-sm text-gray-500 mt-8">
        <i class="ri-information-line"></i> All prices in INR. Credits are added instantly after payment. Need a custom package? <a href="#contact" class="text-pink-600 hover:underline">Contact us</a>.
      </p>
    </div>
  </section>

  <!-- Enquiry Form Section -->
  <section id="contact" class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Get In Touch</h2>
        <p class="text-gray-600">Have questions or need a custom enterprise solution? Drop us a message and we'll get back to you.</p>
      </div>

      <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 border border-pink-100">
        <form id="enquiryForm" class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
            <input type="text" name="name" required placeholder="Your name" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200 bg-white">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Enterprise Name</label>
            <input type="text" name="enterpriseName" placeholder="Your company (optional)" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200 bg-white">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number <span class="text-red-500">*</span></label>
            <input type="tel" name="phone" required placeholder="+91 98765 43210" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200 bg-white">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
            <input type="email" name="email" required placeholder="you@company.com" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200 bg-white">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea name="message" rows="4" placeholder="Tell us about your requirements..." class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200 bg-white resize-none"></textarea>
          </div>
          <div class="md:col-span-2">
            <button type="submit" id="enquirySubmitBtn" class="px-8 py-3.5 btn-pink text-white text-sm font-semibold rounded-xl hover:shadow-lg transition-all flex items-center justify-center gap-2 mx-auto">
              <i class="ri-send-plane-line"></i> <span>Send Enquiry</span>
            </button>
          </div>
        </form>
        <div id="enquirySuccess" class="hidden text-center py-8">
          <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-3">
            <i class="ri-check-line text-2xl text-green-600"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-1">Enquiry Submitted!</h3>
          <p class="text-sm text-gray-500">We'll get back to you shortly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Business Details -->
  <section class="py-16 gradient-bg border-t border-pink-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center mx-auto mb-3">
            <i class="ri-mail-line text-xl text-pink-600"></i>
          </div>
          <h4 class="font-semibold text-gray-900 mb-1">Email</h4>
          <p class="text-sm text-gray-500">support@crm.parrobyte.co.in</p>
        </div>
        <div>
          <div class="w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center mx-auto mb-3">
            <i class="ri-global-line text-xl text-pink-600"></i>
          </div>
          <h4 class="font-semibold text-gray-900 mb-1">Website</h4>
          <p class="text-sm text-gray-500">www.crm.parrobyte.co.in</p>
        </div>
        <div>
          <div class="w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center mx-auto mb-3">
            <i class="ri-building-line text-xl text-pink-600"></i>
          </div>
          <h4 class="font-semibold text-gray-900 mb-1">Business</h4>
          <p class="text-sm text-gray-500">ParroByte CRM Solutions</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-white border-t border-pink-100 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg btn-pink flex items-center justify-center">
            <i class="ri-whatsapp-line text-white"></i>
          </div>
          <span class="font-bold text-gray-900">ParroByte CRM</span>
        </div>
        <p class="text-sm text-gray-500"> ParroByte CRM. All rights reserved.</p>
        <div class="flex items-center gap-4 text-sm text-gray-500">
          <a href="/privacy" class="hover:text-pink-600 transition-colors">Privacy Policy</a>
          <span class="text-gray-300">|</span>
          <a href="/terms" class="hover:text-pink-600 transition-colors">Terms & Conditions</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
  document.getElementById('enquiryForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('enquirySubmitBtn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="ri-loader-4-line animate-spin"></i> Sending...';
    btn.disabled = true;

    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch('/landing/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.success) {
        document.getElementById('enquiryForm').classList.add('hidden');
        document.getElementById('enquirySuccess').classList.remove('hidden');
      } else {
        alert(result.error || 'Failed to submit. Please try again.');
      }
    } catch (err) {
      alert('Error: ' + err.message);
    } finally {
      btn.innerHTML = originalText;
      btn.disabled = false;
    }
  });
  </script>
</body>
</html>
