<div class="mb-6">
  <h2 class="text-xl font-bold text-gray-900">Activity Logs</h2>
  <p class="text-sm text-gray-500">System activity and audit trail</p>
</div>

<div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-pink-100">
        <tr>
          <th class="text-left px-6 py-3 font-medium text-gray-700">User ID</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Action</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Entity</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Details</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">IP</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Time</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% logs.forEach(log => { %>
          <tr class="hover:bg-pink-50/50 transition-colors">
            <td class="px-6 py-4 font-medium text-gray-900"><%= log.userId %></td>
            <td class="px-6 py-4"><span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-600"><%= log.action %></span></td>
            <td class="px-6 py-4 text-gray-600"><%= log.entity || '-' %></td>
            <td class="px-6 py-4 text-gray-600 max-w-xs truncate"><%= log.details || '-' %></td>
            <td class="px-6 py-4 text-xs text-gray-500"><%= log.ipAddress || '-' %></td>
            <td class="px-6 py-4 text-xs text-gray-500"><%= new Date(log.createdAt).toLocaleString() %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (!logs || logs.length === 0) { %>
    <div class="p-8 text-center">
      <p class="text-sm text-gray-500">No activity logs yet</p>
    </div>
  <% } %>
</div>
