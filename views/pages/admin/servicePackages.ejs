<div class="mb-6">
  <h2 class="text-xl font-bold text-gray-900">Service Packages</h2>
  <p class="text-sm text-gray-500">Create service-specific credit bundles for billing and landing pages</p>
</div>

<div class="flex gap-3 mb-6 flex-wrap">
  <a href="/admin" class="px-5 py-2.5 bg-white border border-pink-200 text-pink-600 text-sm font-medium rounded-xl hover:bg-pink-50 transition-colors flex items-center gap-2">
    <i class="ri-arrow-left-line"></i> Back to Admin
  </a>
  <a href="/admin/landing-enquiries" class="px-5 py-2.5 bg-white border border-pink-200 text-pink-600 text-sm font-medium rounded-xl hover:bg-pink-50 transition-colors flex items-center gap-2">
    <i class="ri-mail-line"></i> Landing Enquiries
  </a>
  <a href="/admin/credits" class="px-5 py-2.5 bg-white border border-pink-200 text-pink-600 text-sm font-medium rounded-xl hover:bg-pink-50 transition-colors flex items-center gap-2">
    <i class="ri-coins-line"></i> Credit Config
  </a>
</div>

<!-- Create Form -->
<div class="bg-white rounded-2xl border border-pink-100 p-6 mb-8">
  <h3 class="font-semibold text-gray-900 mb-4">Create New Package</h3>
  <form action="/admin/service-packages/create" method="POST" class="grid md:grid-cols-3 gap-4">
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Service</label>
      <select name="serviceKey" required class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200">
        <% configs.forEach(c => { %>
          <option value="<%= c.serviceKey %>"><%= c.serviceName %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Package Name</label>
      <input type="text" name="serviceName" placeholder="e.g. 100 Messages Pack" required class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200">
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Credits</label>
      <input type="number" name="credits" placeholder="100" required min="1" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200">
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Price (₹)</label>
      <input type="number" name="price" placeholder="99" required min="1" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200">
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Sort Order</label>
      <input type="number" name="sortOrder" placeholder="0" value="0" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200">
    </div>
    <div class="md:col-span-3">
      <label class="block text-xs font-medium text-gray-700 mb-1">Description</label>
      <input type="text" name="description" placeholder="Optional description..." class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200">
    </div>
    <div class="md:col-span-3">
      <button type="submit" class="px-6 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all">
        <i class="ri-add-line"></i> Create Package
      </button>
    </div>
  </form>
</div>

<!-- Existing Packages -->
<div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
  <div class="p-5 border-b border-pink-100 flex items-center justify-between">
    <h3 class="font-semibold text-gray-900">Existing Packages</h3>
    <span class="text-xs text-gray-500"><%= packages.length %> total</span>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-pink-100">
        <tr>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Service</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Package Name</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Credits</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Price</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Status</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% packages.forEach(pkg => { %>
          <tr class="hover:bg-pink-50/50 transition-colors">
            <form action="/admin/service-packages/update/<%= pkg.id %>" method="POST" class="contents">
              <td class="px-6 py-4">
                <select name="serviceKey" class="border border-gray-200 rounded-lg px-2 py-1 text-xs bg-white">
                  <% configs.forEach(c => { %>
                    <option value="<%= c.serviceKey %>" <%= pkg.serviceKey === c.serviceKey ? 'selected' : '' %>><%= c.serviceName %></option>
                  <% }); %>
                </select>
              </td>
              <td class="px-6 py-4">
                <input type="text" name="serviceName" value="<%= pkg.serviceName %>" class="border border-gray-200 rounded-lg px-2 py-1 text-xs w-full">
              </td>
              <td class="px-6 py-4">
                <input type="number" name="credits" value="<%= pkg.credits %>" class="border border-gray-200 rounded-lg px-2 py-1 text-xs w-20">
              </td>
              <td class="px-6 py-4">
                <input type="number" name="price" value="<%= pkg.price %>" class="border border-gray-200 rounded-lg px-2 py-1 text-xs w-20">
              </td>
              <td class="px-6 py-4">
                <label class="inline-flex items-center cursor-pointer">
                  <input type="checkbox" name="isActive" <%= pkg.isActive ? 'checked' : '' %> class="sr-only peer">
                  <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-pink-500 relative"></div>
                </label>
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  <button type="submit" class="text-xs px-3 py-1 bg-pink-50 text-pink-600 rounded-lg hover:bg-pink-100 transition-colors">Save</button>
                  <button type="button" onclick="deletePackage(<%= pkg.id %>)" class="text-xs px-3 py-1 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors">Delete</button>
                </div>
              </td>
            </form>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (!packages || packages.length === 0) { %>
    <div class="p-8 text-center">
      <div class="w-16 h-16 rounded-full bg-pink-50 flex items-center justify-center mx-auto mb-3">
        <i class="ri-stack-line text-2xl text-pink-300"></i>
      </div>
      <p class="text-sm text-gray-500">No service packages yet</p>
    </div>
  <% } %>
</div>

<script>
async function deletePackage(id) {
  if (!confirm('Are you sure you want to delete this package?')) return;
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/admin/service-packages/delete/' + id;
  document.body.appendChild(form);
  form.submit();
}
</script>
