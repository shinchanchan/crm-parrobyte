<div class="mb-6">
  <h2 class="text-xl font-bold text-gray-900">Credit Configuration</h2>
  <p class="text-sm text-gray-500">Manage credit costs for each service</p>
</div>

<div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
  <div class="p-5 border-b border-pink-100 flex items-center justify-between">
    <h3 class="font-semibold text-gray-900">Service Credit Costs</h3>
    <span class="text-xs text-gray-500"><%= configs.length %> services</span>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-pink-100">
        <tr>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Service</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Key</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Description</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Cost (₹)</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Free Quota</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Visible</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Status</th>
          <th class="text-right px-6 py-3 font-medium text-gray-700">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% configs.forEach(cfg => { %>
          <tr class="hover:bg-pink-50/50 transition-colors">
            <td class="px-6 py-4 font-medium text-gray-900"><%= cfg.serviceName %></td>
            <td class="px-6 py-4 text-xs text-gray-500 font-mono"><%= cfg.serviceKey %></td>
            <td class="px-6 py-4 text-xs text-gray-500"><%= cfg.description || '-' %></td>
            <td class="px-6 py-4">
              <span class="text-sm font-bold text-pink-600">₹<%= parseFloat(cfg.cost).toFixed(2) %></span>
            </td>
            <td class="px-6 py-4">
              <span class="text-xs px-2.5 py-1 rounded-full <%= (cfg.freeQuota || 0) > 0 ? 'bg-blue-100 text-blue-600' : 'bg-gray-100 text-gray-500' %>">
                <%= cfg.freeQuota || 0 %>/mo
              </span>
            </td>
            <td class="px-6 py-4">
              <span class="text-xs px-2.5 py-1 rounded-full <%= cfg.isVisible ? 'bg-blue-100 text-blue-600' : 'bg-gray-100 text-gray-500' %>">
                <%= cfg.isVisible ? 'Visible' : 'Hidden' %>
              </span>
            </td>
            <td class="px-6 py-4">
              <span class="text-xs px-2.5 py-1 rounded-full <%= cfg.isActive ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-500' %>">
                <%= cfg.isActive ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td class="px-6 py-4 text-right">
              <button onclick="editConfig('<%= cfg.id %>', '<%= cfg.serviceName %>', '<%= cfg.serviceKey %>', <%= cfg.cost %>, <%= cfg.isActive %>, <%= cfg.freeQuota || 0 %>, <%= cfg.isVisible %>)" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg">
                <i class="ri-edit-line"></i>
              </button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (!configs || configs.length === 0) { %>
    <div class="p-8 text-center">
      <p class="text-sm text-gray-500">No credit configs found. Run seed to populate defaults.</p>
    </div>
  <% } %>
</div>

<!-- Edit Config Modal -->
<dialog id="editConfigModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-sm">
    <h3 class="font-bold text-lg text-gray-900 mb-1">Edit Credit Cost</h3>
    <p class="text-sm text-gray-500 mb-4" id="ecServiceName"></p>
    <form id="editConfigForm" action="" method="POST" data-loading-text="Saving...">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Cost (₹)</label>
        <input type="number" name="cost" id="ecCost" required min="0" step="0.01" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Free Quota (uses per month)</label>
        <input type="number" name="freeQuota" id="ecFreeQuota" required min="0" step="1" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
        <p class="text-xs text-gray-400 mt-1">Number of free uses per user per month. 0 = no free quota.</p>
      </div>
      <div class="flex items-center gap-2 mb-4">
        <input type="checkbox" name="isVisible" id="ecIsVisible" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
        <label class="text-sm text-gray-700">Visible in Sidebar</label>
      </div>
      <div class="flex items-center gap-2 mb-4">
        <input type="checkbox" name="isActive" id="ecIsActive" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
        <label class="text-sm text-gray-700">Active (billing enabled)</label>
      </div>
      <div class="flex gap-3 justify-end">
        <button type="button" onclick="document.getElementById('editConfigModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-save-line"></i> Save</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
function editConfig(id, serviceName, serviceKey, cost, isActive, freeQuota, isVisible) {
  document.getElementById('editConfigForm').action = '/admin/credits/update/' + id;
  document.getElementById('ecServiceName').textContent = serviceName + ' (' + serviceKey + ')';
  document.getElementById('ecCost').value = cost;
  document.getElementById('ecFreeQuota').value = freeQuota || 0;
  document.getElementById('ecIsVisible').checked = isVisible === true || isVisible === 'true' || isVisible === 1;
  document.getElementById('ecIsActive').checked = isActive === true || isActive === 'true' || isActive === 1;
  document.getElementById('editConfigModal').showModal();
}
</script>
