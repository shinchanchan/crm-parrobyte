<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h2 class="text-xl font-bold text-gray-900">Webhooks</h2>
    <p class="text-sm text-gray-500">Configure webhook endpoints for event notifications per WhatsApp session</p>
  </div>
  <button onclick="document.getElementById('webhookModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2 w-fit">
    <i class="ri-add-line"></i> Add Webhook
  </button>
</div>

<div class="space-y-4">
  <% webhooks.forEach(hook => { %>
    <div class="bg-white rounded-2xl border border-pink-100 p-6 card-hover">
      <div class="flex items-start justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
            <i class="ri-webhook-line"></i>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900"><%= hook.name %></h3>
            <p class="text-xs text-gray-500 truncate max-w-md"><%= hook.url %></p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs px-2.5 py-1 rounded-full <%= hook.isActive ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-500' %>"><%= hook.isActive ? 'Active' : 'Inactive' %></span>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-3 mb-3">
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-500 mb-1">Endpoint URL</p>
          <code class="text-sm text-gray-700 break-all"><%= hook.url %></code>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-500 mb-1">WhatsApp Session</p>
          <p class="text-sm text-gray-700">
            <% if (hook.sessionId) { %>
              <% const s = sessions.find(s => s.id === hook.sessionId); %>
              <span class="text-indigo-600 font-medium"><i class="ri-whatsapp-line"></i> <%= s ? s.sessionName : 'Session #' + hook.sessionId %></span>
            <% } else { %>
              <span class="text-gray-500"><i class="ri-global-line"></i> All Sessions</span>
            <% } %>
          </p>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 mb-3">
        <% hook.events.forEach(ev => { %>
          <span class="text-xs px-2 py-1 rounded-full bg-pink-50 text-pink-600 border border-pink-100"><%= ev %></span>
        <% }); %>
        <% if (!hook.events.length) { %>
          <span class="text-xs px-2 py-1 rounded-full bg-gray-50 text-gray-400 border border-gray-100">No events configured</span>
        <% } %>
      </div>

      <% if (hook.secret) { %>
        <div class="bg-gray-50 rounded-xl p-3 mb-3">
          <p class="text-xs text-gray-500 mb-1">Secret (HMAC signature enabled)</p>
          <code class="text-sm text-gray-700">••••••••</code>
        </div>
      <% } %>

      <!-- Delivery Logs -->
      <% if (hook.logs && hook.logs.length > 0) { %>
        <div class="mt-4 border-t border-gray-100 pt-4">
          <p class="text-xs font-medium text-gray-700 mb-2">Recent Deliveries</p>
          <div class="space-y-2 max-h-48 overflow-y-auto">
            <% hook.logs.forEach(log => { %>
              <div class="flex items-center gap-3 text-xs p-2 rounded-lg <%= log.responseStatus && log.responseStatus >= 200 && log.responseStatus < 300 ? 'bg-green-50' : 'bg-red-50' %>">
                <span class="font-medium <%= log.responseStatus && log.responseStatus >= 200 && log.responseStatus < 300 ? 'text-green-600' : 'text-red-600' %>">
                  <%= log.responseStatus || 'ERR' %>
                </span>
                <span class="text-gray-500"><%= log.eventType %></span>
                <span class="text-gray-400 ml-auto"><%= new Date(log.createdAt).toLocaleString() %></span>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>

      <div class="flex gap-2 pt-3 border-t border-gray-100 mt-4">
        <button onclick="testWebhook(<%= hook.id %>)" class="flex-1 py-2 text-xs font-medium text-emerald-600 bg-emerald-50 rounded-lg hover:bg-emerald-100 transition-colors flex items-center justify-center gap-1">
          <i class="ri-send-plane-line"></i> Test
        </button>
        <button onclick="editWebhook(<%= hook.id %>, '<%= hook.name %>', '<%= hook.url %>', '<%= hook.secret || '' %>', <%= hook.isActive %>, <%= hook.sessionId || 'null' %>, <%= JSON.stringify(hook.events) %>)" class="flex-1 py-2 text-xs font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors flex items-center justify-center gap-1">
          <i class="ri-edit-line"></i> Edit
        </button>
        <form action="/webhooks/delete/<%= hook.id %>" method="POST" class="flex-1" onsubmit="return confirm('Delete this webhook?')">
          <button type="submit" class="w-full py-2 text-xs font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition-colors flex items-center justify-center gap-1">
            <i class="ri-delete-bin-line"></i> Delete
          </button>
        </form>
      </div>
    </div>
  <% }); %>
</div>

<% if (!webhooks || webhooks.length === 0) { %>
  <div class="bg-white rounded-2xl border border-pink-100 p-12 text-center">
    <div class="w-16 h-16 rounded-full bg-pink-50 flex items-center justify-center mx-auto mb-3">
      <i class="ri-webhook-line text-2xl text-pink-300"></i>
    </div>
    <h3 class="font-semibold text-gray-900 mb-2">No Webhooks</h3>
    <p class="text-sm text-gray-500">Add webhooks to receive event notifications for specific WhatsApp sessions</p>
  </div>
<% } %>

<!-- Add Webhook Modal -->
<dialog id="webhookModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Add Webhook</h3>
    <form action="/webhooks/create" method="POST" data-loading-text="Creating webhook...">
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
        <input type="text" name="name" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Endpoint URL *</label>
        <input type="url" name="url" required placeholder="https://your-app.com/webhook" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Session</label>
        <select name="sessionId" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
          <option value="">All Sessions (global)</option>
          <% sessions.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.sessionName %> <%= s.phoneNumber ? '(' + s.phoneNumber + ')' : '' %></option>
          <% }); %>
        </select>
        <p class="text-xs text-gray-400 mt-1">Select a specific session to only receive events from that number</p>
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Events</label>
        <div class="grid grid-cols-2 gap-2">
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer">
            <input type="checkbox" name="events" value="message.received" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-message-3-line text-pink-500"></i> Message Received</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer">
            <input type="checkbox" name="events" value="message.sent" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-send-plane-line text-pink-500"></i> Message Sent</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer">
            <input type="checkbox" name="events" value="session.connected" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-qr-code-line text-pink-500"></i> Session Connected</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer">
            <input type="checkbox" name="events" value="session.disconnected" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-logout-box-line text-pink-500"></i> Session Disconnected</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer col-span-2">
            <input type="checkbox" name="events" value="all" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-global-line text-pink-500"></i> All Events</span>
          </label>
        </div>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Secret (for HMAC signature)</label>
        <input type="text" name="secret" placeholder="Optional - used to sign webhook payloads" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
        <p class="text-xs text-gray-400 mt-1">If set, payloads will be signed with sha256=... in X-Webhook-Signature header</p>
      </div>
      <div class="flex gap-3 justify-end">
        <button type="button" onclick="document.getElementById('webhookModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-save-line"></i> Save</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- Edit Webhook Modal -->
<dialog id="editWebhookModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Edit Webhook</h3>
    <form id="editWebhookForm" action="" method="POST" data-loading-text="Updating webhook...">
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
        <input type="text" name="name" id="ewName" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Endpoint URL</label>
        <input type="url" name="url" id="ewUrl" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Session</label>
        <select name="sessionId" id="ewSessionId" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
          <option value="">All Sessions (global)</option>
          <% sessions.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.sessionName %> <%= s.phoneNumber ? '(' + s.phoneNumber + ')' : '' %></option>
          <% }); %>
        </select>
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Events</label>
        <div class="grid grid-cols-2 gap-2">
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer">
            <input type="checkbox" name="events" value="message.received" id="ewEvReceived" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-message-3-line text-pink-500"></i> Message Received</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer">
            <input type="checkbox" name="events" value="message.sent" id="ewEvSent" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-send-plane-line text-pink-500"></i> Message Sent</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer">
            <input type="checkbox" name="events" value="session.connected" id="ewEvConnected" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-qr-code-line text-pink-500"></i> Session Connected</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer">
            <input type="checkbox" name="events" value="session.disconnected" id="ewEvDisconnected" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-logout-box-line text-pink-500"></i> Session Disconnected</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 p-2 rounded-lg border border-gray-100 hover:bg-pink-50 cursor-pointer col-span-2">
            <input type="checkbox" name="events" value="all" id="ewEvAll" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
            <span><i class="ri-global-line text-pink-500"></i> All Events</span>
          </label>
        </div>
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Secret</label>
        <input type="text" name="secret" id="ewSecret" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>
      <div class="flex items-center gap-2 mb-4">
        <input type="checkbox" name="isActive" id="ewIsActive" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500">
        <label class="text-sm text-gray-700">Active</label>
      </div>
      <div class="flex gap-3 justify-end">
        <button type="button" onclick="document.getElementById('editWebhookModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-save-line"></i> Update</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
function editWebhook(id, name, url, secret, isActive, sessionId, events) {
  document.getElementById('editWebhookForm').action = '/webhooks/update/' + id;
  document.getElementById('ewName').value = name;
  document.getElementById('ewUrl').value = url;
  document.getElementById('ewSecret').value = secret || '';
  document.getElementById('ewIsActive').checked = isActive === true || isActive === 'true' || isActive === 1;

  // Set session select
  const sessionSelect = document.getElementById('ewSessionId');
  if (sessionId) {
    sessionSelect.value = sessionId;
  } else {
    sessionSelect.value = '';
  }

  // Set event checkboxes
  const eventSet = new Set(events || []);
  document.getElementById('ewEvReceived').checked = eventSet.has('message.received');
  document.getElementById('ewEvSent').checked = eventSet.has('message.sent');
  document.getElementById('ewEvConnected').checked = eventSet.has('session.connected');
  document.getElementById('ewEvDisconnected').checked = eventSet.has('session.disconnected');
  document.getElementById('ewEvAll').checked = eventSet.has('all') || eventSet.has('*');

  document.getElementById('editWebhookModal').showModal();
}

async function testWebhook(id) {
  try {
    const res = await fetch('/webhooks/test/' + id, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      alert(data.message);
      setTimeout(() => window.location.reload(), 1500);
    } else {
      alert(data.error || 'Test failed');
    }
  } catch (err) {
    alert('Error: ' + err.message);
  }
}
</script>
