<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h2 class="text-xl font-bold text-gray-900">Auto Reply</h2>
    <p class="text-sm text-gray-500">Set up automatic replies for incoming messages</p>
  </div>
  <!-- AI Status Banner -->
  <a href="/ai-config" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-purple-50 border border-purple-200 text-purple-700 text-xs font-medium hover:bg-purple-100 transition-colors">
    <i class="ri-brain-line"></i> AI Assistant: <span id="aiStatusText">Configure in AI Settings</span>
  </a>
  <button onclick="document.getElementById('ruleModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2 w-fit">
    <i class="ri-add-line"></i> Add Rule
  </button>
</div>

<div class="space-y-4">
  <% rules.forEach(rule => { %>
    <div class="bg-white rounded-2xl border border-pink-100 p-6 card-hover">
      <div class="flex items-start justify-between">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg <%= rule.responseType === 'ai' ? 'bg-purple-100 text-purple-600' : 'bg-blue-100 text-blue-600' %> flex items-center justify-center">
            <i class="ri-<%= rule.responseType === 'ai' ? 'brain-line' : 'message-3-line' %>"></i>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900"><%= rule.name %></h3>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full"><%= rule.triggerType %>: <%= rule.triggerValue %></span>
              <span class="text-xs bg-pink-100 text-pink-600 px-2 py-0.5 rounded-full">Priority: <%= rule.priority %></span>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs px-2.5 py-1 rounded-full <%= rule.isActive ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-500' %>"><%= rule.isActive ? 'Active' : 'Inactive' %></span>
          <button onclick="editRule('<%= rule.id %>', '<%= rule.name %>', '<%= rule.sessionId %>', '<%= rule.triggerType %>', `<%= rule.triggerValue %>`, '<%= rule.responseType %>', `<%= rule.responseContent %>`, `<%= rule.aiPrompt %>`, '<%= rule.priority %>', '<%= rule.isActive %>')" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg">
            <i class="ri-edit-line"></i>
          </button>
          <form action="/auto-reply/delete/<%= rule.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this rule?')">
            <button type="submit" class="p-2 text-red-600 hover:bg-red-50 rounded-lg"><i class="ri-delete-bin-line"></i></button>
          </form>
        </div>
      </div>
      
      <div class="mt-4 pt-4 border-t border-gray-100">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-gray-500 mb-1">Trigger</p>
            <p class="text-sm text-gray-700"><%= rule.triggerType %>: <code class="bg-gray-100 px-2 py-0.5 rounded text-xs"><%= rule.triggerValue %></code></p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-1">Response Type</p>
            <p class="text-sm text-gray-700 capitalize"><%= rule.responseType %></p>
          </div>
        </div>
        <div class="mt-3">
          <p class="text-xs text-gray-500 mb-1">Response Content</p>
          <p class="text-sm text-gray-700 bg-gray-50 rounded-lg p-3"><%= rule.responseContent %></p>
        </div>
        <% if (rule.aiPrompt) { %>
          <div class="mt-3">
            <p class="text-xs text-gray-500 mb-1">AI Prompt</p>
            <p class="text-sm text-gray-600 bg-purple-50 rounded-lg p-3"><%= rule.aiPrompt %></p>
          </div>
        <% } %>
      </div>
    </div>
  <% }); %>
</div>

<% if (!rules || rules.length === 0) { %>
  <div class="bg-white rounded-2xl border border-pink-100 p-12 text-center">
    <div class="w-16 h-16 rounded-full bg-pink-50 flex items-center justify-center mx-auto mb-3">
      <i class="ri-robot-line text-2xl text-pink-300"></i>
    </div>
    <h3 class="font-semibold text-gray-900 mb-2">No Auto Reply Rules</h3>
    <p class="text-sm text-gray-500 mb-4">Create rules to automatically respond to incoming messages</p>
    <button onclick="document.getElementById('ruleModal').showModal()" class="px-6 py-2.5 btn-pink text-white text-sm font-medium rounded-xl inline-flex items-center gap-2">
      <i class="ri-add-line"></i> Add First Rule
    </button>
  </div>
<% } %>

<dialog id="ruleModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Add Auto Reply Rule</h3>
    <form action="/auto-reply/create" method="POST" data-loading-text="Creating auto-reply rule...">
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Rule Name *</label><input type="text" name="name" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Session (optional)</label>
          <select name="sessionId" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="">All sessions</option>
            <% sessions.forEach(s => { %><option value="<%= s.id %>"><%= s.sessionName %></option><% }); %>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Trigger Type</label>
          <select name="triggerType" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="contains">Contains</option><option value="exact">Exact Match</option><option value="starts_with">Starts With</option><option value="ends_with">Ends With</option><option value="regex">Regex</option>
          </select>
        </div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Trigger Value *</label><input type="text" name="triggerValue" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Response Type</label>
        <select name="responseType" id="responseType" onchange="toggleAiPrompt(this)" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
          <option value="static">Static Text</option>
          <option value="ai">AI Generated</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Response Content *</label>
        <textarea name="responseContent" rows="3" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm" placeholder="Your response message..."></textarea>
      </div>
      <div id="aiPromptDiv" class="hidden">
        <label class="block text-sm font-medium text-gray-700 mb-1">AI Prompt Template</label>
        <textarea name="aiPrompt" rows="2" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm" placeholder="You are a helpful assistant. Respond to: {message}"></textarea>
        <p class="text-xs text-gray-400 mt-1">Use {message} to include the incoming message. AI responses are queued with a 45-second gap to prevent overload.</p>
      </div>
      <div><label class="block text-sm font-medium text-gray-700 mb-1">Priority (1-10)</label><input type="number" name="priority" value="1" min="1" max="10" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></div>
      <div class="flex gap-3 justify-end">
        <button type="button" onclick="document.getElementById('ruleModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-save-line"></i> Save Rule</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="editRuleModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Edit Auto Reply Rule</h3>
    <form id="editRuleForm" action="" method="POST" data-loading-text="Updating auto-reply rule...">
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Rule Name</label><input type="text" name="name" id="erName" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Session</label>
          <select name="sessionId" id="erSession" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="">All sessions</option>
            <% sessions.forEach(s => { %><option value="<%= s.id %>"><%= s.sessionName %></option><% }); %>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Trigger Type</label>
          <select name="triggerType" id="erTriggerType" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="contains">Contains</option><option value="exact">Exact Match</option><option value="starts_with">Starts With</option><option value="ends_with">Ends With</option><option value="regex">Regex</option>
          </select>
        </div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Trigger Value</label><input type="text" name="triggerValue" id="erTriggerValue" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Response Type</label>
        <select name="responseType" id="erResponseType" onchange="toggleAiPromptEdit(this)" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
          <option value="static">Static Text</option>
          <option value="ai">AI Generated</option>
        </select>
      </div>
      <div><label class="block text-sm font-medium text-gray-700 mb-1">Response Content</label><textarea name="responseContent" id="erResponseContent" rows="3" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></textarea></div>
      <div id="erAiPromptDiv" class="hidden">
        <label class="block text-sm font-medium text-gray-700 mb-1">AI Prompt Template</label>
        <textarea name="aiPrompt" id="erAiPrompt" rows="2" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></textarea>
      </div>
      <div><label class="block text-sm font-medium text-gray-700 mb-1">Priority</label><input type="number" name="priority" id="erPriority" value="1" min="1" max="10" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></div>
      <div class="flex items-center gap-2"><input type="checkbox" name="isActive" id="erIsActive" class="rounded border-pink-200 text-pink-600 focus:ring-pink-500"><label class="text-sm text-gray-700">Active</label></div>
      <div class="flex gap-3 justify-end">
        <button type="button" onclick="document.getElementById('editRuleModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-save-line"></i> Update</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
function toggleAiPrompt(select) {
  document.getElementById('aiPromptDiv').classList.toggle('hidden', select.value !== 'ai');
}
function toggleAiPromptEdit(select) {
  document.getElementById('erAiPromptDiv').classList.toggle('hidden', select.value !== 'ai');
}
function editRule(id, name, sessionId, triggerType, triggerValue, responseType, responseContent, aiPrompt, priority, isActive) {
  document.getElementById('editRuleForm').action = '/auto-reply/update/' + id;
  document.getElementById('erName').value = name;
  document.getElementById('erSession').value = sessionId || '';
  document.getElementById('erTriggerType').value = triggerType;
  document.getElementById('erTriggerValue').value = triggerValue;
  document.getElementById('erResponseType').value = responseType;
  document.getElementById('erResponseContent').value = responseContent;
  document.getElementById('erAiPrompt').value = aiPrompt || '';
  document.getElementById('erPriority').value = priority;
  document.getElementById('erIsActive').checked = isActive === 'true' || isActive === true;
  toggleAiPromptEdit(document.getElementById('erResponseType'));
  document.getElementById('editRuleModal').showModal();
}
</script>
