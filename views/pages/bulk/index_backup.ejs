<div class="mb-6">
  <h2 class="text-xl font-bold text-gray-900">Bulk Messages</h2>
  <p class="text-sm text-gray-500">Send messages to multiple contacts with configurable gap time</p>
</div>

<!-- Send Form -->
<div class="bg-white rounded-2xl border border-pink-100 p-6 mb-8">
  <h3 class="font-semibold text-gray-900 mb-4"><i class="ri-send-plane-fill text-pink-500 mr-1"></i> New Bulk Message Job</h3>

  <!-- WhatsApp Ban Warning -->
  <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-5 flex gap-3">
    <div class="w-10 h-10 rounded-full bg-yellow-100 flex items-center justify-center flex-shrink-0">
      <i class="ri-alert-line text-yellow-600 text-xl"></i>
    </div>
    <div>
      <p class="text-sm font-medium text-yellow-800">WhatsApp Account Safety Warning</p>
      <p class="text-xs text-yellow-700 mt-1">Sending too many messages too quickly can result in your WhatsApp number being banned. We enforce a minimum 30-second gap between messages. Ensure recipients have consented to receive your messages.</p>
    </div>
  </div>

  <form action="/bulk/send" method="POST" enctype="multipart/form-data" data-loading-text="Starting bulk message job...">
    <!-- Row 1: Session + Template + Campaign Category -->
    <div class="grid md:grid-cols-3 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">WhatsApp Session *</label>
        <%
          const connectedSessions = (typeof availableSessions !== 'undefined' ? availableSessions : []).filter(s => s.realtimeStatus === 'connected' || s.status === 'connected');
        %>
        <% if (connectedSessions.length > 0) { %>
          <select name="sessionId" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="">Select session</option>
            <% connectedSessions.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.label %></option>
            <% }); %>
          </select>
          <% if (typeof sharedSession !== 'undefined' && sharedSession) { %>
            <p class="text-[10px] text-gray-400 mt-1"><i class="ri-share-line mr-1"></i> Shared session available</p>
          <% } %>
        <% } else { %>
          <div class="w-full px-4 py-2.5 rounded-xl border border-red-200 bg-red-50 text-sm text-red-700">
            <i class="ri-error-warning-line mr-1"></i> No connected session available. Create or reconnect a session first.
          </div>
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Template (optional)</label>
        <select name="templateId" id="bulkTemplateSelect" onchange="fillBulkTemplate(this)"
          class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
          <option value="">No template</option>
          <% templates.forEach(t => { %>
            <option value="<%= t.id %>" data-content="<%= (t.content || '').replace(/"/g, '&quot;') %>" data-type="<%= t.type %>" data-mediaurl="<%= t.mediaUrl || '' %>" data-variables="<%= (t.variables || '').replace(/"/g, '&quot;') %>"><%= t.name %> <%= t.type !== 'text' ? '(' + t.type + ')' : '' %></option>
          <% }); %>
        </select>
        <p class="text-xs text-gray-400 mt-1" id="templateTypeHint"></p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Campaign Category</label>
        <select name="campaignCategory" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
          <option value="promotional">Promotional</option>
          <option value="followup">Follow-up</option>
          <option value="welcome">Welcome</option>
          <option value="announcement">Announcement</option>
          <option value="reminder">Reminder</option>
        </select>
      </div>
    </div>

    <!-- Message Type Tabs -->
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-2">Message Type</label>
      <div class="flex gap-2 flex-wrap">
        <button type="button" onclick="setBulkMsgType('text')" id="bulk-tab-text" class="bulk-msg-type-tab px-4 py-2 rounded-xl text-sm font-medium transition-all bg-pink-100 text-pink-700 border border-pink-200">
          <i class="ri-chat-1-line mr-1"></i> Text / Media
        </button>
        <button type="button" onclick="setBulkMsgType('poll')" id="bulk-tab-poll" class="bulk-msg-type-tab px-4 py-2 rounded-xl text-sm font-medium transition-all bg-gray-100 text-gray-600 border border-gray-200 hover:bg-gray-200">
          <i class="ri-bar-chart-box-line mr-1"></i> Poll
        </button>
      </div>
    </div>
    <input type="hidden" name="messageType" id="bulkMessageType" value="text">

    <!-- Text / Media Panel -->
    <div id="bulk-panel-text" class="bulk-msg-panel mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-2">Message *</label>
      <textarea name="message" id="bulkMessageContent" rows="3" required
        class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"
        placeholder="Your message content..."></textarea>
      <!-- Hidden fields for template media -->
      <input type="hidden" name="mediaUrl" id="bulkMediaUrl" value="">
      <!-- Media File Upload -->
      <div class="mt-4">
        <label class="block text-sm font-medium text-gray-700 mb-2"><i class="ri-image-line text-pink-500 mr-1"></i> Media File (optional — max 10MB)</label>
        <input type="file" name="mediaFile" id="bulkMediaFile" accept="image/*,video/*,audio/*,.pdf,.doc,.docx"
          class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-pink-50 file:text-pink-600 hover:file:bg-pink-100"
          onchange="validateBulkFile()">
        <p id="bulkFileError" class="text-xs text-red-600 mt-1 hidden"></p>
        <p class="text-[10px] text-gray-400 mt-1">If uploaded, this becomes the media and the message above becomes its caption. Overrides template media.</p>
      </div>
      <!-- Voice Recorder -->
      <div class="mt-4" id="bulkVoiceRecorderBox">
        <label class="block text-sm font-medium text-gray-700 mb-2"><i class="ri-mic-line text-pink-500 mr-1"></i> Or Record Voice Note</label>
        <%- include('../../partials/audio-recorder', { inputId: 'bulkMediaUrl', containerId: 'bulkRecorderWrap', typeInputId: 'bulkMessageType', showMic: false, showFileUpload: true }) %>
      </div>
    </div>

    <!-- Poll Panel -->
    <div id="bulk-panel-poll" class="bulk-msg-panel mb-4 hidden">
      <div class="bg-green-50 border border-green-100 rounded-xl p-4">
        <p class="text-xs text-green-700 mb-3"><i class="ri-information-line mr-1"></i> Polls let recipients vote on options. Votes automatically create or update leads.</p>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Poll Question *</label>
            <textarea name="message" rows="2" class="bulk-poll-content w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm resize-none" placeholder="Which package do you prefer?"></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Poll Options *</label>
            <textarea name="pollOptions" id="pollOptionsInput" rows="4" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm font-mono text-xs resize-none" placeholder="Starter&#10;Pro&#10;Enterprise" oninput="updatePollAutoResponses()"></textarea>
            <p class="text-[10px] text-gray-400 mt-1">One option per line. Minimum 2 options required.</p>
          </div>
          <!-- Auto-Responses per Option -->
          <div id="pollAutoResponsesBox" class="hidden">
            <label class="block text-xs font-semibold text-gray-600 mb-2 uppercase tracking-wide"><i class="ri-robot-2-line mr-1 text-pink-500"></i> Auto-Response per Option</label>
            <p class="text-[10px] text-gray-500 mb-2">When someone votes, automatically send the selected template.</p>
            <div id="pollAutoResponsesList" class="space-y-2">
              <!-- Dynamically populated by JS -->
            </div>
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" name="pollAllowMultiple" id="bulkPollAllowMultiple" value="true" class="rounded border-pink-200 text-pink-500">
            <label for="bulkPollAllowMultiple" class="text-xs text-gray-600">Allow multiple answers</label>
          </div>
        </div>
      </div>
    </div>

    <!-- Row: Contact Selection + Questionnaire Filter + Gap + Button -->
    <div class="grid md:grid-cols-4 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Select Contacts</label>
        <select id="contactSelectMode" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
          <option value="all">All Contacts</option>
          <option value="custom">Select Specific</option>
        </select>
      </div>
      <% if (typeof questionnaires !== 'undefined' && questionnaires.length > 0) { %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Filter by Questionnaire</label>
        <div class="grid grid-cols-3 gap-2">
          <select name="questionnaireFilterId" id="qFilterQnaire" onchange="updateQuestionFilter()"
            class="col-span-1 w-full px-3 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-xs bg-white">
            <option value="">Any</option>
            <% questionnaires.forEach(q => { %>
              <option value="<%= q.id %>"><%= q.name %></option>
            <% }); %>
          </select>
          <select name="questionFilterId" id="qFilterQuestion" onchange="updateAnswerFilter()"
            class="col-span-1 w-full px-3 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-xs bg-white">
            <option value="">Question</option>
          </select>
          <select name="answerFilterValue" id="qFilterAnswer"
            class="col-span-1 w-full px-3 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-xs bg-white">
            <option value="">Answer</option>
          </select>
        </div>
      </div>
      <% } %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Gap Between Messages</label>
        <div class="flex items-center gap-3 px-4 py-2 rounded-xl border border-pink-200">
          <input type="range" name="gapSeconds" min="30" max="60" value="30" id="gapRange"
            class="flex-1 accent-pink-500" oninput="document.getElementById('gapValue').textContent = this.value + 's'">
          <span id="gapValue" class="text-sm font-semibold text-pink-600 w-12 text-right">30s</span>
        </div>
      </div>
      <div class="flex items-end">
        <button type="submit" onclick="return prepareBulkSubmit()"
          class="w-full px-6 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center justify-center gap-2">
          <i class="ri-rocket-line"></i> Start Bulk Send
        </button>
      </div>
    </div>

    <!-- Contact Selection Panel -->
    <div id="contactPanel" class="hidden border border-pink-200 rounded-xl p-4 mb-4">
      <!-- Filters -->
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-3 mb-3 pb-3 border-b border-gray-100">
        <div class="sm:col-span-2">
          <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
          <div class="relative">
            <i class="ri-search-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="text" id="bulkContactSearch" placeholder="Search name or phone..."
              class="w-full pl-9 pr-3 py-2 rounded-lg border border-pink-200 focus:border-pink-500 outline-none text-sm">
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Group</label>
          <select id="bulkGroupFilter" class="w-full px-3 py-2 rounded-lg border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="">All Groups</option>
            <% groups.forEach(g => { %>
              <option value="<%= g %>"><%= g %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Tag</label>
          <select id="bulkTagFilter" class="w-full px-3 py-2 rounded-lg border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="">All Tags</option>
            <% tags.forEach(t => { %>
              <option value="<%= t %>"><%= t %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <!-- Select All Bar -->
      <div class="flex items-center gap-2 mb-3">
        <input type="checkbox" id="selectAllContacts" class="rounded border-pink-200 text-pink-500">
        <label class="text-sm font-medium text-gray-700">Select All Visible</label>
        <span class="text-xs text-gray-400 ml-auto" id="bulkFilterCount">Showing <%= contacts.length %> contacts</span>
        <span class="text-xs text-pink-600 font-medium" id="bulkSelectedCount">0 selected</span>
      </div>

      <!-- Contact Grid -->
      <div class="max-h-60 overflow-y-auto pr-1">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2" id="bulkContactGrid">
          <% contacts.forEach(c => { %>
            <label class="bulk-contact-row flex items-center gap-2 p-2 rounded-lg hover:bg-pink-50 cursor-pointer transition-colors"
              data-name="<%= (c.name || '').toLowerCase() %>"
              data-phone="<%= (c.phone || '').toLowerCase() %>"
              data-group="<%= c.group || 'default' %>"
              data-tags="<%= (c.tags || '').toLowerCase() %>">
              <input type="checkbox" name="contactIdsArr" value="<%= c.id %>" class="bulk-contact-check rounded border-pink-200 text-pink-500">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= c.name %></p>
                <p class="text-xs text-gray-500"><%= c.phone %></p>
                <% if (c.group && c.group !== 'default') { %>
                  <span class="inline-block mt-0.5 text-[10px] bg-blue-50 text-blue-600 px-1.5 py-0.5 rounded"><%= c.group %></span>
                <% } %>
                <% if (c.tags) { %>
                  <span class="inline-block mt-0.5 text-[10px] bg-pink-50 text-pink-600 px-1.5 py-0.5 rounded"><%= c.tags %></span>
                <% } %>
              </div>
            </label>
          <% }); %>
        </div>
        <div id="bulkNoContacts" class="hidden text-center py-8 text-sm text-gray-400">
          <i class="ri-user-search-line text-2xl text-gray-300 mb-1 block"></i>
          No contacts match your filters
        </div>
      </div>
    </div>

    <input type="hidden" name="contactIds" id="contactIdsJson" value="[]">
  </form>
</div>

<!-- Active Jobs -->
<% var activeJobs = typeof jobs !== 'undefined' ? jobs.filter(j => j.status === 'processing' || j.status === 'pending') : []; %>
<% if (activeJobs && activeJobs.length > 0) { %>
<div class="mb-8">
  <h3 class="font-semibold text-gray-900 mb-4">Active Jobs</h3>
  <div class="space-y-4">
    <% activeJobs.forEach(function(job) { %>
      <div class="bg-white rounded-2xl border border-pink-100 p-5 card-hover" data-job-id="<%= job.id %>">
        <div class="flex items-center justify-between mb-3">
          <div>
            <h4 class="font-medium text-gray-900 text-sm">Bulk Job #<%= job.id %></h4>
            <p class="text-xs text-gray-500 mt-1">
              <%= job.totalContacts || 0 %> contacts |
              <span class="job-status <%= job.status === 'completed' ? 'text-green-600' : 'text-yellow-600' %>"><%= job.status %></span>
            </p>
          </div>
          <div class="relative w-14 h-14">
            <svg class="w-14 h-14 transform -rotate-90" viewBox="0 0 36 36">
              <path class="text-gray-200" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3"/>
              <path class="text-pink-500 job-progress-ring"
                stroke-dasharray="<%= Math.round(((job.sentCount || 0 + job.failedCount || 0) / (job.totalContacts || 1)) * 100) %>, 100"
                d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3"/>
            </svg>
            <span class="absolute inset-0 flex items-center justify-center text-xs font-bold text-gray-700 job-progress-text">
              <%= Math.round(((job.sentCount || 0 + job.failedCount || 0) / (job.totalContacts || 1)) * 100) || 0 %>%
            </span>
          </div>
        </div>
        <div class="flex items-center gap-6 text-sm">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
            <span class="text-gray-600 text-xs">Sent: <span class="font-semibold job-sent text-green-600"><%= job.sentCount || 0 %></span></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500"></span>
            <span class="text-gray-600 text-xs">Failed: <span class="font-semibold job-failed text-red-600"><%= job.failedCount || 0 %></span></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-gray-300"></span>
            <span class="text-gray-600 text-xs">Pending: <span class="font-semibold job-pending text-gray-500"><%= (job.totalContacts || 0) - (job.sentCount || 0) - (job.failedCount || 0) %></span></span>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
</div>
<% } %>

<!-- Job History Table -->
<% var historyJobs = typeof jobs !== 'undefined' ? jobs.filter(j => j.status === 'completed' || j.status === 'failed') : []; %>
<div class="mb-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
    <h3 class="font-semibold text-gray-900">Job History</h3>
    <form method="GET" class="flex items-center gap-2">
      <input type="date" name="from" value="<%= typeof fromDate !== 'undefined' ? fromDate : '' %>" class="px-3 py-2 rounded-xl border border-pink-200 text-sm focus:border-pink-500 outline-none">
      <span class="text-gray-400 text-sm">to</span>
      <input type="date" name="to" value="<%= typeof toDate !== 'undefined' ? toDate : '' %>" class="px-3 py-2 rounded-xl border border-pink-200 text-sm focus:border-pink-500 outline-none">
      <button type="submit" class="px-4 py-2 bg-pink-50 text-pink-600 text-sm font-medium rounded-xl hover:bg-pink-100 transition-colors">
        <i class="ri-filter-search-line"></i> Filter
      </button>
      <% if (typeof fromDate !== 'undefined' && fromDate || typeof toDate !== 'undefined' && toDate) { %>
        <a href="/bulk" class="px-3 py-2 text-sm text-gray-500 hover:bg-gray-100 rounded-xl transition-colors"><i class="ri-close-line"></i></a>
      <% } %>
    </form>
  </div>
  <% if (historyJobs && historyJobs.length > 0) { %>
  <div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-pink-100">
          <tr>
            <th class="text-left px-6 py-3 font-medium text-gray-700">Content</th>
            <th class="text-left px-6 py-3 font-medium text-gray-700">Type</th>
            <th class="text-left px-6 py-3 font-medium text-gray-700">Contacts</th>
            <th class="text-left px-6 py-3 font-medium text-gray-700">Sent</th>
            <th class="text-left px-6 py-3 font-medium text-gray-700">Failed</th>
            <th class="text-left px-6 py-3 font-medium text-gray-700">Status</th>
            <th class="text-left px-6 py-3 font-medium text-gray-700">Date</th>
            <th class="text-left px-4 py-3 font-medium text-gray-700 w-10"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% historyJobs.forEach(job => { %>
            <tr class="hover:bg-pink-50/50 transition-colors">
              <td class="px-6 py-3 text-gray-600 max-w-xs truncate"><%= job.content || '-' %></td>
              <td class="px-6 py-3">
                <span class="text-xs capitalize px-2 py-1 rounded-full
                  <%= job.type === 'poll' ? 'bg-green-100 text-green-600' : job.type === 'image' ? 'bg-pink-100 text-pink-600' : job.type === 'video' ? 'bg-red-100 text-red-600' : job.type === 'audio' ? 'bg-amber-100 text-amber-600' : 'bg-gray-100 text-gray-600' %>">
                  <i class="ri-<%= job.type === 'poll' ? 'bar-chart-box-line' : job.type === 'image' ? 'image-line' : job.type === 'video' ? 'video-line' : job.type === 'audio' ? 'mic-line' : job.type === 'document' ? 'file-line' : 'chat-1-line' %> mr-1"></i>
                  <%= job.type %>
                </span>

              </td>
              <td class="px-6 py-3 text-xs font-medium"><%= job.totalContacts || 0 %></td>
              <td class="px-6 py-3 text-xs text-green-600 font-medium"><%= job.sentCount || 0 %></td>
              <td class="px-6 py-3 text-xs <%= (job.failedCount || 0) > 0 ? 'text-red-600' : 'text-gray-400' %> font-medium"><%= job.failedCount || 0 %></td>
              <td class="px-6 py-3">
                <% const statusCls = job.status === 'completed' ? 'bg-green-100 text-green-700' : job.status === 'processing' ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-600'; %>
                <span class="text-xs <%= statusCls %> px-2 py-1 rounded-full capitalize"><%= job.status %></span>
              </td>
              <td class="px-6 py-3 text-xs text-gray-500"><%= new Date(job.createdAt).toLocaleString() %></td>
              <td class="px-4 py-3">
                <form action="/bulk/delete-job/<%= job.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this job?');">
                  <button type="submit" class="text-gray-400 hover:text-red-500 transition-colors" title="Delete job">
                    <i class="ri-delete-bin-line"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination for History -->
  <% const dateQ = (typeof fromDate !== 'undefined' && fromDate ? '&from=' + encodeURIComponent(fromDate) : '') + (typeof toDate !== 'undefined' && toDate ? '&to=' + encodeURIComponent(toDate) : ''); %>
  <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
  <style>
    .page-btn { min-width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; font-size: 13px; font-weight: 500; border: 1px solid #e5e7eb; background: #fff; color: #374151; transition: all 0.15s; cursor: pointer; text-decoration: none; }
    .page-btn:hover { border-color: #ec4899; color: #ec4899; }
    .page-btn.active { background: #ec4899; color: #fff; border-color: #ec4899; }
    .page-btn.disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }
    .per-page-select { padding: 6px 28px 6px 12px; border-radius: 10px; border: 1px solid #e5e7eb; background: #fff url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e") right 8px center/16px no-repeat; font-size: 13px; color: #374151; appearance: none; -webkit-appearance: none; cursor: pointer; }
  </style>
  <div class="flex flex-wrap items-center justify-between gap-3 mt-4 px-2">
    <div class="text-xs text-gray-500">
      Showing <span class="font-semibold text-gray-700"><%= (pagination.page - 1) * pagination.perPage + 1 %></span>
      – <span class="font-semibold text-gray-700"><%= Math.min(pagination.page * pagination.perPage, pagination.total) %></span>
      of <span class="font-semibold text-gray-700"><%= pagination.total %></span> jobs
    </div>
    <div class="flex items-center gap-2">
      <a href="/bulk?page=<%= pagination.page - 1 %>&perPage=<%= pagination.perPage %><%= dateQ %>" class="page-btn <%= pagination.hasPrev ? '' : 'disabled' %>"><i class="ri-arrow-left-s-line"></i></a>
      <% pagination.pageRange.forEach(p => { %>
        <a href="/bulk?page=<%= p %>&perPage=<%= pagination.perPage %><%= dateQ %>" class="page-btn <%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
      <% }); %>
      <a href="/bulk?page=<%= pagination.page + 1 %>&perPage=<%= pagination.perPage %><%= dateQ %>" class="page-btn <%= pagination.hasNext ? '' : 'disabled' %>"><i class="ri-arrow-right-s-line"></i></a>
      <select class="per-page-select ml-2" onchange="window.location.href='/bulk?page=1&perPage=' + this.value + '<%= dateQ %>'">
        <option value="10" <%= pagination.perPage === 10 ? 'selected' : '' %>>10</option>
        <option value="30" <%= pagination.perPage === 30 ? 'selected' : '' %>>30</option>
        <option value="50" <%= pagination.perPage === 50 ? 'selected' : '' %>>50</option>
      </select>
    </div>
  </div>
  <% } %>
  <% } else { %>
  <div class="bg-white rounded-2xl border border-pink-100 p-8 text-center text-gray-400">
    <i class="ri-inbox-line text-3xl text-gray-300 mb-2 block"></i>
    No job history found
  </div>
  <% } %>
</div>

<script>
// Questionnaire data for filter dropdowns
const questionnaireData = <%- JSON.stringify((questionnaireQuestions || []).map(q => ({
  id: q.id,
  questionnaireId: q.questionnaireId,
  text: q.questionText,
  type: q.questionType,
  options: q.options
}))) %>;

const BULK_MAX_MB = 10;

function validateBulkFile() {
  const fileInput = document.getElementById('bulkMediaFile');
  const errorEl = document.getElementById('bulkFileError');
  const submitBtn = document.querySelector('button[onclick="return prepareBulkSubmit()"]');

  if (!fileInput.files || !fileInput.files[0]) {
    errorEl.classList.add('hidden');
    if (submitBtn) submitBtn.disabled = false;
    return true;
  }

  const file = fileInput.files[0];
  const sizeMB = file.size / 1024 / 1024;

  if (sizeMB > BULK_MAX_MB) {
    errorEl.textContent = `File too large (${sizeMB.toFixed(1)}MB). Maximum allowed is ${BULK_MAX_MB}MB.`;
    errorEl.classList.remove('hidden');
    if (submitBtn) submitBtn.disabled = true;
    return false;
  }

  errorEl.classList.add('hidden');
  if (submitBtn) submitBtn.disabled = false;
  return true;
}

function setBulkMsgType(type) {
  document.getElementById('bulkMessageType').value = type;

  // Update tabs
  document.querySelectorAll('.bulk-msg-type-tab').forEach(tab => {
    tab.classList.remove('bg-pink-100', 'text-pink-700', 'border-pink-200');
    tab.classList.add('bg-gray-100', 'text-gray-600', 'border-gray-200');
  });
  const activeTab = document.getElementById('bulk-tab-' + type);
  if (activeTab) {
    activeTab.classList.remove('bg-gray-100', 'text-gray-600', 'border-gray-200');
    activeTab.classList.add('bg-pink-100', 'text-pink-700', 'border-pink-200');
  }

  // Show/hide panels
  document.querySelectorAll('.bulk-msg-panel').forEach(p => p.classList.add('hidden'));
  document.getElementById('bulk-panel-' + type).classList.remove('hidden');

  // Update required fields
  const textContent = document.getElementById('bulkMessageContent');
  const pollContent = document.querySelector('.bulk-poll-content');
  if (textContent) textContent.required = (type === 'text');
  if (pollContent) pollContent.required = (type === 'poll');
}

function fillBulkTemplate(select) {
  const option = select.options[select.selectedIndex];
  const contentEl = document.getElementById('bulkMessageContent');
  const pollContentEl = document.querySelector('.bulk-poll-content');
  const typeEl = document.getElementById('bulkMessageType');
  const mediaEl = document.getElementById('bulkMediaUrl');
  const hintEl = document.getElementById('templateTypeHint');
  const recorderBox = document.getElementById('bulkVoiceRecorderBox');

  if (option.value) {
    const type = option.dataset.type || 'text';
    // Decode HTML entities (&quot; -> ") because dataset returns raw attribute text
    const decodeHtml = (str) => (str || '').replace(/&quot;/g, '"').replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>');
    const decodedContent = decodeHtml(option.dataset.content);
    const decodedVariables = decodeHtml(option.dataset.variables);

    // If template type is poll, switch to that tab and fill question + options
    if (type === 'poll') {
      setBulkMsgType('poll');
      try {
        const vars = JSON.parse(decodedVariables || '{}');
        const pollOpts = document.querySelector('#bulk-panel-poll textarea[name="pollOptions"]');
        const pollAllow = document.getElementById('bulkPollAllowMultiple');
        if (pollContentEl) pollContentEl.value = decodedContent || '';
        if (pollOpts && vars.pollOptions) {
          pollOpts.value = vars.pollOptions.join('\n');
          updatePollAutoResponses();
        }
        if (pollAllow) pollAllow.checked = !!vars.allowMultipleAnswers;
      } catch (e) { console.error('Poll template parse error:', e); }
    } else {
      setBulkMsgType('text');
      if (contentEl) contentEl.value = decodedContent || '';
    }
    typeEl.value = type;
    mediaEl.value = option.dataset.mediaurl || '';

    const mediaUrl = option.dataset.mediaurl || '';
    if (type !== 'text' && type !== 'poll' && mediaUrl) {
      hintEl.innerHTML = '<i class="ri-attachment-2"></i> This template includes ' + type + ' media (' + mediaUrl.split('/').pop() + ')';
      hintEl.className = 'text-xs text-pink-600 mt-1';
    } else if (type !== 'text' && type !== 'poll') {
      hintEl.innerHTML = '<i class="ri-information-line"></i> This is a ' + type + ' template but has no media file';
      hintEl.className = 'text-xs text-yellow-600 mt-1';
    } else {
      hintEl.textContent = '';
    }

    // Hide recorder if using an audio template (template provides the audio)
    if (type === 'audio') {
      recorderBox.classList.add('hidden');
    } else {
      recorderBox.classList.remove('hidden');
    }
  } else {
    setBulkMsgType('text');
    typeEl.value = 'text';
    mediaEl.value = '';
    hintEl.textContent = '';
    recorderBox.classList.remove('hidden');
  }
}

function updateQuestionFilter() {
  const qnaireId = parseInt(document.getElementById('qFilterQnaire').value) || 0;
  const qSelect = document.getElementById('qFilterQuestion');
  const aSelect = document.getElementById('qFilterAnswer');
  qSelect.innerHTML = '<option value="">Question</option>';
  aSelect.innerHTML = '<option value="">Answer</option>';
  if (!qnaireId) return;

  const questions = questionnaireData.filter(q => q.questionnaireId === qnaireId);
  questions.forEach(q => {
    const opt = document.createElement('option');
    opt.value = q.id;
    opt.textContent = q.text.substring(0, 30) + (q.text.length > 30 ? '...' : '');
    qSelect.appendChild(opt);
  });
}

function updateAnswerFilter() {
  const questionId = parseInt(document.getElementById('qFilterQuestion').value) || 0;
  const aSelect = document.getElementById('qFilterAnswer');
  aSelect.innerHTML = '<option value="">Answer</option>';
  if (!questionId) return;

  const q = questionnaireData.find(x => x.id === questionId);
  if (!q) return;

  if (q.type === 'yesno') {
    ['yes', 'no'].forEach(val => {
      const opt = document.createElement('option');
      opt.value = val;
      opt.textContent = val.charAt(0).toUpperCase() + val.slice(1);
      aSelect.appendChild(opt);
    });
  } else if (q.options) {
    try {
      const opts = JSON.parse(q.options);
      (Array.isArray(opts) ? opts : []).forEach(val => {
        const opt = document.createElement('option');
        opt.value = val;
        opt.textContent = val;
        aSelect.appendChild(opt);
      });
    } catch (e) {}
  }
}

document.getElementById('contactSelectMode').addEventListener('change', function() {
  const panel = document.getElementById('contactPanel');
  if (this.value === 'custom') {
    panel.classList.remove('hidden');
  } else {
    panel.classList.add('hidden');
  }
});

document.getElementById('selectAllContacts').addEventListener('change', function() {
  const visibleChecks = document.querySelectorAll('.bulk-contact-row:not(.hidden) .bulk-contact-check');
  visibleChecks.forEach(cb => cb.checked = this.checked);
  updateBulkCount();
});

document.getElementById('bulkContactSearch').addEventListener('input', filterBulkContacts);
document.getElementById('bulkGroupFilter').addEventListener('change', filterBulkContacts);
document.getElementById('bulkTagFilter').addEventListener('change', filterBulkContacts);

function filterBulkContacts() {
  const search = document.getElementById('bulkContactSearch').value.toLowerCase().trim();
  const group = document.getElementById('bulkGroupFilter').value;
  const tag = document.getElementById('bulkTagFilter').value;

  let visibleCount = 0;
  document.querySelectorAll('.bulk-contact-row').forEach(row => {
    const name = row.dataset.name || '';
    const phone = row.dataset.phone || '';
    const rowGroup = row.dataset.group || '';
    const rowTags = row.dataset.tags || '';

    const matchesSearch = !search || name.includes(search) || phone.includes(search);
    const matchesGroup = !group || rowGroup === group;
    const matchesTag = !tag || rowTags.includes(tag.toLowerCase());

    if (matchesSearch && matchesGroup && matchesTag) {
      row.classList.remove('hidden');
      visibleCount++;
    } else {
      row.classList.add('hidden');
      // Uncheck hidden contacts so they don't get submitted
      const cb = row.querySelector('.bulk-contact-check');
      if (cb) cb.checked = false;
    }
  });

  document.getElementById('bulkFilterCount').textContent = 'Showing ' + visibleCount + ' of <%= contacts.length %> contacts';
  document.getElementById('bulkNoContacts').classList.toggle('hidden', visibleCount > 0);
  updateBulkCount();
}

// Attach change listeners after filtering
function attachBulkCheckListeners() {
  document.querySelectorAll('.bulk-contact-check').forEach(cb => {
    cb.removeEventListener('change', updateBulkCount);
    cb.addEventListener('change', updateBulkCount);
  });
}
attachBulkCheckListeners();

function updateBulkCount() {
  const checked = document.querySelectorAll('.bulk-contact-check:checked');
  document.getElementById('bulkSelectedCount').textContent = checked.length + ' selected';
}

function prepareBulkSubmit() {
  const mode = document.getElementById('contactSelectMode').value;
  if (mode === 'custom') {
    const checked = document.querySelectorAll('.bulk-contact-check:checked');
    if (checked.length === 0) { alert('Select at least one contact'); return false; }
    const ids = Array.from(checked).map(cb => cb.value);
    document.getElementById('contactIdsJson').value = JSON.stringify(ids);
  }
  // Sync active panel content and clear inactive panels to avoid duplicate array submission
  const msgType = document.getElementById('bulkMessageType').value;
  const mainContent = document.getElementById('bulkMessageContent');
  const pollContent = document.querySelector('.bulk-poll-content');

  if (msgType === 'poll') {
    if (pollContent && mainContent) mainContent.value = pollContent.value;
  } else {
    if (pollContent) pollContent.value = '';
  }
  return true;
}

// Poll job status
function pollJobStatus() {
  document.querySelectorAll('[data-job-id]').forEach(card => {
    fetch('/bulk/status').then(r => r.json()).then(data => {
      if (data.error) return;
      const total = data.total || 1;
      const pct = Math.round(((data.sent + data.failed) / total) * 100);
      const ring = card.querySelector('.job-progress-ring');
      if (ring) ring.setAttribute('stroke-dasharray', pct + ', 100');
      const txt = card.querySelector('.job-progress-text');
      if (txt) txt.textContent = pct + '%';
      const sent = card.querySelector('.job-sent');
      if (sent) sent.textContent = data.sent;
      const failed = card.querySelector('.job-failed');
      if (failed) failed.textContent = data.failed;
      const pending = card.querySelector('.job-pending');
      if (pending) pending.textContent = total - data.sent - data.failed;
    }).catch(() => {});
  });
}
if (document.querySelectorAll('[data-job-id]').length > 0) {
  setInterval(pollJobStatus, 3000);
}

// Poll auto-response dynamic UI
const pollTemplates = <%- JSON.stringify((typeof templates !== 'undefined' ? templates : []).map(t => ({ id: t.id, name: t.name }))) %>;

function updatePollAutoResponses() {
  const optionsText = document.getElementById('pollOptionsInput').value;
  const options = optionsText.split('\n').map(o => o.trim()).filter(Boolean);
  const box = document.getElementById('pollAutoResponsesBox');
  const list = document.getElementById('pollAutoResponsesList');

  if (options.length < 2) {
    box.classList.add('hidden');
    list.innerHTML = '';
    return;
  }

  box.classList.remove('hidden');
  list.innerHTML = '';

  options.forEach((opt, idx) => {
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2 bg-white rounded-lg border border-green-200 px-3 py-2';

    const label = document.createElement('span');
    label.className = 'text-xs font-medium text-gray-700 flex-shrink-0';
    label.textContent = opt;

    const arrow = document.createElement('span');
    arrow.className = 'text-xs text-gray-400';
    arrow.textContent = '→';

    const select = document.createElement('select');
    select.name = 'pollAutoResponse_' + idx;
    select.className = 'flex-1 min-w-0 px-2 py-1.5 rounded-lg border border-pink-200 text-xs bg-white outline-none focus:border-pink-500';
    select.innerHTML = '<option value="">No auto-response</option>' +
      pollTemplates.map(t => '<option value="' + t.id + '">' + t.name + '</option>').join('');

    const hiddenOpt = document.createElement('input');
    hiddenOpt.type = 'hidden';
    hiddenOpt.name = 'pollAutoOption_' + idx;
    hiddenOpt.value = opt;

    row.appendChild(label);
    row.appendChild(arrow);
    row.appendChild(select);
    row.appendChild(hiddenOpt);
    list.appendChild(row);
  });
}
</script>
