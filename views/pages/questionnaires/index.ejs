<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h2 class="text-xl font-bold text-gray-900">Session Questionnaires</h2>
    <p class="text-sm text-gray-500">Create questionnaires that appear when users create WhatsApp sessions</p>
  </div>
  <button onclick="document.getElementById('createModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2 w-fit">
    <i class="ri-add-line"></i> New Questionnaire
  </button>
</div>

<% if (questionnaires.length === 0) { %>
  <div class="bg-white rounded-2xl border border-pink-100 p-12 text-center">
    <div class="w-16 h-16 rounded-full bg-purple-50 flex items-center justify-center mx-auto mb-4">
      <i class="ri-questionnaire-line text-2xl text-purple-300"></i>
    </div>
    <h3 class="font-semibold text-gray-900 mb-2">No Questionnaires Yet</h3>
    <p class="text-sm text-gray-500 mb-4 max-w-md mx-auto">Create a questionnaire to collect business information when users set up WhatsApp sessions. Answers can auto-create leads.</p>
    <button onclick="document.getElementById('createModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all inline-flex items-center gap-2">
      <i class="ri-add-line"></i> Create Questionnaire
    </button>
  </div>
<% } else { %>
  <div class="space-y-6">
    <% questionnaires.forEach(q => { %>
      <div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
        <div class="p-5 border-b border-pink-100 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center">
              <i class="ri-questionnaire-line text-purple-600"></i>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900"><%= q.name %></h3>
              <p class="text-xs text-gray-500"><%= q.description || 'No description' %> — <%= q.questions ? q.questions.length : 0 %> questions</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs px-2.5 py-1 rounded-full <%= q.isActive ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-500' %>">
              <%= q.isActive ? 'Active' : 'Inactive' %>
            </span>
            <button onclick="showAddQuestionModal('<%= q.id %>', '<%= q.name %>')" class="px-3 py-1.5 text-xs font-medium text-pink-600 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors">
              <i class="ri-add-line mr-1"></i> Add Question
            </button>
            <form action="/questionnaires/delete/<%= q.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this questionnaire and all its questions?')">
              <button type="submit" class="p-2 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                <i class="ri-delete-bin-line"></i>
              </button>
            </form>
          </div>
        </div>

        <% if (q.questions && q.questions.length > 0) { %>
          <div class="divide-y divide-gray-100">
            <% q.questions.forEach((question, idx) => { %>
              <div class="px-5 py-4 flex items-start justify-between hover:bg-gray-50/50 transition-colors">
                <div class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-gray-100 text-gray-500 text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5"><%= idx + 1 %></span>
                  <div>
                    <p class="text-sm font-medium text-gray-900"><%= question.questionText %></p>
                    <div class="flex items-center gap-2 mt-1">
                      <span class="text-[10px] px-2 py-0.5 rounded-full bg-blue-50 text-blue-600 font-medium uppercase"><%= question.questionType %></span>
                      <% if (question.isRequired) { %>
                        <span class="text-[10px] px-2 py-0.5 rounded-full bg-red-50 text-red-600 font-medium">Required</span>
                      <% } %>
                      <% if (question.mapToLeadField) { %>
                        <span class="text-[10px] px-2 py-0.5 rounded-full bg-green-50 text-green-600 font-medium">→ <%= question.mapToLeadField %></span>
                      <% } %>
                      <% if (question.options) { %>
                        <% try { const opts = JSON.parse(question.options); %>
                          <span class="text-[10px] text-gray-400"><%= opts.join(', ') %></span>
                        <% } catch(e) {} %>
                      <% } %>
                    </div>
                  </div>
                </div>
                <form action="/questionnaires/delete-question/<%= question.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this question?')">
                  <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors">
                    <i class="ri-delete-bin-line text-sm"></i>
                  </button>
                </form>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="px-5 py-6 text-center">
            <p class="text-sm text-gray-400">No questions yet. Click "Add Question" to build your questionnaire.</p>
          </div>
        <% } %>
      </div>
    <% }); %>
  </div>
<% } %>

<!-- Create Questionnaire Modal -->
<dialog id="createModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-md">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Create Questionnaire</h3>
    <form action="/questionnaires/create" method="POST">
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
          <input type="text" name="name" required placeholder="e.g., Business Onboarding"
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea name="description" rows="2" placeholder="What this questionnaire is for..."
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm resize-none"></textarea>
        </div>
      </div>
      <div class="flex gap-3 justify-end mt-4">
        <button type="button" onclick="document.getElementById('createModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-add-line"></i> Create</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- Add Question Modal -->
<dialog id="addQuestionModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-1">Add Question</h3>
    <p class="text-xs text-gray-500 mb-4" id="aqQuestionnaireName"></p>
    <form action="" method="POST" id="addQuestionForm">
      <input type="hidden" name="questionnaireId" id="aqQuestionnaireId">
      <div class="space-y-3">
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Question Text *</label>
          <input type="text" name="questionText" required placeholder="What is your business name?"
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Type *</label>
            <select name="questionType" id="aqType" onchange="toggleOptions()" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-white">
              <option value="text">Text Input</option>
              <option value="select">Select Box (Dropdown)</option>
              <option value="yesno">Yes / No</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Map to Lead Field</label>
            <select name="mapToLeadField" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm bg-white">
              <option value="">— None —</option>
              <option value="name">Name</option>
              <option value="phone">Phone</option>
              <option value="email">Email</option>
              <option value="status">Status</option>
              <option value="tags">Tags</option>
              <option value="notes">Notes</option>
              <option value="data">Data (JSON)</option>
            </select>
          </div>
        </div>
        <div id="optionsField" class="hidden">
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Options (comma-separated)</label>
          <input type="text" name="options" placeholder="Small, Medium, Large, Enterprise"
            class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
          <p class="text-[10px] text-gray-400 mt-1">For Select Box type only</p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Sort Order</label>
            <input type="number" name="sortOrder" value="0" min="0" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
          </div>
          <div class="flex items-center gap-2 pt-6">
            <input type="checkbox" name="isRequired" checked class="rounded border-pink-200 text-pink-600 focus:ring-pink-500 w-4 h-4">
            <label class="text-sm text-gray-700">Required</label>
          </div>
        </div>
      </div>
      <div class="flex gap-3 justify-end mt-4">
        <button type="button" onclick="document.getElementById('addQuestionModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-add-line"></i> Add Question</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
function showAddQuestionModal(id, name) {
  document.getElementById('addQuestionForm').action = '/questionnaires/add-question/' + id;
  document.getElementById('aqQuestionnaireName').textContent = 'Adding to: ' + name;
  document.getElementById('addQuestionModal').showModal();
}

function toggleOptions() {
  const type = document.getElementById('aqType').value;
  document.getElementById('optionsField').classList.toggle('hidden', type !== 'select');
}
</script>
