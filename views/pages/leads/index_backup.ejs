<script>
// Lead details view
const leadsData = <%- JSON.stringify(leads.map(l => {
  let d = {};
  try { if (l.data) d = JSON.parse(l.data); } catch(e){}
  return { id: l.id, name: l.name, phone: l.phone, email: l.email, countryCode: l.countryCode, source: l.source, status: l.status, tags: l.tags, notes: l.notes, createdAt: l.createdAt, lastContactedAt: l.lastContactedAt, data: d };
})) %>;

function viewLeadDetails(id) {
  const detailRow = document.getElementById('detail-' + id);
  if (detailRow) {
    // Hide all other detail rows
    document.querySelectorAll('.detail-row').forEach(r => { if (r.id !== 'detail-' + id) r.classList.add('hidden'); });
    detailRow.classList.toggle('hidden');
  }
}

// Column resizing
(function initColResize() {
  const table = document.getElementById('leadTable');
  if (!table) return;
  const headers = table.querySelectorAll('thead th');
  let activeHandle = null, startX = 0, startWidth = 0, activeTh = null;

  headers.forEach(th => {
    const handle = th.querySelector('.resize-handle');
    if (!handle) return;
    handle.addEventListener('mousedown', function(e) {
      e.preventDefault();
      activeTh = th;
      activeHandle = handle;
      startX = e.pageX;
      startWidth = th.offsetWidth;
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
    });
  });

  document.addEventListener('mousemove', function(e) {
    if (!activeTh) return;
    const newWidth = Math.max(40, startWidth + (e.pageX - startX));
    activeTh.style.width = newWidth + 'px';
    const colKey = activeTh.dataset.col;
    if (colKey) localStorage.setItem('lead_col_width_' + colKey, newWidth);
  });

  document.addEventListener('mouseup', function() {
    if (activeTh) { activeTh = null; activeHandle = null; document.body.style.cursor = ''; document.body.style.userSelect = ''; }
  });
})();

// Restore saved column widths
(function restoreColWidths() {
  const table = document.getElementById('leadTable');
  if (!table) return;
  table.querySelectorAll('thead th').forEach(th => {
    const colKey = th.dataset.col;
    if (!colKey) return;
    const saved = localStorage.getItem('lead_col_width_' + colKey);
    if (saved) th.style.width = saved + 'px';
  });
})();

// Column visibility toggle
(function initColToggle() {
  const cols = [
    { key: 'sno', label: 'S.No' },
    { key: 'name', label: 'Name' },
    { key: 'phone', label: 'Phone' },
    { key: 'email', label: 'Email' },
    { key: 'source', label: 'Source' },
    { key: 'status', label: 'Status' },
    { key: 'createdAt', label: 'Date' },
    { key: 'actions', label: 'Actions' },
  ];
  const list = document.getElementById('colToggleList');
  if (!list) return;

  cols.forEach(col => {
    const saved = localStorage.getItem('lead_col_hide_' + col.key);
    const isHidden = saved === 'true';
    const row = document.createElement('label');
    row.className = 'flex items-center gap-2 cursor-pointer';
    row.innerHTML = `<input type="checkbox" class="rounded border-gray-300 text-pink-600" ${isHidden ? '' : 'checked'} onchange="toggleColumn('${col.key}', this.checked)"> <span class="text-sm text-gray-700">${col.label}</span>`;
    list.appendChild(row);
  });

  // Apply saved visibility on load
  cols.forEach(col => {
    const saved = localStorage.getItem('lead_col_hide_' + col.key);
    if (saved === 'true') toggleColumn(col.key, false);
  });
})();

function toggleColumn(key, show) {
  localStorage.setItem('lead_col_hide_' + key, String(!show));
  const table = document.getElementById('leadTable');
  if (!table) return;
  const th = table.querySelector('th[data-col="' + key + '"]');
  if (th) th.style.display = show ? '' : 'none';
  const cells = table.querySelectorAll('td:nth-child(' + (getColIndex(key) + 1) + ')');
  cells.forEach(td => td.style.display = show ? '' : 'none');
  // Also hide detail row cells that span - they don't need adjustment
}

function getColIndex(key) {
  const table = document.getElementById('leadTable');
  if (!table) return -1;
  const headers = Array.from(table.querySelectorAll('thead th'));
  return headers.findIndex(th => th.dataset.col === key);
}

let submitTimer = null;
function delayedSubmit(form) {
  if (submitTimer) clearTimeout(submitTimer);
  submitTimer = setTimeout(function() { form.submit(); }, 400);
}
</script>

