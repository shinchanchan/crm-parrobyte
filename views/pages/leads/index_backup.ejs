<script>
function fillTemplate(select) {
  const option = select.options[select.selectedIndex];
  if (option.value) document.getElementById('bulkMessage').value = option.dataset.content;
}

function fillModalTemplate(select) {
  const option = select.options[select.selectedIndex];
  const recorderBox = document.getElementById('modalRecorderBox');
  const pollPanel = document.getElementById('leadPollPanel');
  const decodeHtml = (str) => (str || '').replace(/&quot;/g, '"').replace(/&amp;/g, '&');

  if (option.value) {
    const type = option.dataset.type || 'text';
    document.getElementById('modalMessage').value = decodeHtml(option.dataset.content) || '';
    document.getElementById('modalTemplateId').value = option.value;
    document.getElementById('modalMessageType').value = type;
    document.getElementById('modalMediaUrl').value = option.dataset.mediaurl || '';

    if (type === 'poll') {
      if (recorderBox) recorderBox.classList.add('hidden');
      try {
        const vars = JSON.parse(decodeHtml(option.dataset.variables) || '{}');
        if (vars.pollOptions && vars.pollOptions.length >= 2) {
          const qEl = document.getElementById('leadPollQuestion');
          const oEl = document.getElementById('leadPollOptions');
          if (qEl) qEl.value = decodeHtml(option.dataset.content) || '';
          if (oEl) oEl.value = vars.pollOptions.join('\n');
          if (pollPanel) pollPanel.classList.remove('hidden');
        }
      } catch (e) {}
    } else {
      if (pollPanel) pollPanel.classList.add('hidden');
      if (type === 'audio') {
        if (recorderBox) recorderBox.classList.add('hidden');
      } else {
        if (recorderBox) recorderBox.classList.remove('hidden');
      }
    }
  } else {
    document.getElementById('modalMessage').value = '';
    document.getElementById('modalTemplateId').value = '';
    document.getElementById('modalMessageType').value = 'text';
    document.getElementById('modalMediaUrl').value = '';
    if (pollPanel) pollPanel.classList.add('hidden');
    if (recorderBox) recorderBox.classList.remove('hidden');
  }
}

function editLead(id, name, status, notes, tags) {
  document.getElementById('editLeadForm').action = '/leads/update/' + id;
  document.getElementById('editLeadStatus').value = status || 'new';
  document.getElementById('editLeadNotes').value = notes || '';
  document.getElementById('editLeadTags').value = tags || '';
  document.getElementById('editLeadModal').showModal();
}

function getVisibleCheckboxes() {
  return Array.from(document.querySelectorAll('.row-checkbox')).filter(cb => {
    const row = cb.closest('tr');
    return row && row.style.display !== 'none';
  });
}

function getVisibleChecked() {
  return getVisibleCheckboxes().filter(cb => cb.checked);
}

function deleteSelectedLeads() {
  const checked = getVisibleChecked();
  if (checked.length === 0) { alert('Select at least one lead'); return; }
  if (!confirm('Delete ' + checked.length + ' selected lead(s)? This cannot be undone.')) return;

  const ids = checked.map(cb => cb.value);
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/leads/delete-bulk';
  const input = document.createElement('input');
  input.type = 'hidden';
  input.name = 'leadIds';
  input.value = JSON.stringify(ids);
  form.appendChild(input);
  document.body.appendChild(form);
  form.submit();
}

function openWhatsAppModal() {
  const checked = getVisibleChecked();
  if (checked.length === 0) { alert('Select at least one lead'); return; }

  const ids = checked.map(cb => cb.value);
  document.getElementById('modalLeadIds').value = JSON.stringify(ids);
  document.getElementById('modalSelectedCount').textContent = checked.length;
  document.getElementById('whatsappModal').showModal();
}

function openEmailModal() {
  const checked = getVisibleChecked();
  if (checked.length === 0) { alert('Select at least one lead'); return; }

  const ids = checked.map(cb => cb.value);
  document.getElementById('emailLeadIds').value = JSON.stringify(ids);
  document.getElementById('emailSelectedCount').textContent = checked.length;
  document.getElementById('emailModal').showModal();
}

function fillEmailTemplate(select) {
  const option = select.options[select.selectedIndex];
  const decodeHtml = (str) => (str || '').replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&#10;/g, '\n').replace(/&amp;/g, '&');
  if (option.value) {
    document.getElementById('emailSubject').value = decodeHtml(option.dataset.subject) || '';
    document.getElementById('emailBody').value = decodeHtml(option.dataset.content) || '';
    document.getElementById('emailTemplateId').value = option.value;
    const isHtml = option.dataset.ishtml === 'true';
    document.getElementById('emailIsHtml').value = isHtml ? 'true' : 'false';
    document.getElementById('emailHtmlToggle').checked = isHtml;
  } else {
    document.getElementById('emailSubject').value = '';
    document.getElementById('emailBody').value = '';
    document.getElementById('emailTemplateId').value = '';
    document.getElementById('emailIsHtml').value = 'false';
    document.getElementById('emailHtmlToggle').checked = false;
  }
}

// Checkbox selection
function initCheckboxes() {
  const selectAll = document.getElementById('selectAll');

  if (selectAll) {
    selectAll.addEventListener('change', function() {
      getVisibleCheckboxes().forEach(cb => cb.checked = this.checked);
      updateCount();
      syncSelectAllState();
    });
  }

  // Use event delegation for row checkboxes (works with pagination/filtering)
  const tableBody = document.querySelector('.lead-table tbody') || document.querySelector('#leadTable tbody');
  if (tableBody) {
    tableBody.addEventListener('change', function(e) {
      if (e.target.classList.contains('row-checkbox')) {
        updateCount();
        syncSelectAllState();
      }
    });
  }
}

function updateCount() {
  const checked = getVisibleChecked();
  const countDisplay = document.getElementById('selectedCount');
  if (countDisplay) countDisplay.textContent = checked.length;
}

function syncSelectAllState() {
  const selectAll = document.getElementById('selectAll');
  if (!selectAll) return;
  const visible = getVisibleCheckboxes();
  if (visible.length === 0) {
    selectAll.checked = false;
    selectAll.indeterminate = false;
    return;
  }
  const checkedCount = visible.filter(cb => cb.checked).length;
  if (checkedCount === 0) {
    selectAll.checked = false;
    selectAll.indeterminate = false;
  } else if (checkedCount === visible.length) {
    selectAll.checked = true;
    selectAll.indeterminate = false;
  } else {
    selectAll.checked = false;
    selectAll.indeterminate = true;
  }
}

// Lightbox for image/video full view
function openLightbox(type, src) {
  let existing = document.getElementById('leadLightbox');
  if (!existing) {
    existing = document.createElement('div');
    existing.id = 'leadLightbox';
    existing.className = 'lightbox';
    existing.innerHTML = '<div class="lightbox-close" onclick="closeLightbox()">&times;</div><div id="lightboxContent"></div>';
    existing.onclick = function(e) { if (e.target === existing) closeLightbox(); };
    document.body.appendChild(existing);
  }
  const content = document.getElementById('lightboxContent');
  content.innerHTML = type === 'video'
    ? '<video src="' + src + '" controls autoplay style="max-width:90vw;max-height:90vh;border-radius:12px;"></video>'
    : '<img src="' + src + '" style="max-width:90vw;max-height:90vh;border-radius:12px;">';
  existing.classList.add('active');
}
function closeLightbox() {
  const box = document.getElementById('leadLightbox');
  if (box) box.classList.remove('active');
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeLightbox();
});

// Initialize on DOM ready
document.addEventListener('DOMContentLoaded', initCheckboxes);
</script>
