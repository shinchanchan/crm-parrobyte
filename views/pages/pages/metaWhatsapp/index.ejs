<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h2 class="text-xl font-bold text-gray-900">Meta WhatsApp API</h2>
    <p class="text-sm text-gray-500">Official WhatsApp Business API — no ban risk, template messaging</p>
  </div>
  <% if (accounts.length === 0) { %>
    <button onclick="document.getElementById('connectModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2 w-fit">
      <i class="ri-link"></i> Connect Account
    </button>
  <% } else { %>
    <a href="/meta-whatsapp/send" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2 w-fit">
      <i class="ri-send-plane-line"></i> Send Message
    </a>
  <% } %>
</div>

<!-- Stats Cards -->
<% if (accounts.length > 0) { %>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-2xl border border-pink-100 p-5 card-hover">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center">
        <i class="ri-send-plane-line text-green-600"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500">Sent Today</p>
        <p class="text-xl font-bold text-gray-900"><%= stats.todaySent %></p>
      </div>
    </div>
  </div>
  <div class="bg-white rounded-2xl border border-pink-100 p-5 card-hover">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center">
        <i class="ri-message-3-line text-blue-600"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500">Total Sent</p>
        <p class="text-xl font-bold text-gray-900"><%= stats.totalSent %></p>
      </div>
    </div>
  </div>
  <div class="bg-white rounded-2xl border border-pink-100 p-5 card-hover">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center">
        <i class="ri-file-list-3-line text-purple-600"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500">Templates Approved</p>
        <p class="text-xl font-bold text-gray-900"><%= stats.templatesApproved %></p>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Connected Accounts -->
<% if (accounts.length > 0) { %>
<div class="bg-white rounded-2xl border border-pink-100 p-6 mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="font-semibold text-gray-900 flex items-center gap-2">
      <i class="ri-whatsapp-fill text-green-600"></i> Connected Accounts
    </h3>
    <button onclick="document.getElementById('connectModal').showModal()" class="text-sm text-pink-600 hover:text-pink-700 font-medium">
      <i class="ri-add-line"></i> Add Another
    </button>
  </div>
  <div class="space-y-3">
    <% accounts.forEach(account => { %>
      <div class="flex items-center justify-between p-4 rounded-xl bg-gray-50/60 border border-gray-100">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center">
            <i class="ri-whatsapp-line text-green-600 text-lg"></i>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900"><%= account.accountName %></p>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-green-100 text-green-600 font-medium">Connected</span>
              <span class="text-[10px] text-gray-400"><%= account.displayPhoneNumber || account.phoneNumberId %></span>
              <span class="text-[10px] text-gray-400">WABA: <%= account.wabaId %></span>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <a href="/meta-whatsapp/send" class="px-3 py-1.5 text-xs font-medium text-white bg-gradient-to-r from-green-500 to-green-600 rounded-lg hover:shadow transition-all">
            <i class="ri-send-plane-line mr-1"></i> Send
          </a>
          <form action="/meta-whatsapp/disconnect/<%= account.id %>" method="POST" class="inline" onsubmit="return confirm('Disconnect this account? All templates will remain on Meta.')">
            <button type="submit" class="p-2 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Disconnect">
              <i class="ri-logout-box-r-line"></i>
            </button>
          </form>
        </div>
      </div>
    <% }); %>
  </div>
</div>
<% } %>

<!-- Setup Guide -->
<div class="bg-white rounded-2xl border border-pink-100 p-6">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500 to-blue-500 flex items-center justify-center text-white">
      <i class="ri-book-open-line"></i>
    </div>
    <div>
      <h3 class="font-bold text-lg text-gray-900">Setup Guide</h3>
      <p class="text-xs text-gray-500">Follow these steps to connect your Meta WhatsApp Business API</p>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-4">
    <!-- Step 1 -->
    <div class="p-5 rounded-2xl bg-gray-50/60 border border-gray-100 hover:border-green-200 transition-all">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-blue-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">1</div>
        <div>
          <h4 class="font-semibold text-sm text-gray-900 mb-1">Create Meta Business Account</h4>
          <p class="text-xs text-gray-500 mb-2">Sign up at Meta Business Manager with your business details.</p>
          <a href="https://business.facebook.com/overview" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-green-50 text-green-600 text-xs font-medium hover:bg-green-100 transition-colors">
            <i class="ri-external-link-line"></i> Open Business Manager
          </a>
        </div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="p-5 rounded-2xl bg-gray-50/60 border border-gray-100 hover:border-green-200 transition-all">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-blue-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">2</div>
        <div>
          <h4 class="font-semibold text-sm text-gray-900 mb-1">Create Facebook App</h4>
          <p class="text-xs text-gray-500 mb-2">Create an app, add "WhatsApp" product, and link your Business Account.</p>
          <a href="https://developers.facebook.com/apps/" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-green-50 text-green-600 text-xs font-medium hover:bg-green-100 transition-colors">
            <i class="ri-external-link-line"></i> Facebook Developers
          </a>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="p-5 rounded-2xl bg-gray-50/60 border border-gray-100 hover:border-green-200 transition-all">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-blue-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">3</div>
        <div>
          <h4 class="font-semibold text-sm text-gray-900 mb-1">Add & Verify Phone Number</h4>
          <p class="text-xs text-gray-500 mb-2">In the WhatsApp product settings, add a phone number and complete verification via SMS/call.</p>
          <div class="bg-amber-50 rounded-lg p-2 text-[10px] text-amber-700">
            <i class="ri-information-line mr-1"></i> You can use a new number or port an existing one
          </div>
        </div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="p-5 rounded-2xl bg-gray-50/60 border border-gray-100 hover:border-green-200 transition-all">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-blue-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">4</div>
        <div>
          <h4 class="font-semibold text-sm text-gray-900 mb-1">Get Permanent Access Token</h4>
          <p class="text-xs text-gray-500 mb-2">Go to Business Settings → System Users → Generate Token with <code>whatsapp_business_messaging</code> and <code>whatsapp_business_management</code> permissions.</p>
          <div class="bg-blue-50 rounded-lg p-2 text-[10px] text-blue-700 font-mono">
            Permissions needed:<br>whatsapp_business_messaging<br>whatsapp_business_management
          </div>
        </div>
      </div>
    </div>

    <!-- Step 5 -->
    <div class="p-5 rounded-2xl bg-gray-50/60 border border-gray-100 hover:border-green-200 transition-all">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-blue-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">5</div>
        <div>
          <h4 class="font-semibold text-sm text-gray-900 mb-1">Find Your IDs</h4>
          <p class="text-xs text-gray-500 mb-2">Copy these values from your WhatsApp product dashboard:</p>
          <div class="space-y-1.5">
            <div class="flex items-center justify-between gap-2 bg-white rounded-lg px-3 py-1.5 border border-gray-200">
              <span class="text-[10px] text-gray-500">Phone Number ID</span>
              <span class="text-[10px] font-mono text-gray-700">1xxxxxxxxxx</span>
            </div>
            <div class="flex items-center justify-between gap-2 bg-white rounded-lg px-3 py-1.5 border border-gray-200">
              <span class="text-[10px] text-gray-500">WABA ID</span>
              <span class="text-[10px] font-mono text-gray-700">1xxxxxxxxxx</span>
            </div>
            <div class="flex items-center justify-between gap-2 bg-white rounded-lg px-3 py-1.5 border border-gray-200">
              <span class="text-[10px] text-gray-500">App ID</span>
              <span class="text-[10px] font-mono text-gray-700">1xxxxxxxxxx</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 6 -->
    <div class="p-5 rounded-2xl bg-gray-50/60 border border-green-200 hover:border-green-300 transition-all">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-blue-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">6</div>
        <div>
          <h4 class="font-semibold text-sm text-gray-900 mb-1">Paste & Connect</h4>
          <p class="text-xs text-gray-500 mb-2">Fill in the connect form below with all the details you copied.</p>
          <button onclick="document.getElementById('connectModal').showModal()" class="w-full py-2 text-xs font-medium text-white rounded-lg flex items-center justify-center gap-1 bg-gradient-to-r from-green-500 to-blue-500 hover:shadow transition-all">
            <i class="ri-link mr-1"></i> Open Connect Form
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Webhook Setup Note -->
  <% if (accounts.length > 0) { %>
  <div class="mt-6 p-4 rounded-xl bg-blue-50 border border-blue-100">
    <div class="flex items-start gap-3">
      <i class="ri-webhook-line text-blue-600 mt-0.5"></i>
      <div>
        <p class="text-sm font-medium text-blue-800">Webhook Configuration</p>
        <p class="text-xs text-blue-600 mb-2">To receive incoming messages and delivery receipts, configure this webhook URL in your Meta app:</p>
        <div class="flex items-center gap-2">
          <code class="flex-1 bg-white rounded-lg px-3 py-2 text-xs font-mono text-gray-700 border border-blue-200 break-all"><%= process.env.APP_URL || 'https://yourdomain.com' %>/meta-whatsapp/webhook</code>
          <button onclick="copyWebhookUrl()" class="px-3 py-2 bg-blue-600 text-white text-xs font-medium rounded-lg hover:bg-blue-700 transition-colors flex-shrink-0">
            <i class="ri-file-copy-line"></i>
          </button>
        </div>
        <p class="text-[10px] text-blue-500 mt-1">Verify Token: <span class="font-mono"><%= accounts[0].webhookVerifyToken %></span></p>
      </div>
    </div>
  </div>
  <% } %>
</div>

<!-- Connect Modal -->
<dialog id="connectModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-1">Connect Meta WhatsApp API</h3>
    <p class="text-xs text-gray-500 mb-4">Enter your Meta app credentials from the setup guide above</p>
    <form action="/meta-whatsapp/connect" method="POST" data-loading-text="Validating credentials...">
      <div class="space-y-3">
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Account Name</label>
          <input type="text" name="accountName" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm" placeholder="e.g., My Business WhatsApp">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">App ID</label>
            <input type="text" name="appId" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm font-mono" placeholder="123456789">
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">App Secret <span class="text-gray-400 font-normal normal-case">(optional)</span></label>
            <input type="password" name="appSecret" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm font-mono" placeholder="For webhook verification">
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Permanent Access Token</label>
          <textarea name="accessToken" rows="2" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm font-mono resize-none" placeholder="EAAB... (System User Token)"></textarea>
          <p class="text-[10px] text-gray-400 mt-1">Generate from Business Settings → System Users</p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">Phone Number ID</label>
            <input type="text" name="phoneNumberId" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm font-mono" placeholder="1xxxxxxxxxx">
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wide">WABA ID</label>
            <input type="text" name="wabaId" required class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm font-mono" placeholder="1xxxxxxxxxx">
            <p class="text-[10px] text-gray-400 mt-1">WhatsApp Business Account ID</p>
          </div>
        </div>
      </div>
      <div class="flex gap-3 justify-end mt-4">
        <button type="button" onclick="document.getElementById('connectModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg flex items-center gap-1">
          <i class="ri-link mr-1"></i> Connect
        </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
function copyWebhookUrl() {
  const url = '<%= process.env.APP_URL || 'https://yourdomain.com' %>/meta-whatsapp/webhook';
  navigator.clipboard.writeText(url).then(() => {
    alert('Webhook URL copied to clipboard!');
  });
}
</script>
