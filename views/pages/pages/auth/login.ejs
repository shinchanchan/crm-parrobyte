<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Sign in to ParroByte CRM — WhatsApp automation and lead management platform.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <link rel="stylesheet" href="/css/app.css">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.1.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 50%, #fbcfe8 100%); min-height: 100vh; }
    .btn-pink { background: linear-gradient(135deg, #ec4899 0%, #f472b6 100%); }
    .btn-pink:hover { background: linear-gradient(135deg, #db2777 0%, #ec4899 100%); }
  </style>
</head>
<body class="flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-3xl shadow-xl shadow-pink-100 border border-pink-100 p-8">
      <div class="text-center mb-8">
        <div class="w-16 h-16 rounded-2xl btn-pink flex items-center justify-center mx-auto mb-4">
          <i class="ri-whatsapp-line text-white text-3xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Welcome Back</h1>
        <p class="text-sm text-gray-500 mt-1">Sign in to your ParroByte CRM account</p>
      </div>

      <% if (error && error.length > 0) { %>
        <div class="alert alert-error mb-4 bg-red-50 text-red-700 border border-red-200 text-sm">
          <i class="ri-error-warning-line"></i> <%= error %>
        </div>
      <% } %>
      <% if (success && success.length > 0) { %>
        <div class="alert alert-success mb-4 bg-emerald-50 text-emerald-700 border border-emerald-200 text-sm">
          <i class="ri-checkbox-circle-line"></i> <%= success %>
        </div>
      <% } %>

      <form action="/auth/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
          <div class="relative">
            <i class="ri-mail-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="email" name="email" required 
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="you@example.com">
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <label class="block text-sm font-medium text-gray-700">Password</label>
            <a href="/auth/forgot-password" class="text-xs text-pink-600 hover:underline">Forgot Password?</a>
          </div>
          <div class="relative">
            <i class="ri-lock-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="password" name="password" required minlength="6" autocomplete="current-password"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="Min 6 characters">
          </div>
        </div>
        <button type="submit" class="w-full py-3.5 text-white font-semibold rounded-xl btn-pink shadow-lg shadow-pink-200 hover:shadow-xl transition-all flex items-center justify-center gap-2">
          <i class="ri-login-circle-line"></i> Sign In
        </button>
      </form>

      <div class="mt-4 bg-blue-50 rounded-xl p-3 text-xs text-blue-700">
        <i class="ri-information-line"></i> <strong>Security:</strong> Only one login session is allowed per account. Logging in from another device will automatically log you out here.
      </div>

      <div class="mt-4 text-center">
        <p class="text-sm text-gray-600">Don't have an account? <a href="/auth/register" class="text-pink-600 font-semibold hover:underline">Register</a></p>
        <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-pink-600 mt-3"><i class="ri-arrow-left-line"></i> Back to Home</a>
      </div>
    </div>
  </div>
</body>
</html>
