<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Set a new password for your ParroByte CRM account.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <link rel="stylesheet" href="/css/app.css">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.1.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 50%, #fbcfe8 100%); min-height: 100vh; }
    .btn-pink { background: linear-gradient(135deg, #ec4899 0%, #f472b6 100%); }
    .btn-pink:hover { background: linear-gradient(135deg, #db2777 0%, #ec4899 100%); }
  </style>
</head>
<body class="flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-3xl shadow-xl shadow-pink-100 border border-pink-100 p-8">
      <div class="text-center mb-8">
        <div class="w-16 h-16 rounded-2xl btn-pink flex items-center justify-center mx-auto mb-4">
          <i class="ri-shield-keyhole-line text-white text-3xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Reset Password</h1>
        <p class="text-sm text-gray-500 mt-1">Enter the code sent to your email and set a new password</p>
      </div>

      <% if (error && error.length > 0) { %>
        <div class="alert alert-error mb-4 bg-red-50 text-red-700 border border-red-200 text-sm">
          <i class="ri-error-warning-line"></i> <%= error %>
        </div>
      <% } %>
      <% if (success && success.length > 0) { %>
        <div class="alert alert-success mb-4 bg-emerald-50 text-emerald-700 border border-emerald-200 text-sm">
          <i class="ri-checkbox-circle-line"></i> <%= success %>
        </div>
      <% } %>

      <form action="/auth/reset-password" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
          <div class="relative">
            <i class="ri-mail-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="email" name="email" value="<%= email || '' %>" required 
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="you@example.com">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Reset Code</label>
          <div class="relative">
            <i class="ri-shield-check-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="text" name="code" required maxlength="6" pattern="[0-9]{6}" 
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="6-digit code">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
          <div class="relative">
            <i class="ri-lock-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="password" name="password" required minlength="6" autocomplete="new-password"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="Min 6 characters">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
          <div class="relative">
            <i class="ri-lock-password-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="password" name="confirmPassword" required minlength="6" autocomplete="new-password"
              class="w-full pl-10 pr-4 py-3 rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all text-sm"
              placeholder="Repeat password">
          </div>
        </div>
        <button type="submit" class="w-full py-3.5 text-white font-semibold rounded-xl btn-pink shadow-lg shadow-pink-200 hover:shadow-xl transition-all flex items-center justify-center gap-2">
          <i class="ri-check-line"></i> Reset Password
        </button>
      </form>

      <div class="mt-4 text-center">
        <p class="text-sm text-gray-600">Didn't get a code? <a href="/auth/forgot-password" class="text-pink-600 font-semibold hover:underline">Resend</a></p>
      </div>
    </div>
  </div>
</body>
</html>
