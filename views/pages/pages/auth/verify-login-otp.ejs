<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Verify your login with OTP for ParroByte CRM.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <link rel="stylesheet" href="/css/app.css">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.1.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>body{font-family:'Inter',sans-serif;}</style>
</head>
<body class="min-h-screen gradient-bg flex items-center justify-center p-4" style="background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 50%, #fbcfe8 100%);">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <!-- Logo -->
      <div class="text-center mb-6">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-pink-400 to-pink-600 flex items-center justify-center mx-auto mb-4 shadow-lg">
          <i class="ri-shield-check-line text-white text-3xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Verify Login</h1>
        <p class="text-sm text-gray-500 mt-1">Secure login with email OTP</p>
      </div>

      <!-- Email info -->
      <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 mb-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
            <i class="ri-mail-line text-blue-600"></i>
          </div>
          <div>
            <p class="text-sm text-blue-700 font-medium">OTP sent to</p>
            <p class="text-sm text-blue-600 font-semibold"><%= email || 'your email address' %></p>
          </div>
        </div>
      </div>

      <% if (typeof success !== 'undefined' && success.length) { %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm mb-4"><%= success %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error.length) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-4"><%= error %></div>
      <% } %>

      <!-- OTP Form -->
      <form action="/auth/verify-login-otp" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Enter 6-digit OTP</label>
          <input type="text" name="otp" maxlength="6" required inputmode="numeric" pattern="[0-9]{6}"
            class="w-full px-4 py-3 text-center text-2xl font-bold tracking-[0.5em] rounded-xl border border-pink-200 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none transition-all"
            placeholder="000000" autofocus>
        </div>
        <button type="submit" class="w-full py-3 bg-gradient-to-r from-pink-500 to-pink-600 text-white font-semibold rounded-xl hover:shadow-lg transition-all flex items-center justify-center gap-2">
          <i class="ri-login-circle-line"></i> Complete Login
        </button>
      </form>

      <!-- Resend / Back -->
      <div class="mt-6 flex items-center justify-between">
        <form action="/auth/resend-login-otp" method="POST" data-no-loading>
          <button type="submit" class="text-sm text-pink-600 hover:text-pink-700 font-medium flex items-center gap-1">
            <i class="ri-refresh-line"></i> Resend OTP
          </button>
        </form>
        <a href="/auth/login" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
          <i class="ri-arrow-left-line"></i> Back to Login
        </a>
      </div>

      <!-- Timer -->
      <p class="text-center text-xs text-gray-400 mt-4">OTP expires in 10 minutes</p>
    </div>
  </div>
</body>
</html>
