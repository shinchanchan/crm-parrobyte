<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h2 class="text-xl font-bold text-gray-900">Lead URLs</h2>
    <p class="text-sm text-gray-500">Create API endpoints to capture leads from external websites</p>
  </div>
  <button onclick="openBuilder()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2 w-fit">
    <i class="ri-add-line"></i> Create Lead URL
  </button>
</div>

<!-- Lead URLs Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
  <% leadUrls.forEach(function(lu) { %>
    <% let labels = []; try { labels = JSON.parse(lu.labels || '[]'); } catch(e) {} %>
    <div class="bg-white rounded-2xl border border-pink-100 overflow-hidden card-hover">
      <div class="p-5">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg" style="background: #ec489920; color: #ec4899">
              <i class="ri-link"></i>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 text-sm"><%= lu.title %></h3>
              <p class="text-xs text-gray-400"><%= lu.submitCount || 0 %> submissions</p>
            </div>
          </div>
          <span class="text-xs px-2 py-1 rounded-full <%= lu.isActive ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-500' %>"><%= lu.isActive ? 'Active' : 'Inactive' %></span>
        </div>

        <!-- Labels -->
        <div class="flex flex-wrap gap-1.5 mb-3">
          <% labels.forEach(function(lbl) { %>
            <span class="text-xs bg-pink-50 text-pink-600 px-2 py-1 rounded-lg"><%= lbl %></span>
          <% }); %>
        </div>

        <!-- API Endpoint -->
        <div class="bg-gray-50 rounded-xl p-3 mb-3">
          <p class="text-xs text-gray-500 mb-1 font-medium">API Endpoint</p>
          <div class="flex items-center gap-2">
            <code class="text-xs text-gray-700 flex-1 truncate"><%= baseUrl %>/api/lead-url/<%= lu.slug %></code>
            <button onclick="navigator.clipboard.writeText('<%= baseUrl %>/api/lead-url/<%= lu.slug %>')" class="text-pink-600 hover:text-pink-700 transition-colors" title="Copy endpoint">
              <i class="ri-file-copy-line"></i>
            </button>
          </div>
          <p class="text-xs text-gray-500 mt-1 font-medium">API Key</p>
          <div class="flex items-center gap-2">
            <code class="text-xs text-gray-700 flex-1 truncate"><%= lu.apiKey %></code>
            <button onclick="navigator.clipboard.writeText('<%= lu.apiKey %>')" class="text-pink-600 hover:text-pink-700 transition-colors" title="Copy API key">
              <i class="ri-file-copy-line"></i>
            </button>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex gap-2 pt-3 border-t border-gray-100/60">
          <button onclick='showCode(<%= JSON.stringify(lu) %>)' class="flex-1 py-2 text-xs font-medium text-green-600 bg-green-50/80 rounded-lg hover:bg-green-100 transition-colors flex items-center justify-center gap-1">
            <i class="ri-code-line"></i> Code
          </button>
          <button onclick='editLeadUrl(<%= JSON.stringify(lu) %>)' class="flex-1 py-2 text-xs font-medium text-blue-600 bg-blue-50/80 rounded-lg hover:bg-blue-100 transition-colors flex items-center justify-center gap-1">
            <i class="ri-edit-line"></i> Edit
          </button>
          <form action="/lead-urls/delete/<%= lu.id %>" method="POST" class="flex-1" onsubmit="return confirm('Delete this lead URL?')">
            <button type="submit" class="w-full py-2 text-xs font-medium text-red-600 bg-red-50/80 rounded-lg hover:bg-red-100 transition-colors flex items-center justify-center gap-1">
              <i class="ri-delete-bin-line"></i> Delete
            </button>
          </form>
        </div>
      </div>
    </div>
  <% }); %>
</div>

<% if (!leadUrls || leadUrls.length === 0) { %>
  <div class="bg-white rounded-2xl border border-pink-100 p-12 text-center mt-4">
    <div class="w-20 h-20 rounded-full bg-pink-50/80 flex items-center justify-center mx-auto mb-4">
      <i class="ri-link text-4xl text-pink-300"></i>
    </div>
    <h3 class="font-semibold text-gray-900 mb-2">No Lead URLs Yet</h3>
    <p class="text-sm text-gray-500 mb-6">Create your first lead capture API endpoint</p>
    <button onclick="openBuilder()" class="px-6 py-2.5 btn-pink text-white text-sm font-medium rounded-xl inline-flex items-center gap-2">
      <i class="ri-add-line"></i> Create Lead URL
    </button>
  </div>
<% } %>

<!-- Builder Modal -->
<dialog id="builderModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-lg">
    <h3 class="font-bold text-lg text-gray-900 mb-4" id="modalTitle">Create Lead URL</h3>
    <form action="/lead-urls/create" method="POST" id="builderForm" data-loading-text="Saving...">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Title *</label>
        <input type="text" name="title" id="luTitle" required placeholder="e.g. Website Lead Form"
          class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Form Labels *</label>
        <p class="text-xs text-gray-400 mb-2">Add the field names your external form will send (e.g. name, email, phone, company)</p>
        <div id="labelsContainer" class="space-y-2 mb-2"></div>
        <button type="button" onclick="addLabel()" class="text-xs px-3 py-1.5 rounded-lg border border-dashed border-gray-300 text-gray-500 hover:border-pink-300 hover:text-pink-500 transition-all flex items-center gap-1">
          <i class="ri-add-line"></i> Add Label
        </button>
        <input type="hidden" name="labelsJson" id="labelsJson">
      </div>

      <div class="flex gap-3 justify-end pt-3 border-t border-gray-100/60">
        <button type="button" onclick="document.getElementById('builderModal').close()" class="px-5 py-2.5 text-sm text-gray-600 hover:bg-gray-100 rounded-xl transition-colors">Cancel</button>
        <button type="submit" onclick="return buildJson()" class="px-6 py-2.5 btn-pink text-white text-sm font-medium rounded-xl flex items-center gap-2">
          <i class="ri-save-line"></i> <span id="saveLabel">Create</span>
        </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- Integration Code Modal -->
<dialog id="codeModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-3xl w-full">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-bold text-lg text-gray-900">Integration Code</h3>
      <button onclick="document.getElementById('codeModal').close()" class="w-8 h-8 rounded-full hover:bg-gray-100 flex items-center justify-center">
        <i class="ri-close-line text-gray-500"></i>
      </button>
    </div>
    <p class="text-sm text-gray-500 mb-3">Copy this HTML + JavaScript code and paste it into your website. Replace the input fields to match your form labels.</p>
    <div class="bg-gray-900 rounded-xl p-4 overflow-x-auto mb-4">
      <pre class="text-xs text-green-400 font-mono whitespace-pre" id="codeBlock"></pre>
    </div>
    <div class="flex gap-3 justify-end">
      <button type="button" onclick="document.getElementById('codeModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Close</button>
      <button onclick="copyCode()" class="px-5 py-2 btn-pink text-white text-sm font-medium rounded-lg flex items-center gap-2">
        <i class="ri-file-copy-line"></i> Copy Code
      </button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
let labelCount = 0;
let editId = null;

function addLabel(value) {
  if (labelCount >= 20) return;
  const container = document.getElementById('labelsContainer');
  const row = document.createElement('div');
  row.className = 'flex items-center gap-2';
  row.innerHTML = `
    <input type="text" placeholder="Field label (e.g. company)" class="label-input flex-1 px-3 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm" value="${value || ''}" required>
    <button type="button" onclick="removeLabel(this)" class="p-2 text-red-400 hover:text-red-600"><i class="ri-delete-bin-line"></i></button>
  `;
  container.appendChild(row);
  labelCount++;
}

function removeLabel(btn) {
  btn.closest('div').remove();
  labelCount--;
}

function buildJson() {
  const labels = [];
  document.querySelectorAll('.label-input').forEach(function(inp) {
    if (inp.value.trim()) labels.push(inp.value.trim());
  });
  if (labels.length === 0) {
    alert('Add at least one label');
    return false;
  }
  document.getElementById('labelsJson').value = JSON.stringify(labels);
  return true;
}

function openBuilder() {
  editId = null;
  document.getElementById('builderForm').action = '/lead-urls/create';
  document.getElementById('modalTitle').textContent = 'Create Lead URL';
  document.getElementById('saveLabel').textContent = 'Create';
  document.getElementById('luTitle').value = '';
  document.getElementById('labelsContainer').innerHTML = '';
  labelCount = 0;
  addLabel('name');
  addLabel('email');
  addLabel('phone');
  document.getElementById('builderModal').showModal();
}

function editLeadUrl(data) {
  editId = data.id;
  document.getElementById('builderForm').action = '/lead-urls/update/' + data.id;
  document.getElementById('modalTitle').textContent = 'Edit Lead URL';
  document.getElementById('saveLabel').textContent = 'Update';
  document.getElementById('luTitle').value = data.title || '';
  document.getElementById('labelsContainer').innerHTML = '';
  labelCount = 0;
  let labels = [];
  try { labels = JSON.parse(data.labels || '[]'); } catch(e) {}
  labels.forEach(function(l) { addLabel(l); });
  if (labels.length === 0) { addLabel('name'); addLabel('email'); addLabel('phone'); }
  document.getElementById('builderModal').showModal();
}

function showCode(data) {
  let labels = [];
  try { labels = JSON.parse(data.labels || '[]'); } catch(e) {}
  const endpoint = '<%= baseUrl %>/api/lead-url/' + data.slug;
  const apiKey = data.apiKey;

  let inputsHtml = labels.map(function(lbl) {
    const key = lbl.toLowerCase().replace(/\s+/g, '_');
    return `  <div>\n    <label>${lbl}</label>\n    <input type="text" name="${key}" id="${key}" required>\n  </div>`;
  }).join('\n');

  const code = `<!DOCTYPE html>
<html>
<head>
  <title>Lead Form</title>
  <style>
    body { font-family: sans-serif; max-width: 400px; margin: 40px auto; }
    label { display: block; margin: 10px 0 4px; font-weight: 600; }
    input, button { width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd; }
    button { background: #ec4899; color: #fff; border: none; cursor: pointer; margin-top: 16px; }
    button:hover { opacity: 0.9; }
    #status { margin-top: 12px; font-size: 14px; }
  </style>
</head>
<body>
  <h2>Contact Us</h2>
  <form id="leadForm">
${inputsHtml}
    <button type="submit">Submit</button>
  </form>
  <div id="status"></div>

  <script>
    document.getElementById('leadForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const status = document.getElementById('status');
      status.textContent = 'Sending...';

      const formData = new FormData(this);
      const payload = {};
      formData.forEach((v, k) => payload[k] = v);

      try {
        const res = await fetch('${endpoint}', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-API-Key': '${apiKey}'
          },
          body: JSON.stringify(payload)
        });

        const data = await res.json();
        if (data.success) {
          status.style.color = 'green';
          status.textContent = '✅ Submitted successfully! Code: ' + data.code;
          this.reset();
        } else {
          status.style.color = 'red';
          status.textContent = '❌ Error: ' + (data.error || 'Unknown error') + ' (Code: ' + data.code + ')';
        }
      } catch (err) {
        status.style.color = 'red';
        status.textContent = '❌ Network error: ' + err.message;
      }
    });
  <\/script>
</body>
</html>`;

  document.getElementById('codeBlock').textContent = code;
  document.getElementById('codeModal').showModal();
}

function copyCode() {
  const text = document.getElementById('codeBlock').textContent;
  navigator.clipboard.writeText(text).then(function() {
    alert('Integration code copied to clipboard!');
  });
}
</script>
