<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h2 class="text-xl font-bold text-gray-900">Scheduled Messages</h2>
    <p class="text-sm text-gray-500">Plan and schedule your message campaigns</p>
  </div>
  <button onclick="document.getElementById('scheduleModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2 w-fit">
    <i class="ri-calendar-schedule-line"></i> Schedule Message
  </button>
</div>

<%
const scheduleColumns = [
  {
    key: 'content',
    label: 'Content',
    sortable: true,
    searchable: true,
    format: (row) => `<span class="text-gray-600 max-w-xs truncate block">${row.content}</span>`
  },
  {
    key: 'type',
    label: 'Type',
    sortable: true,
    searchable: true,
    format: (row) => `<span class="text-xs capitalize bg-gray-100 text-gray-600 px-2 py-1 rounded-full">${row.type}</span>`
  },
  {
    key: 'scheduleTime',
    label: 'Schedule',
    sortable: true,
    searchable: true,
    format: (row) => `<span class="text-xs text-gray-500">${new Date(row.scheduleTime).toLocaleString()}</span>`
  },
  {
    key: 'status',
    label: 'Status',
    sortable: true,
    searchable: true,
    format: (row) => {
      const colors = { completed: 'bg-green-100 text-green-700', pending: 'bg-yellow-100 text-yellow-700', cancelled: 'bg-gray-100 text-gray-600', processing: 'bg-blue-100 text-blue-700' };
      const cls = colors[row.status] || colors.pending;
      return `<span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full ${cls}">${row.status}</span>`;
    }
  },
  {
    key: 'repeatPattern',
    label: 'Repeat',
    sortable: true,
    searchable: true,
    format: (row) => `<span class="text-xs text-gray-500">${row.repeatPattern || 'Once'}</span>`
  },
  {
    key: 'actions',
    label: 'Actions',
    sortable: false,
    searchable: false,
    format: (row) => `
      <div class="flex items-center justify-end gap-1">
        <button type="button"
          class="edit-schedule-btn p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
          data-id="${row.id}"
          data-sessionid="${row.sessionId}"
          data-templateid="${row.templateId || ''}"
          data-contactids="${(row.contactIds || '[]').replace(/"/g, '&quot;')}"
          data-content="${(row.content || '').replace(/"/g, '&quot;').replace(/\n/g, '&#10;')}"
          data-type="${row.type}"
          data-scheduletime="${row.scheduleTime ? new Date(row.scheduleTime).toISOString().slice(0,16) : ''}"
          data-repeat="${row.repeatPattern || ''}"
        >
          <i class="ri-edit-line"></i>
        </button>
        ${row.status === 'pending' ? `
          <form action="/schedule/cancel/${row.id}" method="POST" class="inline" onsubmit="return confirm('Cancel this scheduled message?')">
            <button type="submit" class="p-2 text-amber-600 hover:bg-amber-50 rounded-lg transition-colors" title="Cancel">
              <i class="ri-close-circle-line"></i>
            </button>
          </form>
        ` : ''}
        <form action="/schedule/delete/${row.id}" method="POST" class="inline" onsubmit="return confirm('Delete this scheduled message permanently?')">
          <button type="submit" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
            <i class="ri-delete-bin-line"></i>
          </button>
        </form>
      </div>
    `
  },
];
%>
<%- include('../../partials/paginated-table', {
  data: schedules,
  columns: scheduleColumns,
  pagination,
  columnFilters,
  sortCol,
  sortDir,
  actionPath: '/schedule',
}) %>

<dialog id="scheduleModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-2xl">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Schedule Message</h3>
    <form action="/schedule/create" method="POST" data-loading-text="Scheduling message..." id="scheduleForm">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Session *</label>
          <% const connectedSessions = (typeof availableSessions !== 'undefined' ? availableSessions : []).filter(s => s.realtimeStatus === 'connected' || s.status === 'connected'); %>
          <% if (connectedSessions.length > 0) { %>
            <select name="sessionId" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
              <option value="">Select session</option>
              <% connectedSessions.forEach(s => { %>
                <option value="<%= s.id %>"><%= s.label %></option>
              <% }); %>
            </select>
          <% } else { %>
            <div class="w-full px-4 py-2 rounded-xl border border-red-200 bg-red-50 text-sm text-red-700">
              <i class="ri-error-warning-line mr-1"></i> No connected session available. Create or reconnect a session first.
            </div>
          <% } %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Template (optional)</label>
          <select name="templateId" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white" onchange="fillTemplate(this)">
            <option value="">No template</option>
            <% templates.forEach(t => { %>
              <option value="<%= t.id %>" data-content="<%= (t.content || '').replace(/"/g, '&quot;') %>" data-type="<%= t.type %>" data-mediaurl="<%= t.mediaUrl || '' %>" data-variables="<%= (t.variables || '').replace(/"/g, '&quot;') %>"><%= t.name %> <%= t.type !== 'text' ? '(' + t.type + ')' : '' %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <!-- Contact Selector -->
      <div class="mt-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Contacts *</label>
        <div class="border border-pink-200 rounded-xl p-3 bg-white">
          <div class="flex items-center gap-2 mb-2">
            <input type="text" id="contactSearch" placeholder="Search contacts..." class="flex-1 px-3 py-1.5 rounded-lg border border-gray-200 text-sm outline-none focus:border-pink-500" oninput="filterContacts()">
            <button type="button" onclick="selectAllContacts()" class="px-3 py-1.5 text-xs bg-pink-50 text-pink-600 rounded-lg hover:bg-pink-100">Select All</button>
            <button type="button" onclick="deselectAllContacts()" class="px-3 py-1.5 text-xs bg-gray-50 text-gray-600 rounded-lg hover:bg-gray-100">Clear</button>
          </div>
          <div class="max-h-48 overflow-y-auto space-y-1" id="contactList">
            <% contacts.forEach(c => { %>
              <label class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-pink-50 cursor-pointer transition-colors contact-row" data-name="<%= c.name.toLowerCase() %> <%= c.phone %>">
                <input type="checkbox" name="contactIds" value="<%= c.id %>" class="contact-checkbox rounded border-pink-300 text-pink-500 focus:ring-pink-200">
                <span class="text-sm text-gray-700"><%= c.name %> <span class="text-xs text-gray-400">(<%= c.phone %>)</span></span>
              </label>
            <% }); %>
          </div>
          <p class="text-xs text-gray-400 mt-1">Selected: <span id="selectedCount">0</span> contacts</p>
        </div>
      </div>

      <input type="hidden" name="type" id="scheduleMsgType" value="text">
      <input type="hidden" name="interactiveData" id="scheduleInteractiveData">

      <div class="mt-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Content *</label>
        <textarea name="content" id="scheduleContent" rows="3" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></textarea>
      </div>

      <!-- Poll Preview Panel -->
      <div id="schedulePollPanel" class="hidden mt-3 bg-pink-50 rounded-xl p-3 border border-pink-100">
        <label class="block text-xs font-medium text-gray-700 mb-1">Poll Question</label>
        <input type="text" id="schedulePollQuestion" readonly class="w-full px-3 py-2 rounded-lg border border-pink-200 bg-white text-sm">
        <label class="block text-xs font-medium text-gray-700 mb-1 mt-2">Options</label>
        <textarea id="schedulePollOptions" readonly rows="3" class="w-full px-3 py-2 rounded-lg border border-pink-200 bg-white text-sm"></textarea>
        <p class="text-xs text-pink-600 mt-1"><i class="ri-information-line"></i> Poll will be sent with these options at scheduled time.</p>
      </div>
      <div class="grid grid-cols-2 gap-4 mt-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Schedule Time *</label>
          <input type="datetime-local" name="scheduleTime" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
          <input type="hidden" name="timezoneOffset" id="scheduleTzOffset" value="">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Repeat</label>
          <select name="repeatPattern" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="">No repeat</option>
            <option value="daily">Daily</option>
            <option value="weekly">Weekly</option>
            <option value="monthly">Monthly</option>
          </select>
        </div>
      </div>
      <div class="flex gap-3 justify-end mt-4">
        <button type="button" onclick="document.getElementById('scheduleModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-calendar-check-line"></i> Schedule</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- Edit Schedule Modal -->
<dialog id="editScheduleModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-2xl">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Edit Scheduled Message</h3>
    <form action="" method="POST" data-loading-text="Updating..." id="editScheduleForm">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Session *</label>
          <% if (connectedSessions.length > 0) { %>
            <select name="sessionId" id="editScheduleSessionId" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
              <option value="">Select session</option>
              <% connectedSessions.forEach(s => { %>
                <option value="<%= s.id %>"><%= s.label %></option>
              <% }); %>
            </select>
          <% } else { %>
            <div class="w-full px-4 py-2 rounded-xl border border-red-200 bg-red-50 text-sm text-red-700">
              <i class="ri-error-warning-line mr-1"></i> No connected session available.
            </div>
          <% } %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Template (optional)</label>
          <select name="templateId" id="editScheduleTemplateId" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white" onchange="fillEditTemplate(this)">
            <option value="">No template</option>
            <% templates.forEach(t => { %>
              <option value="<%= t.id %>" data-content="<%= (t.content || '').replace(/"/g, '&quot;') %>" data-type="<%= t.type %>" data-mediaurl="<%= t.mediaUrl || '' %>" data-variables="<%= (t.variables || '').replace(/"/g, '&quot;') %>"><%= t.name %> <%= t.type !== 'text' ? '(' + t.type + ')' : '' %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <!-- Contact Selector -->
      <div class="mt-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Contacts *</label>
        <div class="border border-pink-200 rounded-xl p-3 bg-white">
          <div class="flex items-center gap-2 mb-2">
            <input type="text" id="editContactSearch" placeholder="Search contacts..." class="flex-1 px-3 py-1.5 rounded-lg border border-gray-200 text-sm outline-none focus:border-pink-500" oninput="filterEditContacts()">
            <button type="button" onclick="selectAllEditContacts()" class="px-3 py-1.5 text-xs bg-pink-50 text-pink-600 rounded-lg hover:bg-pink-100">Select All</button>
            <button type="button" onclick="deselectAllEditContacts()" class="px-3 py-1.5 text-xs bg-gray-50 text-gray-600 rounded-lg hover:bg-gray-100">Clear</button>
          </div>
          <div class="max-h-48 overflow-y-auto space-y-1" id="editContactList">
            <% contacts.forEach(c => { %>
              <label class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-pink-50 cursor-pointer transition-colors edit-contact-row" data-name="<%= c.name.toLowerCase() %> <%= c.phone %>">
                <input type="checkbox" name="contactIds" value="<%= c.id %>" class="edit-contact-checkbox rounded border-pink-300 text-pink-500 focus:ring-pink-200">
                <span class="text-sm text-gray-700"><%= c.name %> <span class="text-xs text-gray-400">(<%= c.phone %>)</span></span>
              </label>
            <% }); %>
          </div>
          <p class="text-xs text-gray-400 mt-1">Selected: <span id="editSelectedCount">0</span> contacts</p>
        </div>
      </div>

      <input type="hidden" name="type" id="editScheduleMsgType" value="text">
      <input type="hidden" name="interactiveData" id="editScheduleInteractiveData">

      <div class="mt-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Content *</label>
        <textarea name="content" id="editScheduleContent" rows="3" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm"></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4 mt-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Schedule Time *</label>
          <input type="datetime-local" name="scheduleTime" id="editScheduleTime" required class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
          <input type="hidden" name="timezoneOffset" id="editScheduleTzOffset" value="">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Repeat</label>
          <select name="repeatPattern" id="editScheduleRepeat" class="w-full px-4 py-2 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
            <option value="">No repeat</option>
            <option value="daily">Daily</option>
            <option value="weekly">Weekly</option>
            <option value="monthly">Monthly</option>
          </select>
        </div>
      </div>
      <div class="flex gap-3 justify-end mt-4">
        <button type="button" onclick="document.getElementById('editScheduleModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg"><i class="ri-save-line"></i> Update</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
// Set browser timezone offset on form open
document.getElementById('scheduleModal').addEventListener('show', function() {
  document.getElementById('scheduleTzOffset').value = new Date().getTimezoneOffset();
});

function fillTemplate(select) {
  const option = select.options[select.selectedIndex];
  const pollPanel = document.getElementById('schedulePollPanel');
  const contentEl = document.getElementById('scheduleContent');
  const typeEl = document.getElementById('scheduleMsgType');
  const intDataEl = document.getElementById('scheduleInteractiveData');

  if (!option.value) {
    if (contentEl) contentEl.value = '';
    if (typeEl) typeEl.value = 'text';
    if (intDataEl) intDataEl.value = '';
    if (pollPanel) pollPanel.classList.add('hidden');
    return;
  }

  const decodeHtml = (str) => (str || '').replace(/&quot;/g, '"').replace(/&amp;/g, '&');
  const type = option.dataset.type || 'text';

  if (type === 'poll') {
    if (contentEl) contentEl.value = decodeHtml(option.dataset.content) || '';
    if (typeEl) typeEl.value = 'poll';
    try {
      const vars = JSON.parse(decodeHtml(option.dataset.variables) || '{}');
      if (vars.pollOptions && vars.pollOptions.length >= 2) {
        const qEl = document.getElementById('schedulePollQuestion');
        const oEl = document.getElementById('schedulePollOptions');
        if (qEl) qEl.value = decodeHtml(option.dataset.content) || '';
        if (oEl) oEl.value = vars.pollOptions.join('\n');
        if (intDataEl) {
          intDataEl.value = JSON.stringify({
            options: vars.pollOptions,
            allowMultipleAnswers: vars.allowMultipleAnswers === true,
          });
        }
        if (pollPanel) pollPanel.classList.remove('hidden');
      }
    } catch (e) {}
  } else {
    if (contentEl) contentEl.value = decodeHtml(option.dataset.content) || '';
    if (typeEl) typeEl.value = type;
    if (intDataEl) intDataEl.value = '';
    if (pollPanel) pollPanel.classList.add('hidden');
  }
}

function filterContacts() {
  const query = document.getElementById('contactSearch').value.toLowerCase();
  document.querySelectorAll('.contact-row').forEach(row => {
    const name = row.dataset.name;
    row.style.display = name.includes(query) ? 'flex' : 'none';
  });
}

function selectAllContacts() {
  document.querySelectorAll('.contact-row:not([style*="none"]) .contact-checkbox').forEach(cb => cb.checked = true);
  updateSelectedCount();
}

function deselectAllContacts() {
  document.querySelectorAll('.contact-checkbox').forEach(cb => cb.checked = false);
  updateSelectedCount();
}

function updateSelectedCount() {
  const count = document.querySelectorAll('.contact-checkbox:checked').length;
  document.getElementById('selectedCount').textContent = count;
}

document.querySelectorAll('.contact-checkbox').forEach(cb => {
  cb.addEventListener('change', updateSelectedCount);
});

document.getElementById('scheduleForm').addEventListener('submit', function(e) {
  const checked = document.querySelectorAll('.contact-checkbox:checked');
  if (checked.length === 0) {
    e.preventDefault();
    alert('Please select at least one contact');
    return false;
  }
});

// ===== EDIT SCHEDULE FUNCTIONS =====

document.querySelector('.paginated-table, table, [class*="table"]')?.closest('body')?.addEventListener('click', function(e) {
  const btn = e.target.closest('.edit-schedule-btn');
  if (!btn) return;
  openEditSchedule(btn);
});

function openEditSchedule(btn) {
  const id = btn.dataset.id;
  const sessionId = btn.dataset.sessionid;
  const templateId = btn.dataset.templateid;

  // Robust contactIds parsing — handle string, number, array, or invalid JSON
  let contactIds = [];
  try {
    const raw = btn.dataset.contactids || '[]';
    const parsed = JSON.parse(raw);
    if (Array.isArray(parsed)) {
      contactIds = parsed;
    } else if (parsed !== null && parsed !== undefined) {
      contactIds = [parsed];
    }
  } catch (e) {
    // If JSON.parse fails, try treating as comma-separated string
    const raw = btn.dataset.contactids || '';
    contactIds = raw.split(',').map(s => parseInt(s.trim(), 10)).filter(n => !isNaN(n));
  }

  const content = btn.dataset.content || '';
  const type = btn.dataset.type || 'text';
  const scheduleTime = btn.dataset.scheduletime || '';
  const repeat = btn.dataset.repeat || '';

  document.getElementById('editScheduleForm').action = '/schedule/update/' + id;

  const sessionSel = document.getElementById('editScheduleSessionId');
  if (sessionSel) sessionSel.value = sessionId;

  const templateSel = document.getElementById('editScheduleTemplateId');
  if (templateSel) templateSel.value = templateId;

  document.getElementById('editScheduleContent').value = content;
  document.getElementById('editScheduleMsgType').value = type;
  document.getElementById('editScheduleTime').value = scheduleTime;
  document.getElementById('editScheduleRepeat').value = repeat;
  document.getElementById('editScheduleTzOffset').value = new Date().getTimezoneOffset();

  // Check contact boxes
  document.querySelectorAll('.edit-contact-checkbox').forEach(cb => cb.checked = false);
  contactIds.forEach(cid => {
    const cb = document.querySelector('.edit-contact-checkbox[value="' + cid + '"]');
    if (cb) cb.checked = true;
  });
  updateEditSelectedCount();

  document.getElementById('editScheduleModal').showModal();
}

function fillEditTemplate(select) {
  const option = select.options[select.selectedIndex];
  const contentEl = document.getElementById('editScheduleContent');
  const typeEl = document.getElementById('editScheduleMsgType');
  const intDataEl = document.getElementById('editScheduleInteractiveData');

  if (!option.value) return;

  const decodeHtml = (str) => (str || '').replace(/&quot;/g, '"').replace(/&amp;/g, '&');
  const type = option.dataset.type || 'text';

  if (contentEl) contentEl.value = decodeHtml(option.dataset.content) || '';
  if (typeEl) typeEl.value = type;
  if (intDataEl) intDataEl.value = '';
}

function filterEditContacts() {
  const query = document.getElementById('editContactSearch').value.toLowerCase();
  document.querySelectorAll('.edit-contact-row').forEach(row => {
    const name = row.dataset.name;
    row.style.display = name.includes(query) ? 'flex' : 'none';
  });
}

function selectAllEditContacts() {
  document.querySelectorAll('.edit-contact-row:not([style*="none"]) .edit-contact-checkbox').forEach(cb => cb.checked = true);
  updateEditSelectedCount();
}

function deselectAllEditContacts() {
  document.querySelectorAll('.edit-contact-checkbox').forEach(cb => cb.checked = false);
  updateEditSelectedCount();
}

function updateEditSelectedCount() {
  const count = document.querySelectorAll('.edit-contact-checkbox:checked').length;
  document.getElementById('editSelectedCount').textContent = count;
}

document.querySelectorAll('.edit-contact-checkbox').forEach(cb => {
  cb.addEventListener('change', updateEditSelectedCount);
});

document.getElementById('editScheduleForm').addEventListener('submit', function(e) {
  const checked = document.querySelectorAll('.edit-contact-checkbox:checked');
  if (checked.length === 0) {
    e.preventDefault();
    alert('Please select at least one contact');
    return false;
  }
});
</script>
