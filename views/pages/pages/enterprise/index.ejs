              <div>
                <label class="block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wide">Phone Number *</label>
                <div class="flex gap-2">
                  <select name="countryCode" class="w-24 px-3 py-3 rounded-xl glass-input text-sm bg-transparent">
                    <option value="+91" class="bg-gray-900">+91</option>
                    <option value="+1" class="bg-gray-900">+1</option>
                    <option value="+44" class="bg-gray-900">+44</option>
                    <option value="+971" class="bg-gray-900">+971</option>
                    <option value="+65" class="bg-gray-900">+65</option>
                    <option value="+61" class="bg-gray-900">+61</option>
                  </select>
                  <input type="tel" name="phone" required class="flex-1 px-4 py-3 rounded-xl glass-input text-sm" placeholder="9876543210">
