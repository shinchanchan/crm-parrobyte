                    <option value="51-200" class="bg-gray-900">51-200</option>
                    <option value="201-500" class="bg-gray-900">201-500</option>
                    <option value="501-1000" class="bg-gray-900">501-1000</option>
                    <option value="1000+" class="bg-gray-900">1000+</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wide">Business Type *</label>
                  <select name="businessType" required class="w-full px-4 py-3 rounded-xl glass-input text-sm bg-transparent">
                    <option value="" class="bg-gray-900">Select</option>
                    <option value="E-commerce" class="bg-gray-900">E-commerce</option>
                    <option value="Healthcare" class="bg-gray-900">Healthcare</option>
                    <option value="Education" class="bg-gray-900">Education</option>
                    <option value="Real Estate" class="bg-gray-900">Real Estate</option>
                    <option value="Finance" class="bg-gray-900">Finance</option>
                    <option value="Technology" class="bg-gray-900">Technology</option>
                    <option value="Manufacturing" class="bg-gray-900">Manufacturing</option>
