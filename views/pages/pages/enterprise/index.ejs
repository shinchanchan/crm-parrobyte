  <script>
  let enquiryId = null;

  // Form submission
  document.getElementById('enquiryForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btnText = document.getElementById('btnText');
    const btnLoader = document.getElementById('btnLoader');
    btnText.textContent = 'Sending...';
    btnLoader.classList.remove('hidden');

    const formData = new FormData(this);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/enterprise/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();

      if (result.success) {
        enquiryId = result.enquiryId;
        document.getElementById('otpEmail').textContent = data.email;
        document.getElementById('enquiryForm').classList.add('hidden');
        document.getElementById('otpSection').classList.remove('hidden');
        // Focus first OTP input
        document.querySelector('.otp-input[data-index="0"]').focus();
      } else {
        alert(result.error || 'Failed to submit');
      }
    } catch (err) {
      alert('Network error');
    }

    btnText.textContent = 'Send Enquiry';
    btnLoader.classList.add('hidden');
  });

  // OTP input handling
  function handleOtpInput(input, index) {
    input.value = input.value.replace(/[^0-9]/g, '');
    if (input.value && index < 5) {
      document.querySelector('.otp-input[data-index="' + (index + 1) + '"]').focus();
    }
  }
  function handleOtpKeydown(e, index) {
    if (e.key === 'Backspace' && !e.target.value && index > 0) {
      document.querySelector('.otp-input[data-index="' + (index - 1) + '"]').focus();
    }
  }

  function getOtpValue() {
    let otp = '';
    document.querySelectorAll('.otp-input').forEach(function(input) {
      otp += input.value;
    });
    return otp;
  }

  async function verifyOtp() {
    const otp = getOtpValue();
    if (otp.length !== 6) {
      showOtpMessage('Please enter all 6 digits', 'red');
      return;
    }

    document.getElementById('verifyBtnText').textContent = 'Verifying...';

    try {
      const res = await fetch('/enterprise/verify-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ enquiryId, otp }),
      });
      const result = await res.json();

      if (result.success) {
        document.getElementById('otpSection').classList.add('hidden');
        document.getElementById('successSection').classList.remove('hidden');
        document.getElementById('refId').textContent = 'ENT-' + String(enquiryId).padStart(4, '0');
      } else {
        showOtpMessage(result.error, 'red');
      }
    } catch (err) {
      showOtpMessage('Verification failed', 'red');
    }

    document.getElementById('verifyBtnText').textContent = 'Verify OTP';
  }

  async function resendOtp() {
    try {
      const res = await fetch('/enterprise/resend-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ enquiryId }),
      });
      const result = await res.json();
      showOtpMessage(result.message, 'green');
    } catch (err) {
      showOtpMessage('Failed to resend', 'red');
    }
  }

  function showOtpMessage(msg, color) {
    const el = document.getElementById('otpMessage');
    el.textContent = msg;
    el.className = 'text-center text-xs mt-2 ' + (color === 'red' ? 'text-red-400' : 'text-green-400');
    el.classList.remove('hidden');
  }
  </script>
</body>
</html>
