              </div>
              <div>
                <label class="block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wide">Requirements</label>
                <textarea name="requirements" rows="3" class="w-full px-4 py-3 rounded-xl glass-input text-sm resize-none" placeholder="Tell us about your requirements..."></textarea>
