          <!-- Enterprise Package -->
          <div class="glass-card rounded-2xl p-6 animate-in" style="animation-delay:0.2s">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg, #a78bfa, #8b5cf6)">
                  <i class="ri-building-4-fill text-white text-xl"></i>
