<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h2 class="text-xl font-bold text-gray-900">API Keys</h2>
    <p class="text-sm text-gray-500">Manage API keys for external integrations</p>
  </div>
  <button onclick="document.getElementById('createKeyModal').showModal()" class="px-5 py-2.5 btn-pink text-white text-sm font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2 w-fit">
    <i class="ri-add-line"></i> Generate Key
  </button>
</div>

<dialog id="createKeyModal" class="modal">
  <div class="modal-box bg-white rounded-2xl max-w-md">
    <h3 class="font-bold text-lg text-gray-900 mb-4">Create API Key</h3>
    <form action="/api-keys/create" method="POST" data-loading-text="Creating API key...">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Key Name *</label>
        <input type="text" name="keyName" required placeholder="e.g. Website Integration" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm">
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Default WhatsApp Session</label>
        <select name="sessionId" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
          <option value="">Auto-select first connected session</option>
          <% sessions.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.sessionName %> <%= s.phoneNumber ? '(' + s.phoneNumber + ')' : '' %> [<%= s.status %>]</option>
          <% }); %>
        </select>
        <p class="text-xs text-gray-400 mt-1">This session will be used automatically when sending messages via API without specifying a sessionId.</p>
      </div>
      <div class="flex gap-3 justify-end">
        <button type="button" onclick="document.getElementById('createKeyModal').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
        <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg">Generate</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<div class="bg-white rounded-2xl border border-pink-100 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-pink-100">
        <tr>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Name</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">API Key</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Default Session</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Status</th>
          <th class="text-left px-6 py-3 font-medium text-gray-700">Created</th>
          <th class="text-right px-6 py-3 font-medium text-gray-700">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% keys.forEach(key => { %>
          <% const linkedSession = sessionMap.get(key.sessionId); %>
          <tr class="hover:bg-pink-50/50 transition-colors">
            <td class="px-6 py-4 font-medium text-gray-900"><%= key.keyName || 'API Key' %></td>
            <td class="px-6 py-4">
              <code class="text-xs bg-gray-100 px-3 py-1.5 rounded-lg font-mono text-gray-600"><%= key.apiKey.substring(0, 20) %>...</code>
              <button onclick="navigator.clipboard.writeText('<%= key.apiKey %>')" class="ml-2 p-1.5 text-gray-400 hover:text-pink-500 transition-colors" title="Copy">
                <i class="ri-file-copy-line"></i>
              </button>
            </td>
            <td class="px-6 py-4">
              <% if (linkedSession) { %>
                <div class="flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full <%= linkedSession.status === 'connected' ? 'bg-green-500' : 'bg-gray-400' %>"></span>
                  <span class="text-xs text-gray-700"><%= linkedSession.sessionName %></span>
                </div>
                <span class="text-[10px] text-gray-400"><%= linkedSession.phoneNumber || 'No phone' %></span>
              <% } else { %>
                <span class="text-xs text-gray-400 italic">Auto-select</span>
              <% } %>
            </td>
            <td class="px-6 py-4">
              <span class="text-xs <%= key.isActive ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %> px-2 py-1 rounded-full"><%= key.isActive ? 'Active' : 'Inactive' %></span>
            </td>
            <td class="px-6 py-4 text-xs text-gray-500"><%= new Date(key.createdAt).toLocaleDateString() %></td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-2">
                <button onclick="document.getElementById('updateSessionModal-<%= key.id %>').showModal()" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Change Session">
                  <i class="ri-whatsapp-line"></i>
                </button>
                <form action="/api-keys/revoke/<%= key.id %>" method="POST" class="inline" onsubmit="return confirm('Revoke this key?')">
                  <button type="submit" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                    <i class="ri-delete-bin-line"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>

          <!-- Update Session Modal -->
          <dialog id="updateSessionModal-<%= key.id %>" class="modal">
            <div class="modal-box bg-white rounded-2xl max-w-md">
              <h3 class="font-bold text-lg text-gray-900 mb-4">Update Default Session</h3>
              <p class="text-sm text-gray-600 mb-4">Key: <strong><%= key.keyName %></strong></p>
              <form action="/api-keys/update-session/<%= key.id %>" method="POST">
                <div class="mb-4">
                  <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Session</label>
                  <select name="sessionId" class="w-full px-4 py-2.5 rounded-xl border border-pink-200 focus:border-pink-500 outline-none text-sm bg-white">
                    <option value="">Auto-select first connected session</option>
                    <% sessions.forEach(s => { %>
                      <option value="<%= s.id %>" <%= key.sessionId === s.id ? 'selected' : '' %>>
                        <%= s.sessionName %> <%= s.phoneNumber ? '(' + s.phoneNumber + ')' : '' %> [<%= s.status %>]
                      </option>
                    <% }); %>
                  </select>
                </div>
                <div class="flex gap-3 justify-end">
                  <button type="button" onclick="document.getElementById('updateSessionModal-<%= key.id %>').close()" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Cancel</button>
                  <button type="submit" class="px-6 py-2 btn-pink text-white text-sm font-medium rounded-lg">Update</button>
                </div>
              </form>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
          </dialog>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (!keys || keys.length === 0) { %>
    <div class="p-12 text-center">
      <p class="text-sm text-gray-500">No API keys generated yet</p>
      <button onclick="document.getElementById('createKeyModal').showModal()" class="mt-3 px-4 py-2 btn-pink text-white text-sm font-medium rounded-xl">Generate your first key</button>
    </div>
  <% } %>
</div>
