<!-- AI Auto-Reply Animated Demo -->
<style>
.ai-demo-brain {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  animation: ai-pulse 2s ease-in-out infinite;
}
@keyframes ai-pulse {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.4); }
  50% { transform: scale(1.05); box-shadow: 0 0 20px 10px rgba(139, 92, 246, 0.1); }
}
.ai-demo-brain-ring {
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  border: 2px solid rgba(139, 92, 246, 0.2);
  animation: ai-ring-spin 3s linear infinite;
}
@keyframes ai-ring-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.ai-demo-msg {
  padding: 10px 14px;
  border-radius: 14px;
  font-size: 12px;
  max-width: 220px;
  opacity: 0;
  transform: translateY(8px);
  transition: all 0.4s ease;
}
.ai-demo-msg.show {
  opacity: 1;
  transform: translateY(0);
}
.ai-demo-msg.in {
  background: #f3f4f6;
  color: #374151;
  align-self: flex-start;
}
.ai-demo-msg.out {
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
  color: white;
  align-self: flex-end;
}
.ai-demo-msg.ai {
  background: linear-gradient(135deg, #06b6d4, #8b5cf6);
  color: white;
  align-self: flex-end;
}
.ai-demo-thinking {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  background: #f3f4f6;
  border-radius: 14px;
  font-size: 11px;
  color: #6b7280;
  align-self: flex-start;
  opacity: 0;
}
.ai-demo-thinking.show { opacity: 1; }
.ai-demo-thinking-dot {
  width: 5px; height: 5px;
  background: #8b5cf6;
  border-radius: 50%;
  animation: ai-dot-blink 1s ease-in-out infinite;
}
.ai-demo-thinking-dot:nth-child(2) { animation-delay: 0.2s; }
.ai-demo-thinking-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes ai-dot-blink {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}
</style>

<div class="mb-6">
  <div class="bg-gradient-to-br from-violet-50 to-pink-50 rounded-2xl border border-violet-100 p-6 overflow-hidden">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="font-bold text-gray-900 text-lg flex items-center gap-2">
          <i class="ri-brain-line text-violet-600"></i> AI Auto-Reply Demo
        </h3>
        <p class="text-sm text-gray-500 mt-1">Smart responses powered by your local AI</p>
      </div>
      <span class="inline-flex items-center gap-1 px-3 py-1 bg-violet-100 text-violet-600 rounded-full text-xs font-medium">
        <i class="ri-magic-line"></i> AI Powered
      </span>
    </div>

    <div class="grid md:grid-cols-2 gap-6 items-center">
      <!-- AI Brain Visualization -->
      <div class="flex flex-col items-center justify-center py-4">
        <div class="ai-demo-brain mb-4">
          <div class="ai-demo-brain-ring"></div>
          <i class="ri-brain-line text-white text-2xl"></i>
        </div>
        <p class="text-sm font-medium text-gray-900">Ollama AI Engine</p>
        <p class="text-xs text-gray-500 mt-1">Runs locally on your server</p>
        <div class="mt-3 flex flex-wrap gap-2 justify-center">
          <span class="px-2 py-1 bg-white rounded-lg text-xs text-gray-600 border border-gray-100">Keyword Match</span>
          <span class="px-2 py-1 bg-white rounded-lg text-xs text-gray-600 border border-gray-100">AI Fallback</span>
          <span class="px-2 py-1 bg-white rounded-lg text-xs text-gray-600 border border-gray-100">Context Aware</span>
        </div>
      </div>

      <!-- Chat Simulation -->
      <div class="bg-white rounded-xl border border-gray-100 p-4">
        <div class="flex items-center gap-2 mb-3 pb-2 border-b border-gray-50">
          <div class="w-6 h-6 rounded-full bg-gradient-to-br from-violet-500 to-pink-500 flex items-center justify-center">
            <i class="ri-robot-2-line text-white text-xs"></i>
          </div>
          <span class="text-xs font-medium text-gray-700">AI Assistant</span>
        </div>
        <div class="flex flex-col gap-2 min-h-[180px]" id="aiChatDemo">
          <!-- Messages via JS -->
        </div>
      </div>
    </div>

    <div class="mt-4 grid grid-cols-3 gap-3">
      <div class="bg-white/60 rounded-xl p-3 text-center">
        <p class="text-xl font-bold text-violet-600">&lt;3s</p>
        <p class="text-xs text-gray-500">Response Time</p>
      </div>
      <div class="bg-white/60 rounded-xl p-3 text-center">
        <p class="text-xl font-bold text-pink-600">24/7</p>
        <p class="text-xs text-gray-500">Always On</p>
      </div>
      <div class="bg-white/60 rounded-xl p-3 text-center">
        <p class="text-xl font-bold text-cyan-600">Local</p>
        <p class="text-xs text-gray-500">No API Keys</p>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const chat = document.getElementById('aiChatDemo');
  const scenarios = [
    { customer: 'Hi, do you offer discounts?', ai: 'Yes! We have a 20% discount running this week. Use code SAVE20 at checkout! 🎉' },
    { customer: 'What are your business hours?', ai: 'We are open Monday-Saturday, 9 AM to 7 PM. Closed on Sundays! 🕘' },
    { customer: 'Can I get a refund?', ai: 'Of course! We offer a 7-day no-questions-asked refund policy. Just reach out to our support team.' },
  ];
  let idx = 0;

  function addMsg(text, type, delay) {
    return new Promise(resolve => {
      setTimeout(() => {
        const el = document.createElement('div');
        el.className = `ai-demo-msg ${type}`;
        el.textContent = text;
        chat.appendChild(el);
        requestAnimationFrame(() => el.classList.add('show'));
        chat.scrollTop = chat.scrollHeight;
        resolve();
      }, delay);
    });
  }

  function showThinking(delay) {
    return new Promise(resolve => {
      setTimeout(() => {
        const el = document.createElement('div');
        el.className = 'ai-demo-thinking';
        el.innerHTML = '<span class="ai-demo-thinking-dot"></span><span class="ai-demo-thinking-dot"></span><span class="ai-demo-thinking-dot"></span><span>AI thinking...</span>';
        chat.appendChild(el);
        requestAnimationFrame(() => el.classList.add('show'));
        chat.scrollTop = chat.scrollHeight;
        setTimeout(() => {
          el.remove();
          resolve();
        }, 1200);
      }, delay);
    });
  }

  async function runScenario() {
    chat.innerHTML = '';
    const s = scenarios[idx];
    await addMsg(s.customer, 'in', 500);
    await showThinking(600);
    await addMsg(s.ai, 'ai', 200);
    idx = (idx + 1) % scenarios.length;
    setTimeout(runScenario, 3500);
  }

  runScenario();
})();
</script>
