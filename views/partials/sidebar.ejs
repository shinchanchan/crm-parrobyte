<% 
// Menu items mapped to service keys for admin visibility control
const allMenuItems = [
  { href: '/dashboard', icon: 'ri-dashboard-line', label: 'Dashboard', serviceKey: null },
  { href: '/sessions', icon: 'ri-qr-code-line', label: 'WhatsApp Sessions', serviceKey: 'create_session' },
  { href: '/questionnaires', icon: 'ri-questionnaire-line', label: 'Questionnaires', serviceKey: 'session_questionnaire' },
  { href: '/meta-whatsapp', icon: 'ri-whatsapp-fill', label: 'Meta WhatsApp API', serviceKey: 'whatsapp_api_message' },
  { href: '/contacts', icon: 'ri-contacts-line', label: 'Contacts', serviceKey: 'create_contact' },
  { href: '/templates', icon: 'ri-file-list-line', label: 'Templates', serviceKey: 'create_template' },
  { href: '/bulk', icon: 'ri-send-plane-fill', label: 'Bulk Messages', serviceKey: 'send_message' },
  { href: '/schedule', icon: 'ri-calendar-schedule-line', label: 'Schedule', serviceKey: 'schedule_message' },
  { href: '/auto-reply', icon: 'ri-robot-line', label: 'Auto Reply', serviceKey: 'auto_reply' },
  { href: '/ai-config', icon: 'ri-brain-line', label: 'AI Assistant', serviceKey: 'ai_reply' },
  { href: '/social-automation', icon: 'ri-messenger-line', label: 'Social Auto', serviceKey: 'social_automation' },
  { href: '/youtube', icon: 'ri-youtube-line', label: 'YouTube', serviceKey: 'youtube_rule' },
  { href: '/instagram', icon: 'ri-instagram-line', label: 'Instagram', serviceKey: 'instagram_rule' },
  { href: '/forms', icon: 'ri-survey-line', label: 'Enquiry Forms', serviceKey: 'create_form' },
  { href: '/leads', icon: 'ri-user-search-line', label: 'Leads', serviceKey: 'lead_import' },
  { href: '/polls', icon: 'ri-bar-chart-box-line', label: 'Poll Results', serviceKey: 'send_message' },
  { href: '/lead-urls', icon: 'ri-link', label: 'Lead URLs', serviceKey: 'lead_import' },
  { href: '/scraper', icon: 'ri-map-pin-line', label: 'Business Scraper', serviceKey: 'scrape' },
  { href: '/api-keys', icon: 'ri-key-line', label: 'API Keys', serviceKey: 'api_key' },
  { href: '/webhooks', icon: 'ri-webhook-line', label: 'Webhooks', serviceKey: 'webhook' },
  { href: '/email', icon: 'ri-mail-send-line', label: 'Email Automation', serviceKey: 'send_email' },
  { href: '/billing', icon: 'ri-bill-line', label: 'Billing & Credits', serviceKey: null },
  { href: '/billing/services', icon: 'ri-apps-line', label: 'Services & Pricing', serviceKey: null },
  { href: '/developer', icon: 'ri-code-box-line', label: 'Developer', serviceKey: null },
  { href: '/help', icon: 'ri-question-line', label: 'Help', serviceKey: null },
];

// Filter by admin-configured visibility (null serviceKey = always visible)
const visibleSet = (typeof visibleServices !== 'undefined' && visibleServices) ? visibleServices : new Set();
const menuItems = allMenuItems
  .filter(item => {
    if (item.adminOnly && (!user || user.role !== 'admin')) return false;
    return !item.serviceKey || visibleSet.has(item.serviceKey);
  })
  .map(item => ({
    ...item,
    locked: false,
    href: item.href,
  }));

// Admin panel link for admins only
if (user && user.role === 'admin') {
  menuItems.push({ href: '/admin', icon: 'ri-shield-user-line', label: 'Admin Panel', feature: '', locked: false });
  menuItems.push({ href: '/feedback/admin', icon: 'ri-feedback-line', label: 'Feedbacks', feature: '', locked: false });
}
%>

<!-- Desktop Sidebar -->
<aside class="hidden lg:flex fixed left-0 top-0 h-screen w-64 bg-white border-r border-pink-100 flex-col z-40">
  <div class="p-6 border-b border-pink-100">
    <a href="/dashboard" class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl btn-pink flex items-center justify-center">
        <i class="ri-whatsapp-line text-white text-xl"></i>
      </div>
      <div>
        <h1 class="font-bold text-lg text-gray-900 leading-tight">ParroByte</h1>
        <p class="text-xs text-pink-500 font-medium">CRM</p>
      </div>
    </a>
  </div>

  <nav class="flex-1 overflow-y-auto py-4">
    <% menuItems.forEach(item => { %>
      <a href="<%= item.href %>"
         class="sidebar-link flex items-center gap-3 px-6 py-3 text-sm font-medium transition-colors
         <%= item.locked ? 'text-gray-400 cursor-not-allowed hover:bg-gray-50' : (path === item.href ? 'active text-pink-600 bg-gradient-to-r from-pink-50 to-transparent' : 'text-gray-600 hover:text-pink-600 hover:bg-pink-50/50') %>">
        <i class="<%= item.icon %> text-lg <%= item.locked ? 'text-gray-300' : (path === item.href ? 'text-pink-600' : 'text-gray-400') %>"></i>
        <span><%= item.label %></span>
        <% if (item.locked) { %>
          <i class="ri-lock-line text-xs text-gray-300 ml-auto" title="Upgrade to unlock"></i>
        <% } %>
      </a>
    <% }); %>
  </nav>

  <div class="p-4 border-t border-pink-100">
    <a href="/auth/profile" class="flex items-center gap-3 p-3 rounded-xl hover:bg-pink-50 transition-colors">
      <div class="w-10 h-10 rounded-full bg-gradient-to-br from-pink-400 to-pink-600 flex items-center justify-center text-white font-bold text-sm">
        <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-gray-900 truncate"><%= user.name %></p>
        <p class="text-xs text-pink-500 capitalize">₹<%= parseFloat(creditBalance).toFixed(2) %></p>
      </div>
    </a>
    <!-- PWA Install Button (hidden until browser supports it) -->
    <button id="pwaInstallBtn" onclick="installPWA()" class="mt-2 hidden w-full flex items-center gap-2 px-3 py-2 text-sm text-pink-600 hover:bg-pink-50 rounded-lg transition-colors">
      <i class="ri-download-cloud-2-line"></i> Install App
    </button>

    <a href="/logout" class="mt-2 flex items-center gap-2 px-3 py-2 text-sm text-red-500 hover:bg-red-50 rounded-lg transition-colors">
      <i class="ri-logout-box-r-line"></i> Logout
    </a>
  </div>
</aside>

<!-- Mobile Overlay -->
<div id="mobile-sidebar" class="mobile-menu fixed inset-0 z-50 lg:hidden" style="touch-action: pan-x pan-y pinch-zoom;">
  <div class="absolute inset-0 bg-black bg-opacity-50" onclick="toggleMobileMenu()"></div>
  <aside class="absolute left-0 top-0 h-full w-72 bg-white shadow-xl flex flex-col">
    <div class="p-5 border-b border-pink-100 flex items-center justify-between">
      <a href="/dashboard" class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl btn-pink flex items-center justify-center">
          <i class="ri-whatsapp-line text-white text-lg"></i>
        </div>
        <div>
          <h1 class="font-bold text-gray-900 leading-tight">ParroByte CRM</h1>
        </div>
      </a>
      <button onclick="toggleMobileMenu()" class="p-2 hover:bg-pink-50 rounded-lg">
        <i class="ri-close-line text-xl text-gray-600"></i>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto py-3">
      <% menuItems.forEach(item => { %>
        <a href="<%= item.href %>"
           class="flex items-center gap-3 px-5 py-3 text-sm font-medium transition-colors
           <%= item.locked ? 'text-gray-400 cursor-not-allowed' : (path === item.href ? 'active text-pink-600 bg-pink-50' : 'text-gray-600 hover:text-pink-600') %>">
          <i class="<%= item.icon %> text-lg <%= item.locked ? 'text-gray-300' : (path === item.href ? 'text-pink-600' : 'text-gray-400') %>"></i>
          <span><%= item.label %></span>
          <% if (item.locked) { %>
            <i class="ri-lock-line text-xs text-gray-300 ml-auto"></i>
          <% } %>
        </a>
      <% }); %>
    </nav>

    <div class="p-4 border-t border-pink-100">
      <a href="/auth/profile" class="flex items-center gap-3 p-3 rounded-xl hover:bg-pink-50">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-pink-400 to-pink-600 flex items-center justify-center text-white font-bold text-sm">
          <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900"><%= user.name %></p>
          <p class="text-xs text-pink-500 capitalize">₹<%= parseFloat(creditBalance).toFixed(2) %></p>
        </div>
      </a>
      <!-- PWA Install Button Mobile (hidden until browser supports it) -->
      <button id="pwaInstallBtnMobile" onclick="installPWA()" class="mt-2 hidden w-full flex items-center gap-2 px-3 py-2 text-sm text-pink-600 hover:bg-pink-50 rounded-lg">
        <i class="ri-download-cloud-2-line"></i> Install App
      </button>

      <a href="/logout" class="mt-2 flex items-center gap-2 px-3 py-2 text-sm text-red-500 hover:bg-red-50 rounded-lg">
        <i class="ri-logout-box-r-line"></i> Logout
      </a>
    </div>
  </aside>
</div>
