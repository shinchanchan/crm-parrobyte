<header class="bg-white border-b border-pink-100 sticky top-0 z-30 px-4 lg:px-8 py-4">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <button id="menu-toggle" onclick="toggleMobileMenu()" class="lg:hidden p-2 hover:bg-pink-50 rounded-lg transition-colors">
        <i class="ri-menu-line text-xl text-gray-700"></i>
      </button>
      <div>
        <h2 class="text-xl font-bold text-gray-900"><%= title.split(' - ')[0] %></h2>
        <p class="text-xs text-gray-500 hidden sm:block"><%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
      </div>
    </div>
    
    <div class="flex items-center gap-3">
      <% if (typeof activeSubscription !== 'undefined' && activeSubscription) { %>
        <a href="/billing" class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold bg-gradient-to-r from-green-50 to-green-100 text-green-700 border border-green-200 hover:shadow-md transition-all" title="Subscription active until <%= new Date(activeSubscription.subscription.expiresAt).toLocaleDateString('en-IN') %>">
          <i class="ri-vip-crown-line"></i>
          <span><%= activeSubscription.plan.displayName %></span>
        </a>
      <% } %>
      <% if (typeof creditBalance !== 'undefined') { %>
        <a href="/billing" class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold bg-gradient-to-r from-pink-50 to-pink-100 text-pink-700 border border-pink-200 hover:shadow-md transition-all">
          <i class="ri-coins-line"></i>
          <span>₹<%= parseFloat(creditBalance).toFixed(2) %></span>
        </a>
      <% } %>
      
      <a href="/auth/profile" class="w-9 h-9 rounded-full bg-gradient-to-br from-pink-400 to-pink-600 flex items-center justify-center text-white font-bold text-sm hover:shadow-lg transition-shadow lg:hidden">
        <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
      </a>
    </div>
  </div>
</header>
