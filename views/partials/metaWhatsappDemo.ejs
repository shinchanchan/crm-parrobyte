<!-- Meta WhatsApp API Animated Demo -->
<style>
.meta-demo-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 8px;
  border-radius: 6px;
  font-size: 10px;
  font-weight: 500;
}
.meta-demo-template {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 8px 10px;
  font-size: 11px;
  transition: all 0.3s ease;
  cursor: pointer;
}
.meta-demo-template:hover {
  border-color: #ec4899;
  box-shadow: 0 2px 8px rgba(236,72,153,0.1);
}
.meta-demo-template.active {
  border-color: #ec4899;
  background: #fdf2f8;
}
.meta-demo-phone-green {
  background: linear-gradient(180deg, #075e54 0%, #128c7e 100%);
  border-radius: 24px;
  padding: 12px;
  width: 170px;
  box-shadow: 0 20px 40px -10px rgba(0,0,0,0.3);
  border: 3px solid #0c5e54;
}
.meta-demo-msg-green {
  background: #dcf8c6;
  color: #303030;
  padding: 6px 10px;
  border-radius: 8px 8px 0 8px;
  font-size: 10px;
  max-width: 85%;
  align-self: flex-end;
  opacity: 0;
  transform: translateY(6px);
  transition: all 0.3s ease;
}
.meta-demo-msg-green.show {
  opacity: 1;
  transform: translateY(0);
}
</style>

<div class="mb-6">
  <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-2xl border border-green-100 p-6 overflow-hidden">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="font-bold text-gray-900 text-lg flex items-center gap-2">
          <i class="ri-whatsapp-fill text-green-600"></i> Meta WhatsApp API Demo
        </h3>
        <p class="text-sm text-gray-500 mt-1">Official API — no ban risk, template messaging</p>
      </div>
      <span class="inline-flex items-center gap-1 px-3 py-1 bg-green-100 text-green-600 rounded-full text-xs font-medium">
        <i class="ri-shield-check-line"></i> Official API
      </span>
    </div>

    <div class="grid md:grid-cols-3 gap-4 items-center">
      <!-- Template Selector -->
      <div class="space-y-2">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">1. Select Template</p>
        <div class="space-y-2" id="metaTemplates">
          <div class="meta-demo-template active" data-tpl="welcome">
            <div class="flex items-center gap-2">
              <i class="ri-mail-send-line text-green-500"></i>
              <span class="font-medium">Welcome Message</span>
            </div>
            <p class="text-[10px] text-gray-400 mt-1">Hello {{name}}, welcome to...</p>
          </div>
          <div class="meta-demo-template" data-tpl="order">
            <div class="flex items-center gap-2">
              <i class="ri-shopping-bag-line text-blue-500"></i>
              <span class="font-medium">Order Update</span>
            </div>
            <p class="text-[10px] text-gray-400 mt-1">Your order #{{order_id}} is...</p>
          </div>
          <div class="meta-demo-template" data-tpl="promo">
            <div class="flex items-center gap-2">
              <i class="ri-coupon-line text-pink-500"></i>
              <span class="font-medium">Promo Alert</span>
            </div>
            <p class="text-[10px] text-gray-400 mt-1">Get 20% off with code...</p>
          </div>
        </div>
      </div>

      <!-- Phone Preview -->
      <div class="flex justify-center">
        <div class="meta-demo-phone-green">
          <div class="bg-white/10 rounded-xl p-2 h-[240px] flex flex-col">
            <div class="flex items-center gap-2 mb-2 pb-2 border-b border-white/10">
              <div class="w-6 h-6 rounded-full bg-green-200 flex items-center justify-center text-[10px]">👤</div>
              <span class="text-white text-[10px] font-medium">+91 98765 43210</span>
            </div>
            <div class="flex-1 flex flex-col gap-1.5 overflow-hidden" id="metaChatPreview">
              <!-- Messages via JS -->
            </div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="space-y-3">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">3. Delivery Status</p>
        <div class="space-y-2">
          <div class="flex items-center justify-between p-2.5 bg-white rounded-lg border border-gray-100">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-green-500"></div>
              <span class="text-xs text-gray-600">Delivered</span>
            </div>
            <span class="text-xs font-bold text-green-600" id="metaDelivered">0</span>
          </div>
          <div class="flex items-center justify-between p-2.5 bg-white rounded-lg border border-gray-100">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              <span class="text-xs text-gray-600">Read</span>
            </div>
            <span class="text-xs font-bold text-blue-600" id="metaRead">0</span>
          </div>
          <div class="flex items-center justify-between p-2.5 bg-white rounded-lg border border-gray-100">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-red-500"></div>
              <span class="text-xs text-gray-600">Failed</span>
            </div>
            <span class="text-xs font-bold text-red-600">0</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const chat = document.getElementById('metaChatPreview');
  const templates = document.querySelectorAll('.meta-demo-template');
  const delivered = document.getElementById('metaDelivered');
  const read = document.getElementById('metaRead');

  const msgs = [
    'Hello Rahul! Welcome to ParroByte CRM. 🎉',
    'Your order #12345 has been shipped! 📦',
    'Get 20% off your next purchase with code SAVE20! 💰',
  ];
  let idx = 0;

  function showMsg(text, delay) {
    setTimeout(() => {
      chat.innerHTML = '';
      const el = document.createElement('div');
      el.className = 'meta-demo-msg-green';
      el.textContent = text;
      chat.appendChild(el);
      requestAnimationFrame(() => el.classList.add('show'));

      templates.forEach((t, i) => {
        t.classList.toggle('active', i === idx);
      });

      let d = parseInt(delivered.textContent) || 0;
      let r = parseInt(read.textContent) || 0;
      delivered.textContent = d + 1;
      setTimeout(() => { read.textContent = r + 1; }, 800);

      idx = (idx + 1) % msgs.length;
      setTimeout(() => showMsg(msgs[idx], 2000), 2500);
    }, delay);
  }

  showMsg(msgs[0], 500);
})();
</script>
